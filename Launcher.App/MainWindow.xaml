<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:models="clr-namespace:Launcher.App.Models"
        x:Class="Launcher.App.MainWindow"
        x:Name="RootWindow"
        Title="Launcher"
        Width="980"
        Height="640"
        MinWidth="640"
        MinHeight="420"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        ResizeMode="CanResize">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="48"
                            CornerRadius="8"
                            GlassFrameThickness="-1"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="46" />
            <Setter Property="Margin" Value="8,3" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#24FFFFFF" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#35FFFFFF" />
                </Trigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="#0891fe" />
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="12"
                                              Color="#2A96ee"
                                              Opacity="0.2"
                                              ShadowDepth="0" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CaptionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Foreground" Value="#E8E8E8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#24FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#38FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccountButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#22FFFFFF" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#34FFFFFF" />
                </Trigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="#260891FE" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="8"
            BorderBrush="#6E4e4e4e"
            BorderThickness="1"
            Background="Transparent"
            SnapsToDevicePixels="True">
        <Grid Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="MenuColumn" Width="62" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Column="0"
                    Grid.RowSpan="2"
                    BorderBrush="#554e4e4e"
                    BorderThickness="0,0,1,0"
                    Background="Transparent">
                <DockPanel LastChildFill="True">
                    <Button DockPanel.Dock="Bottom"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="ToggleMenu_Click">
                        <StackPanel Orientation="Horizontal" Margin="8,0">
                            <TextBlock Width="30"
                                       Text="&#xE700;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="18"
                                       TextAlignment="Center" />
                            <TextBlock Margin="12,0,0,0"
                                       Text="菜单"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsMenuExpanded, ElementName=RootWindow, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}" />
                        </StackPanel>
                    </Button>

                    <ItemsControl ItemsSource="{Binding NavigationItems}" Margin="0,22,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:NavigationItem}">
                                <Button Style="{StaticResource MenuButtonStyle}"
                                        Click="Navigation_Click">
                                    <StackPanel Orientation="Horizontal" Margin="8,0">
                                        <TextBlock Width="30"
                                                   Text="{Binding Icon}"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="22"
                                                   TextAlignment="Center" />
                                        <TextBlock Margin="12,0,0,0"
                                                   Text="{Binding Page, Converter={StaticResource PageTitleConverter}}"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding IsMenuExpanded, ElementName=RootWindow, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

            <Border Grid.Column="1"
                    Grid.RowSpan="2"
                    Background="#E0151515" />

            <Grid Grid.Column="1"
                  Grid.RowSpan="2"
                  Visibility="{Binding CurrentPage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=Account}">
                <Border Width="224"
                        Margin="24,48,0,38"
                        HorizontalAlignment="Left"
                        Background="#5A4A4A4A"
                        BorderBrush="#35FFFFFF"
                        BorderThickness="1"
                        CornerRadius="14">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Accounts}"
                                      Margin="14,18,14,10">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:LauncherAccount}">
                                    <Button Style="{StaticResource AccountButtonStyle}"
                                            Click="Account_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="32" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Width="26"
                                                    Height="26"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    ClipToBounds="True">
                                                <Image Source="{Binding AvatarUrl}"
                                                       RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                            </Border>

                                            <TextBlock Grid.Column="1"
                                                       Margin="12,0,0,0"
                                                       Text="{Binding DisplayName}"
                                                       Foreground="#F4F4F4"
                                                       FontSize="16"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <Grid Margin="284,72,40,40">
                    <TextBlock Text="&#x9009;&#x62E9;&#x8D26;&#x53F7;&#x4EE5;&#x6D4F;&#x89C8;&#x6216;&#x4FEE;&#x6539;&#x8BBE;&#x7F6E;&#x3002;"
                               Foreground="#B8FFFFFF"
                               FontSize="18"
                               VerticalAlignment="Top">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedAccount}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedAccount}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <Image Width="64"
                               Height="64"
                               HorizontalAlignment="Left"
                               Source="{Binding SelectedAccount.AvatarUrl}"
                               RenderOptions.BitmapScalingMode="NearestNeighbor" />
                        <TextBlock Margin="0,18,0,0"
                                   Text="{Binding SelectedAccount.DisplayName}"
                                   Foreground="#F4F4F4"
                                   FontSize="24"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding SelectedAccount.AccountKindText}"
                                   Foreground="#AFFFFFFF"
                                   FontSize="13" />
                    </StackPanel>
                </Grid>
            </Grid>

            <StackPanel Grid.Column="1"
                        Grid.RowSpan="2"
                        Margin="28,64,28,28"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentPage}" Value="Account">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="{Binding CurrentPage, Converter={StaticResource PageTitleConverter}}"
                           Foreground="#F4F4F4"
                           FontSize="24"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding StatusMessage}"
                           Margin="0,12,0,0"
                           Foreground="#B8FFFFFF"
                           FontSize="13" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Grid.Row="0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,8,12,0">
                <Button Style="{StaticResource CaptionButtonStyle}"
                        Click="Minimize_Click">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               FontSize="10"
                               Text="&#xE921;" />
                </Button>
                <Button Style="{StaticResource CaptionButtonStyle}"
                        Margin="4,0,0,0"
                        Click="Close_Click">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               FontSize="12"
                               Text="&#xE8BB;" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
