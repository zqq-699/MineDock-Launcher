<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:models="clr-namespace:Launcher.App.Models"
        xmlns:controls="clr-namespace:Launcher.App.Controls"
        xmlns:views="clr-namespace:Launcher.App.Views"
        x:Class="Launcher.App.MainWindow"
        x:Name="RootWindow"
        Title="Launcher"
        Width="980"
        Height="640"
        MinWidth="960"
        MinHeight="420"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        FontFamily="Microsoft YaHei UI"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="48"
                            CornerRadius="8"
                            GlassFrameThickness="-1"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border CornerRadius="8"
            BorderBrush="#344e4e4e"
            BorderThickness="1"
            Background="Transparent"
            SnapsToDevicePixels="True">
        <Grid Background="Transparent">
            <Grid x:Name="WindowContentLayer">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="MenuColumn" Width="62" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="48" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Column="0"
                        Grid.RowSpan="2"
                        BorderBrush="#284e4e4e"
                        BorderThickness="0,0,1,0"
                        Background="Transparent"
                        ClipToBounds="True">
                    <DockPanel LastChildFill="True">
                        <Button DockPanel.Dock="Bottom"
                                Style="{StaticResource NavigationMenuButtonStyle}"
                                Click="ToggleMenu_Click">
                            <StackPanel Orientation="Horizontal" Margin="8,0">
                                <TextBlock Text="&#xE700;"
                                           Style="{StaticResource NavigationMenuGlyphStyle}" />
                                <TextBlock Text="&#x83DC;&#x5355;"
                                           Style="{StaticResource NavigationMenuTextStyle}" />
                            </StackPanel>
                        </Button>

                        <ItemsControl ItemsSource="{Binding NavigationItems}" Margin="0,22,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:NavigationItem}">
                                    <Button Style="{StaticResource NavigationMenuButtonStyle}"
                                            Click="Navigation_Click">
                                        <StackPanel Orientation="Horizontal" Margin="8,0">
                                            <Grid Width="30">
                                                <TextBlock Text="{Binding Icon}"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="22"
                                                           TextAlignment="Center"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasAvatar}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <Border>
                                                    <Border.Style>
                                                        <Style TargetType="Border" BasedOn="{StaticResource NavigationMenuAvatarContainerStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasAvatar}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Image Source="{Binding AvatarUrl}"
                                                           Stretch="Fill"
                                                           SnapsToDevicePixels="True"
                                                           RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                                </Border>
                                            </Grid>
                                            <TextBlock Text="{Binding Page, Converter={StaticResource PageTitleConverter}}"
                                                       Style="{StaticResource NavigationMenuTextStyle}" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1"
                        Grid.RowSpan="2"
                        Background="#E0151515" />

                <Grid x:Name="PageTransitionHost"
                      Grid.Column="1"
                      Grid.RowSpan="2"
                      ClipToBounds="True">
                    <views:AccountPageView x:Name="AccountPageView"
                                           DataContext="{Binding AccountPage}"
                                           Visibility="{Binding DataContext.CurrentPage, ElementName=RootWindow, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=Account}" />
                    <views:GeneralPageView x:Name="GeneralPageView" />
                </Grid>

                <StackPanel Grid.Column="1"
                            Grid.Row="0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,8,12,0">
                    <Button Style="{StaticResource WindowCaptionButtonStyle}"
                            Click="Minimize_Click">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="10"
                                   Text="&#xE921;" />
                    </Button>
                    <Button Style="{StaticResource WindowCaptionButtonStyle}"
                            Margin="4,0,0,0"
                            Click="Close_Click">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   Text="&#xE8BB;" />
                    </Button>
                </StackPanel>
            </Grid>

            <controls:DialogHost x:Name="AddAccountDialogHost"
                                 Grid.ColumnSpan="2"
                                 Grid.RowSpan="2"
                                 DialogWidth="420"
                                 DataContext="{Binding AccountPage}">
                <views:AddAccountDialogView BackRequested="BackAddAccount_Click"
                                            CancelRequested="CancelAddAccount_Click"
                                            ConfirmRequested="ConfirmAddAccount_Click" />
            </controls:DialogHost>

            <controls:DialogHost x:Name="DeleteAccountDialogHost"
                                 Grid.ColumnSpan="2"
                                 Grid.RowSpan="2"
                                 DialogWidth="380"
                                 DataContext="{Binding AccountPage}">
                <views:DeleteAccountDialogView CancelRequested="CancelDeleteAccount_Click"
                                               ConfirmRequested="ConfirmDeleteAccount_Click" />
            </controls:DialogHost>

            <controls:DialogHost x:Name="RenameAccountDialogHost"
                                 Grid.ColumnSpan="2"
                                 Grid.RowSpan="2"
                                 DialogWidth="420"
                                 DataContext="{Binding AccountPage}">
                <views:RenameAccountDialogView CancelRequested="CancelRenameAccount_Click"
                                               ConfirmRequested="ConfirmRenameAccount_Click" />
            </controls:DialogHost>
        </Grid>
    </Border>
</Window>
