<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Launcher.App.Controls"
             xmlns:models="clr-namespace:Launcher.App.Models"
             xmlns:res="clr-namespace:Launcher.App.Resources"
             x:Class="Launcher.App.Views.Shell.ShellNavigationView"
             x:Name="Root">
    <Border BorderBrush="#284e4e4e"
            BorderThickness="0,0,1,0"
            Background="Transparent"
            ClipToBounds="True">
        <DockPanel LastChildFill="True">
            <Button DockPanel.Dock="Bottom"
                    Style="{StaticResource NavigationMenuButtonStyle}"
                    Command="{Binding ToggleMenuCommand}">
                <StackPanel Orientation="Horizontal" Margin="8,0">
                    <Grid Width="30">
                        <controls:SvgIcon Width="24"
                                          Height="24"
                                          IconKey="main_menu_expand"
                                          Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center">
                            <controls:SvgIcon.Style>
                                <Style TargetType="{x:Type controls:SvgIcon}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMenuExpanded, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </controls:SvgIcon.Style>
                        </controls:SvgIcon>

                        <controls:SvgIcon Width="24"
                                          Height="24"
                                          IconKey="main_menu_fold"
                                          Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center">
                            <controls:SvgIcon.Style>
                                <Style TargetType="{x:Type controls:SvgIcon}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMenuExpanded, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </controls:SvgIcon.Style>
                        </controls:SvgIcon>
                    </Grid>
                    <TextBlock Text="{x:Static res:Strings.Menu_Button}"
                               Style="{StaticResource NavigationMenuTextStyle}" />
                </StackPanel>
            </Button>

            <Button DockPanel.Dock="Bottom"
                    DataContext="{Binding DownloadTasksNavigationItem}"
                    Style="{StaticResource NavigationMenuButtonStyle}"
                    Command="{Binding DataContext.NavigateCommand, ElementName=Root}"
                    CommandParameter="{Binding}">
                <Grid Margin="3,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0"
                          Width="40"
                          Height="40"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center">
                        <Ellipse x:Name="DownloadTaskPulseCircle"
                                 Width="40"
                                 Height="40"
                                 Fill="#66808080"
                                 Opacity="0"
                                 CacheMode="BitmapCache"
                                 IsHitTestVisible="False"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="DownloadTaskPulseScale"
                                                ScaleX="0.9"
                                                ScaleY="0.9" />
                            </Ellipse.RenderTransform>
                        </Ellipse>

                        <controls:SvgIcon Width="24"
                                          Height="24"
                                          IconKey="{Binding IconKey}"
                                          Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Grid>

                    <TextBlock Grid.Column="1"
                               Margin="7,0,0,0"
                               Text="{Binding Page, Converter={StaticResource PageTitleConverter}}"
                               Style="{StaticResource NavigationMenuTextStyle}" />
                </Grid>
            </Button>

            <ItemsControl ItemsSource="{Binding NavigationItems}" Margin="0,22,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:NavigationItem}">
                        <Button Style="{StaticResource NavigationMenuButtonStyle}"
                                Command="{Binding DataContext.NavigateCommand, ElementName=Root}"
                                CommandParameter="{Binding}">
                            <StackPanel Orientation="Horizontal" Margin="8,0">
                                <Grid Width="30">
                                    <controls:SvgIcon Width="24"
                                                      Height="24"
                                                      IconKey="{Binding IconKey}"
                                                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center">
                                        <controls:SvgIcon.Style>
                                            <Style TargetType="{x:Type controls:SvgIcon}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IconKey}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HasAvatar}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </controls:SvgIcon.Style>
                                    </controls:SvgIcon>

                                    <TextBlock Text="{Binding Icon}"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="22"
                                               TextAlignment="Center"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IconKey}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HasAvatar}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource NavigationMenuAvatarContainerStyle}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasAvatar}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Image Source="{Binding AvatarUrl}"
                                               Stretch="Fill"
                                               SnapsToDevicePixels="True"
                                               RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                    </Border>
                                </Grid>
                                <TextBlock Text="{Binding Page, Converter={StaticResource PageTitleConverter}}"
                                           Style="{StaticResource NavigationMenuTextStyle}" />
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </DockPanel>
    </Border>
</UserControl>
