<UserControl x:Class="Launcher.App.Views.HomeLaunchGameListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Launcher.App.Controls"
             xmlns:res="clr-namespace:Launcher.App.Resources"
             xmlns:views="clr-namespace:Launcher.App.Views"
             Focusable="False">
    <UserControl.Resources>
        <DataTemplate x:Key="HomeLaunchInstanceMenuItemContentTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{StaticResource SecondaryMenuIconColumnWidth}" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Image Width="32"
                       Height="32"
                       Source="{Binding IconSource}"
                       Stretch="Fill"
                       SnapsToDevicePixels="True"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"
                            Margin="10,0,8,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding Name}"
                               TextTrimming="CharacterEllipsis"
                               Style="{StaticResource HomeLaunchInstanceNameTextStyle}" />
                    <TextBlock Text="{Binding Subtitle}"
                               TextTrimming="CharacterEllipsis"
                               Style="{StaticResource HomeLaunchInstanceSubtitleTextStyle}" />
                </StackPanel>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid x:Name="HomeLaunchMenuHost"
          Width="272"
          HorizontalAlignment="Left"
          VerticalAlignment="Stretch"
          Panel.ZIndex="4">
        <controls:SecondaryMenuFrame Title="{x:Static res:Strings.Home_LaunchInstanceMenuTitle}"
                                     UseInternalScrollViewer="False">
            <controls:SecondaryMenuFrame.MenuContent>
                <Grid>
                    <TextBlock Text="{x:Static res:Strings.Home_NoLaunchInstances}"
                               TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource HomeLaunchInstanceEmptyTextStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasNoLaunchInstances}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ListBox Tag="HomeLaunchInstanceList"
                             ItemsSource="{Binding LaunchInstances}"
                             Style="{StaticResource HomeLaunchInstanceListBoxStyle}"
                             ItemContainerStyle="{StaticResource ListPageVirtualizedListBoxItemStyle}"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             VirtualizingPanel.ScrollUnit="Pixel">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Button Height="54"
                                        Style="{StaticResource SecondaryMenuButtonStyle}"
                                        Command="{Binding DataContext.SelectLaunchInstanceCommand, RelativeSource={RelativeSource AncestorType={x:Type views:HomeLaunchGameListView}}}"
                                        CommandParameter="{Binding}">
                                    <ContentPresenter Content="{Binding}"
                                                      ContentTemplate="{StaticResource HomeLaunchInstanceMenuItemContentTemplate}" />
                                </Button>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </controls:SecondaryMenuFrame.MenuContent>
        </controls:SecondaryMenuFrame>
    </Grid>
</UserControl>
