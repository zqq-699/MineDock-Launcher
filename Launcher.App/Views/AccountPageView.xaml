<UserControl x:Class="Launcher.App.Views.AccountPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
             xmlns:accountModels="clr-namespace:Launcher.Application.Accounts;assembly=Launcher.Application"
             xmlns:models="clr-namespace:Launcher.App.Models"
             xmlns:controls="clr-namespace:Launcher.App.Controls"
             xmlns:views="clr-namespace:Launcher.App.Views"
             xmlns:res="clr-namespace:Launcher.App.Resources"
             x:Name="Root"
             Focusable="False">
    <Grid x:Name="PageRoot">
        <controls:SecondaryMenuFrame Title="{x:Static res:Strings.Account_ListTitle}"
                                     controls:SecondaryMenuOptionButton.RefreshRequested="SecondaryMenuOptionButton_OnRefreshRequested">
            <controls:SecondaryMenuFrame.MenuContent>
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding Accounts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type accountModels:LauncherAccount}">
                                <Grid>
                                    <controls:SecondaryMenuOptionButton Text="{Binding DisplayName}"
                                                                        IconMode="Avatar"
                                                                        AvatarSource="{Binding AvatarUrl}"
                                                                        IsSelected="{Binding IsSelected}"
                                                                        TextMargin="4,0,42,0"
                                                                        Command="{Binding DataContext.SelectAccountItemCommand, RelativeSource={RelativeSource AncestorType={x:Type views:AccountPageView}}}"
                                                                        CommandParameter="{Binding}" />

                                    <Button HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Margin="0,0,6,6"
                                            Command="{Binding DataContext.RequestDeleteAccountCommand, RelativeSource={RelativeSource AncestorType={x:Type views:AccountPageView}}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryMenuDeleteButtonStyle}">
                                                <Setter Property="Opacity" Value="0" />
                                                <Setter Property="IsHitTestVisible" Value="False" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type Grid}}}" Value="True">
                                                        <Setter Property="Opacity" Value="1" />
                                                        <Setter Property="IsHitTestVisible" Value="True" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <controls:SvgIcon Width="16"
                                                          Height="16"
                                                          IconKey="general/general_delete"
                                                          Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <controls:SecondaryMenuOptionButton Text="{x:Static res:Strings.Account_AddButton}"
                                                        IconMode="Svg"
                                                        IconKey="account_page/account_page_add_account"
                                                        IconWidth="24"
                                                        IconHeight="24"
                                                        Command="{Binding RequestAddAccountCommand}" />
                </StackPanel>
            </controls:SecondaryMenuFrame.MenuContent>
        </controls:SecondaryMenuFrame>

        <Grid Margin="284,72,24,24">
            <TextBlock Text="{x:Static res:Strings.Account_EmptySelection}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource PageEmptyStateTextStyle}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedAccount}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <ScrollViewer x:Name="AccountDetailsScrollViewer">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer" BasedOn="{StaticResource MainContentScrollViewerStyle}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedAccount}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>

                <StackPanel>
                    <Image Width="64"
                           Height="64"
                           HorizontalAlignment="Left"
                           Source="{Binding SelectedAccount.AvatarUrl}"
                           Stretch="Fill"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="NearestNeighbor" />
                    <Grid Margin="0,18,0,0"
                          HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding SelectedAccount.DisplayName}"
                                   Style="{StaticResource PageTitleTextStyle}"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Margin="10,0,0,0"
                                Style="{StaticResource InlineIconButtonStyle}"
                                Command="{Binding RequestRenameAccountCommand}">
                            <controls:SvgIcon Width="16"
                                              Height="16"
                                              IconKey="general/general_edit"
                                              Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                        </Button>
                    </Grid>
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding SelectedAccount.IsOffline, Converter={StaticResource AccountKindTextConverter}}"
                               Foreground="#AFFFFFFF"
                               FontSize="13" />

                    <StackPanel Margin="0,26,0,0"
                                MaxWidth="480"
                                HorizontalAlignment="Left">
                        <GroupBox Header="{x:Static res:Strings.Account_UuidHeader}"
                                  Style="{StaticResource LauncherContentSectionStyle}">
                            <StackPanel>
                                <Border Style="{StaticResource SectionFieldSurfaceStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding OfflineUuid.SelectedAccountUuidText}"
                                                   Foreground="#E8FFFFFF"
                                                   FontSize="14"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center" />
                                        <Button Grid.Column="1"
                                                Margin="10,-4,-6,-4"
                                                Style="{StaticResource InlineIconButtonStyle}"
                                                Command="{Binding CopySelectedUuidCommand}">
                                            <controls:SvgIcon Width="16"
                                                              Height="16"
                                                              IconKey="general/general_copy"
                                                              Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                                        </Button>
                                    </Grid>
                                </Border>

                                <Grid Margin="0,12,0,0"
                                      Visibility="{Binding OfflineUuid.HasSelectedOfflineAccount, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="220" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{x:Static res:Strings.Account_OfflineUuidModeLabel}"
                                               Foreground="#CFFFFFFF"
                                               FontSize="13"
                                               VerticalAlignment="Center" />
                                    <controls:AnimatedComboBox Grid.Column="1"
                                                               ItemsSource="{Binding OfflineUuid.OfflineUuidOptions}"
                                                               SelectedItem="{Binding OfflineUuid.SelectedOfflineUuidOption, Mode=TwoWay}"
                                                               Style="{StaticResource LauncherComboBoxStyle}"
                                                               shell:WindowChrome.IsHitTestVisibleInChrome="True">
                                        <controls:AnimatedComboBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type models:OfflineUuidModeOption}">
                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="#F4F4F4"
                                                           FontSize="13"
                                                           VerticalAlignment="Center" />
                                            </DataTemplate>
                                        </controls:AnimatedComboBox.ItemTemplate>
                                    </controls:AnimatedComboBox>
                                </Grid>

                                <Grid Margin="0,12,0,0"
                                      Visibility="{Binding OfflineUuid.HasManualUuidEditor, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0"
                                             Height="36"
                                             FontSize="12"
                                             Text="{Binding OfflineUuid.ManualUuidText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource LauncherDialogTextBoxStyle}" />
                                    <Button Grid.Column="1"
                                            Margin="10,0,0,0"
                                            Style="{StaticResource LauncherPrimaryDialogButtonStyle}"
                                            Content="{x:Static res:Strings.Apply_Button}"
                                            IsEnabled="{Binding OfflineUuid.CanApplyManualUuid}"
                                            Command="{Binding OfflineUuid.ApplyManualUuidCommand}" />

                                    <TextBlock Grid.Row="1"
                                               Grid.ColumnSpan="2"
                                               Margin="2,8,0,0"
                                               Text="{x:Static res:Strings.Account_OfflineUuidInvalid}"
                                               Foreground="#FFFF8A8A"
                                               FontSize="12"
                                               Visibility="{Binding OfflineUuid.IsManualUuidInvalid, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}" />
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Margin="0,22,0,0"
                                  Header="{x:Static res:Strings.Account_SkinHeader}"
                                  Style="{StaticResource LauncherContentSectionStyle}">
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource LauncherDialogButtonStyle}"
                                        Content="{x:Static res:Strings.Refresh_Button}"
                                        IsEnabled="{Binding CanEditSelectedMicrosoftAccount}"
                                        Command="{Binding RefreshSelectedAccountInfoCommand}" />
                                <Button Style="{StaticResource LauncherPrimaryDialogButtonStyle}"
                                        Margin="10,0,0,0"
                                        Content="{x:Static res:Strings.Account_ChangeSkinButton}"
                                        IsEnabled="{Binding CanChangeSelectedAccountSkin}"
                                        Command="{Binding PickAndChangeSelectedAccountSkinCommand}" />
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Margin="0,22,0,0"
                                  Header="{x:Static res:Strings.Account_CapeHeader}"
                                  Style="{StaticResource LauncherContentSectionStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <controls:AnimatedComboBox ItemsSource="{Binding SelectedAccountCapeOptions}"
                                                               SelectedItem="{Binding SelectedAccountCapeOption, Mode=TwoWay}"
                                                               IsEnabled="{Binding HasSelectedAccountCapes}"
                                                               Style="{StaticResource LauncherComboBoxStyle}"
                                                               shell:WindowChrome.IsHitTestVisibleInChrome="True">
                                        <controls:AnimatedComboBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type accountModels:AccountCapeOption}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="44" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <Border Grid.Column="0"
                                                            Width="24"
                                                            Height="32"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Center"
                                                            Background="#12FFFFFF"
                                                            BorderBrush="#18FFFFFF"
                                                            BorderThickness="1"
                                                            CornerRadius="4"
                                                            ClipToBounds="True">
                                                        <Grid>
                                                            <Border CornerRadius="3"
                                                                    RenderOptions.BitmapScalingMode="NearestNeighbor"
                                                                    SnapsToDevicePixels="True">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Setter Property="Background">
                                                                            <Setter.Value>
                                                                                <ImageBrush ImageSource="{Binding ImageUrl}"
                                                                                            Stretch="Fill"
                                                                                            ViewboxUnits="RelativeToBoundingBox"
                                                                                            Viewbox="0,0.03125,0.1875,0.5" />
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsNone}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                            </Border>

                                                            <TextBlock Text="&#xE7B8;"
                                                                       FontFamily="Segoe MDL2 Assets"
                                                                       FontSize="10"
                                                                       Foreground="#8FFFFFFF"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsNone}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Grid>
                                                    </Border>

                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   Foreground="#F4F4F4"
                                                                   FontSize="13" />
                                                        <TextBlock Text="{Binding Converter={StaticResource CapeStateTextConverter}}"
                                                                   Margin="0,2,0,0"
                                                                   Foreground="#8FFFFFFF"
                                                                   FontSize="11" />
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </controls:AnimatedComboBox.ItemTemplate>
                                    </controls:AnimatedComboBox>

                                    <Button Grid.Column="1"
                                            Margin="10,0,0,0"
                                            Style="{StaticResource LauncherDialogButtonStyle}"
                                            Content="{x:Static res:Strings.Refresh_Button}"
                                            IsEnabled="{Binding CanEditSelectedMicrosoftAccount}"
                                            Command="{Binding RefreshSelectedAccountProfileCommand}" />
                                    <Button Grid.Column="2"
                                            Margin="10,0,0,0"
                                            Style="{StaticResource LauncherPrimaryDialogButtonStyle}"
                                            Content="{x:Static res:Strings.Apply_Button}"
                                            IsEnabled="{Binding CanApplySelectedCape}"
                                            Command="{Binding ApplySelectedAccountCapeCommand}" />
                                </Grid>

                                <TextBlock Margin="0,14,0,0"
                                           Text="{Binding AccountProfileMessage}"
                                           Foreground="#AFFFFFFF"
                                           FontSize="13"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding AccountProfileErrorCodeMessage}"
                                           Foreground="#8FFFFFFF"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding HasAccountProfileErrorCode, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}" />
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
