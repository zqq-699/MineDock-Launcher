<UserControl x:Class="Launcher.App.Views.Resources.ResourcesPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Launcher.App.Controls"
             xmlns:views="clr-namespace:Launcher.App.Views.Resources"
             xmlns:resources="clr-namespace:Launcher.App.ViewModels.Resources"
             xmlns:res="clr-namespace:Launcher.App.Resources"
             x:Name="Root"
             Focusable="False">
    <UserControl.Resources>
        <DataTemplate x:Key="ResourcesMenuItemTemplate" DataType="{x:Type resources:ResourcesSectionItem}">
            <controls:SecondaryMenuOptionButton Text="{Binding Title}"
                                                IconMode="Svg"
                                                IconKey="{Binding IconKey}"
                                                IsSelected="{Binding IsSelected}"
                                                Command="{Binding DataContext.SelectSectionCommand, RelativeSource={RelativeSource AncestorType={x:Type views:ResourcesPageView}}}"
                                                CommandParameter="{Binding}" />
        </DataTemplate>

        <DataTemplate x:Key="ResourcesModFilterTemplate" DataType="{x:Type resources:ResourcesModPageViewModel}">
            <views:ResourcesModFilterView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type resources:ResourcesModPageViewModel}">
            <views:ResourcesModPageView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type resources:ResourcesResourcePacksPageViewModel}">
            <views:ResourcesResourcePacksPageView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type resources:ResourcesShaderPacksPageViewModel}">
            <views:ResourcesShaderPacksPageView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type resources:ResourcesWorldsPageViewModel}">
            <views:ResourcesWorldsPageView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type resources:ResourcesModpacksPageViewModel}">
            <views:ResourcesModpacksPageView />
        </DataTemplate>
    </UserControl.Resources>

    <Grid x:Name="PageRoot">
        <controls:SecondaryMenuFrame Title="{x:Static res:Strings.Page_Resources}">
            <controls:SecondaryMenuFrame.MenuContent>
                <ItemsControl ItemsSource="{Binding Sections}"
                              ItemTemplate="{StaticResource ResourcesMenuItemTemplate}" />
            </controls:SecondaryMenuFrame.MenuContent>
        </controls:SecondaryMenuFrame>

        <controls:ListPageFrame x:Name="ResourcesListFrame"
                                Margin="284,36,24,8"
                                Title="{Binding PageTitle}"
                                SearchText="{Binding ModPage.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                IsSearchVisible="{Binding IsModsSection}"
                                SearchFilterContent="{Binding ModPage}"
                                SearchFilterContentTemplate="{StaticResource ResourcesModFilterTemplate}"
                                IsSearchFilterVisible="{Binding IsModsSection}"
                                IsListVisible="True"
                                UseFrameScrollViewer="True">
            <controls:ListPageFrame.ListContent>
                <StackPanel Loaded="SectionContentRoot_OnLoaded"
                            Unloaded="SectionContentRoot_OnUnloaded">
                    <StackPanel.RenderTransform>
                        <TranslateTransform />
                    </StackPanel.RenderTransform>

                    <ContentControl Content="{Binding CurrentSectionViewModel}" />
                </StackPanel>
            </controls:ListPageFrame.ListContent>
        </controls:ListPageFrame>
    </Grid>
</UserControl>
