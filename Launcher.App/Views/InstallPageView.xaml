<UserControl x:Class="Launcher.App.Views.InstallPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Launcher.App.Controls"
             xmlns:res="clr-namespace:Launcher.App.Resources"
             x:Name="Root"
             Focusable="False">
    <Grid x:Name="PageRoot">
        <controls:ListPageFrame Margin="28,36,24,8"
                                Title="{x:Static res:Strings.Page_Install}"
                                IsSearchVisible="False"
                                IsListVisible="{Binding HasTasks}">
            <controls:ListPageFrame.OverlayContent>
                <TextBlock Margin="0,42,0,0"
                           Text="{x:Static res:Strings.Install_Empty}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource PageEmptyStateTextStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasTasks}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </controls:ListPageFrame.OverlayContent>

            <controls:ListPageFrame.ListContent>
                <ItemsControl ItemsSource="{Binding Tasks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,12,12"
                                    Padding="18"
                                    Background="#1CFFFFFF"
                                    BorderBrush="#18FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="#F4F4F4"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Margin="0,5,0,0"
                                                   Text="{Binding Subtitle}"
                                                   Foreground="#AFFFFFFF"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <Grid Grid.Column="1"
                                          Margin="18,-6,-6,0"
                                          MinWidth="92"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Top">
                                        <Button HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Style="{StaticResource InstallTaskCancelButtonStyle}"
                                                Command="{Binding DataContext.CancelTaskCommand, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                CommandParameter="{Binding}">
                                            <controls:SvgIcon Width="14"
                                                              Height="14"
                                                              IconKey="general/general_delete"
                                                              Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                                        </Button>

                                        <StackPanel Margin="0,30,6,0"
                                                    HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding StateText}"
                                                       Foreground="#DFFFFFFF"
                                                       FontSize="12"
                                                       TextAlignment="Right" />
                                            <TextBlock Margin="0,5,0,0"
                                                       Text="{Binding DownloadSpeedText}"
                                                       Foreground="#9FFFFFFF"
                                                       FontSize="12"
                                                       TextAlignment="Right">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasDownloadSpeedText}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Grid.Row="1"
                                               Grid.ColumnSpan="2"
                                               Margin="0,14,0,0"
                                               Text="{Binding StatusMessage}"
                                               Foreground="#CFFFFFFF"
                                               FontSize="12"
                                               TextWrapping="Wrap" />

                                    <Grid Grid.Row="2"
                                          Grid.ColumnSpan="2"
                                          Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="48" />
                                        </Grid.ColumnDefinitions>

                                        <ProgressBar Height="5"
                                                     Maximum="100"
                                                     Style="{StaticResource LauncherProgressBarStyle}"
                                                     Value="{Binding ProgressPercent}"
                                                     VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding ProgressText}"
                                                   Foreground="#AFFFFFFF"
                                                   FontSize="12"
                                                   TextAlignment="Right"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </controls:ListPageFrame.ListContent>
        </controls:ListPageFrame>
    </Grid>
</UserControl>
