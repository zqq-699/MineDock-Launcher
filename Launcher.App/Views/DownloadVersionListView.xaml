<UserControl x:Class="Launcher.App.Views.DownloadVersionListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Launcher.App.Controls"
             xmlns:views="clr-namespace:Launcher.App.Views"
             xmlns:behaviors="clr-namespace:Launcher.App.Behaviors"
             Focusable="False">
    <ListBox x:Name="DownloadVersionListBox"
             ItemsSource="{Binding VisibleVersions}"
             SelectedItem="{Binding SelectedMinecraftVersion, Mode=OneWay}"
             ItemContainerStyle="{StaticResource DownloadVersionListBoxItemStyle}"
             Style="{StaticResource DownloadVersionListBoxStyle}"
             VirtualizingPanel.IsVirtualizing="True"
             VirtualizingPanel.VirtualizationMode="Recycling"
             VirtualizingPanel.ScrollUnit="Pixel"
             ScrollViewer.CanContentScroll="True"
             behaviors:VirtualizedListItemStateBehavior.IsEnabled="True"
             behaviors:VirtualizedListItemStateBehavior.EntranceAnimationToken="{Binding ListEntranceAnimationToken}"
             behaviors:VirtualizedListItemStateBehavior.ContentTopOffset="132">
        <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
                <VirtualizingStackPanel Margin="0,132,0,64"
                                        VirtualizingPanel.IsVirtualizing="True"
                                        VirtualizingPanel.VirtualizationMode="Recycling"
                                        VirtualizingPanel.ScrollUnit="Pixel" />
            </ItemsPanelTemplate>
        </ListBox.ItemsPanel>

        <ListBox.ItemTemplate>
            <DataTemplate>
                <controls:ListPageItemButton Title="{Binding Name}"
                                             Subtitle="{Binding TypeLabel}"
                                             TrailingText="{Binding ReleaseDateText}"
                                             IconSource="{Binding IconSource}"
                                             IsSelected="{Binding IsSelected}"
                                             IsFirstVisible="{Binding Tag.IsFirstVisible, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}"
                                             IsLastVisible="{Binding Tag.IsLastVisible, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}"
                                             IsPreviousItemHighlighted="{Binding Tag.IsPreviousItemHighlighted, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}"
                                             ShouldPlayEnterAnimation="{Binding Tag.ShouldPlayEnterAnimation, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}, Mode=TwoWay}"
                                             EnterAnimationIndex="{Binding Tag.EnterAnimationIndex, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}"
                                             Command="{Binding DataContext.SelectMinecraftVersionCommand, RelativeSource={RelativeSource AncestorType={x:Type views:DownloadVersionListView}}}"
                                             CommandParameter="{Binding}"
                                             Style="{StaticResource DownloadVersionListItemButtonEntranceStyle}" />
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>
</UserControl>
