<UserControl x:Class="Launcher.App.Views.Multiplayer.JoinLobbyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:Launcher.App.Behaviors"
             xmlns:res="clr-namespace:Launcher.App.Resources"
             Focusable="False">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BlockHelm_Launcher_x64;component/Views/Settings/SettingsSectionResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Margin="0,62,12,72"
                MaxWidth="{StaticResource DetailPageContentMaxWidth}"
                HorizontalAlignment="Stretch">
        <GroupBox Header="{x:Static res:Strings.Multiplayer_SectionJoinLobby}"
                  Style="{StaticResource LauncherContentSectionStyle}">
            <StackPanel>
                <TextBlock Text="{x:Static res:Strings.Multiplayer_Join_StepEnterRoomCode}"
                           Style="{StaticResource SettingsDescriptionTextStyle}" />
                <TextBlock Margin="0,10,0,0"
                           Text="{x:Static res:Strings.Multiplayer_Join_StepJoinLobby}"
                           Style="{StaticResource SettingsDescriptionTextStyle}" />
            </StackPanel>
        </GroupBox>

        <GroupBox Margin="0,26,0,0"
                  Header="{x:Static res:Strings.Multiplayer_Join_RoomCodeSection}"
                  Style="{StaticResource LauncherContentSectionStyle}">
            <StackPanel HorizontalAlignment="Left">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox Text="{Binding JoinRoomCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="256"
                             behaviors:TextBoxPlaceholder.Text="{x:Static res:Strings.Multiplayer_Join_RoomCodePlaceholder}"
                             Style="{StaticResource LauncherDialogTextBoxStyle}" />

                    <Button Grid.Column="1"
                            Margin="12,0,0,0"
                            VerticalAlignment="Top"
                            Content="{x:Static res:Strings.Multiplayer_Join_PasteButton}"
                            Command="{Binding PasteRoomCodeCommand}"
                            Style="{StaticResource LauncherDialogButtonStyle}" />
                    <Button Grid.Column="2"
                            Margin="10,0,0,0"
                            VerticalAlignment="Top"
                            Content="{Binding JoinLobbyButtonText}"
                            Command="{Binding JoinLobbyCommand}"
                            Style="{StaticResource LauncherPrimaryDialogButtonStyle}" />
                </Grid>

                <TextBlock Margin="0,10,0,0"
                           MaxWidth="560"
                           Text="{Binding JoinLobbyStatus}"
                           TextWrapping="Wrap"
                           Visibility="{Binding HasJoinLobbyStatus, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}"
                           Style="{StaticResource SettingsDescriptionTextStyle}" />
            </StackPanel>
        </GroupBox>
    </StackPanel>
</UserControl>
