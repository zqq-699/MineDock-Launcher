<UserControl x:Class="Launcher.App.Views.Install.InstallPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Launcher.App.Controls"
             xmlns:res="clr-namespace:Launcher.App.Resources"
             x:Name="Root"
             Focusable="False">
    <Grid x:Name="PageRoot">
        <controls:ListPageFrame Margin="28,36,24,8"
                                Title="{x:Static res:Strings.Page_Install}"
                                IsSearchVisible="False"
                                IsListVisible="{Binding HasTasks}"
                                IsProgressiveBlurEnabled="{DynamicResource Is.ProgressiveBlur.Enabled}">
            <controls:ListPageFrame.OverlayContent>
                <TextBlock Margin="0,42,0,0"
                           Text="{x:Static res:Strings.Install_Empty}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource PageEmptyStateTextStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasTasks}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </controls:ListPageFrame.OverlayContent>

            <controls:ListPageFrame.ListContent>
                <ItemsControl ItemsSource="{Binding Tasks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource InstallTaskCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Title}"
                                                   Style="{StaticResource InstallTaskTitleTextStyle}" />
                                        <TextBlock Text="{Binding Subtitle}"
                                                   Style="{StaticResource InstallTaskSubtitleTextStyle}" />
                                    </StackPanel>

                                    <Grid Grid.Column="1"
                                          Margin="18,0,0,0"
                                          MinWidth="92"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Top">
                                        <Button HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Style="{StaticResource InstallTaskCancelButtonStyle}"
                                                Command="{Binding DataContext.CancelTaskCommand, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                CommandParameter="{Binding}">
                                            <controls:SvgIcon Width="14"
                                                              Height="14"
                                                              IconKey="general/general_delete"
                                                              Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                                        </Button>

                                        <StackPanel Margin="0,22,0,0"
                                                    HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding StateText}"
                                                       Style="{StaticResource InstallTaskStateTextStyle}" />
                                            <TextBlock Text="{Binding DownloadSpeedText}"
                                                       Style="{StaticResource InstallTaskSpeedTextStyle}" />
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Grid.Row="1"
                                               Grid.ColumnSpan="2"
                                               VerticalAlignment="Center"
                                               Text="{Binding StatusMessage}"
                                               Style="{StaticResource InstallTaskStatusTextStyle}" />

                                    <Grid Grid.Row="2"
                                          Grid.ColumnSpan="2"
                                          Margin="0,8,0,0"
                                          VerticalAlignment="Bottom">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="48" />
                                        </Grid.ColumnDefinitions>

                                        <ProgressBar Height="5"
                                                     Maximum="100"
                                                     Style="{StaticResource LauncherProgressBarStyle}"
                                                     Value="{Binding ProgressPercent}"
                                                     VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding ProgressText}"
                                                   Style="{StaticResource InstallTaskProgressTextStyle}" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </controls:ListPageFrame.ListContent>
        </controls:ListPageFrame>
    </Grid>
</UserControl>


