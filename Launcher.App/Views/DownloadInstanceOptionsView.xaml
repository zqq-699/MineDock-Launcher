<UserControl x:Class="Launcher.App.Views.DownloadInstanceOptionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:Launcher.App.Resources"
             Focusable="False">
    <ScrollViewer Style="{StaticResource ListPageScrollViewerStyle}">
        <StackPanel Margin="0,132,12,72"
                    MaxWidth="560"
                    HorizontalAlignment="Stretch">
            <TextBlock Margin="0,0,0,8"
                       Text="{x:Static res:Strings.Download_InstanceNameLabel}"
                       Foreground="#AFFFFFFF"
                       FontSize="13" />

            <TextBox Height="42"
                     Text="{Binding InstanceName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource LauncherDialogTextBoxStyle}" />

            <TextBlock Margin="0,8,0,0"
                       Text="{Binding InstanceNameDuplicateMessage}"
                       Foreground="#FFFFC56D"
                       FontSize="12">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasInstanceNameDuplicateMessage}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <TextBlock Margin="0,28,0,10"
                       Text="{x:Static res:Strings.Download_LoaderLabel}"
                       Foreground="#AFFFFFFF"
                       FontSize="13" />

            <ListBox ItemsSource="{Binding LoaderOptions}"
                     SelectedItem="{Binding SelectedLoaderOption, Mode=TwoWay}"
                     SelectionMode="Single">
                <ListBox.Style>
                    <Style TargetType="ListBox" BasedOn="{StaticResource DialogChoiceListStyle}">
                        <Setter Property="Margin" Value="0" />
                    </Style>
                </ListBox.Style>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid Width="36"
                                  Height="36">
                                <Image Width="30"
                                       Height="30"
                                       Source="{Binding IconSource}"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                                       SnapsToDevicePixels="True"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IconSource}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IconSource}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>

                                <TextBlock Text="{Binding Icon}"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="26"
                                           Foreground="#F4F4F4"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IconSource}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IconSource}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>

                            <StackPanel Grid.Column="1"
                                        Margin="14,0,0,0">
                                <TextBlock Text="{Binding Title}"
                                           Foreground="#F4F4F4"
                                           FontSize="16"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Subtitle}"
                                           Margin="0,5,0,0"
                                           Foreground="#AFFFFFFF"
                                           FontSize="12"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
