<UserControl x:Class="Launcher.App.Views.Download.Dialogs.DownloadLocalImportDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:animation="clr-namespace:Launcher.App.Behaviors.Animation"
             xmlns:controls="clr-namespace:Launcher.App.Controls"
             xmlns:res="clr-namespace:Launcher.App.Resources"
             Focusable="False">
    <Grid Style="{StaticResource DialogContentGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{x:Static res:Strings.Download_LocalImportDialogTitle}"
                       Style="{StaticResource DialogTitleTextStyle}" />
            <TextBlock Text="{x:Static res:Strings.Download_LocalImportDialogSubtitle}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource DialogSubtitleTextStyle}" />
                </TextBlock.Style>
                <animation:AnimatedCollapse.IsExpanded>
                    <Binding Path="LocalImportDialog.IsSelectionState" />
                </animation:AnimatedCollapse.IsExpanded>
                <animation:AnimatedCollapse.Duration>0:0:0.18</animation:AnimatedCollapse.Duration>
            </TextBlock>
            <TextBlock Text="{x:Static res:Strings.Download_LocalImportUnrecognizedMessage}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource DialogBodyTextStyle}" />
                </TextBlock.Style>
                <animation:AnimatedCollapse.IsExpanded>
                    <Binding Path="LocalImportDialog.IsUnrecognizedState" />
                </animation:AnimatedCollapse.IsExpanded>
                <animation:AnimatedCollapse.Duration>0:0:0.18</animation:AnimatedCollapse.Duration>
            </TextBlock>
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Style="{StaticResource DialogFormPanelStyle}"
                    animation:AnimatedCollapse.IsExpanded="{Binding LocalImportDialog.IsSelectionState}"
                    animation:AnimatedCollapse.Duration="0:0:0.18">
            <StackPanel>

                <Border Style="{StaticResource DialogDropZoneBorderStyle}">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <controls:SvgIcon Width="30"
                                          Height="30"
                                          IconKey="instance_download_page/localimport"
                                          Foreground="{DynamicResource Brush.Icon.Primary}"
                                          HorizontalAlignment="Center" />
                        <TextBlock Margin="0,12,0,0"
                                   Text="{x:Static res:Strings.Download_LocalImportDropZoneTitle}"
                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{x:Static res:Strings.Download_LocalImportDropZoneSubtitle}"
                                   Style="{StaticResource DialogBodyTextStyle}"
                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                   TextAlignment="Center" />
                    </StackPanel>
                </Border>

                <TextBlock Margin="0,18,0,8"
                           Text="{x:Static res:Strings.Download_LocalImportSelectedFileLabel}"
                           Style="{StaticResource DialogFieldLabelTextStyle}" />

                <Border Style="{StaticResource ReadOnlyFieldSurfaceStyle}">
                    <Grid>
                        <TextBlock Text="{Binding LocalImportDialog.SelectedFileName}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource ReadOnlyFieldTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Setter Property="TextWrapping" Value="NoWrap" />
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LocalImportDialog.HasSelectedFile}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBlock Text="{x:Static res:Strings.Download_LocalImportNoFileSelected}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource ReadOnlyFieldTextStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Muted}" />
                                    <Setter Property="TextWrapping" Value="NoWrap" />
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LocalImportDialog.HasSelectedFile}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Content="{x:Static res:Strings.Download_LocalImportSelectFileButton}"
                    HorizontalAlignment="Left"
                    Command="{Binding LocalImportDialog.SelectFileCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource LauncherDialogButtonStyle}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding LocalImportDialog.IsSelectionState}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="{x:Static res:Strings.Cancel_Button}"
                        Command="{Binding LocalImportDialog.CancelCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource LauncherDialogButtonStyle}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LocalImportDialog.IsSelectionState}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Margin="{StaticResource DialogTrailingButtonMargin}"
                        Content="{x:Static res:Strings.Confirm_Button}"
                        Command="{Binding LocalImportDialog.ConfirmImportCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource LauncherPrimaryDialogButtonStyle}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LocalImportDialog.IsSelectionState}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Margin="{StaticResource DialogTrailingButtonMargin}"
                        Content="{x:Static res:Strings.Confirm_Button}"
                        Command="{Binding LocalImportDialog.ConfirmUnrecognizedCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource LauncherPrimaryDialogButtonStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LocalImportDialog.IsUnrecognizedState}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
