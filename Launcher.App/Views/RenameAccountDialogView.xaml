<UserControl x:Class="Launcher.App.Views.RenameAccountDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:Launcher.App.Resources"
             xmlns:controls="clr-namespace:Launcher.App.Controls"
             Focusable="False">
    <Grid Style="{StaticResource DialogContentGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{Binding Dialog.RenameAccountDialogTitle}"
                       Style="{StaticResource DialogTitleTextStyle}" />
            <TextBlock Text="{Binding Dialog.RenameAccountDialogSubtitle}"
                       Style="{StaticResource DialogSubtitleTextStyle}" />
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Style="{StaticResource DialogFormPanelStyle}"
                    Visibility="{Binding Dialog.IsRenameAccountInputStep, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}">
            <TextBlock Text="{x:Static res:Strings.Account_NewUsernameLabel}"
                       Style="{StaticResource DialogFieldLabelTextStyle}" />
            <TextBox Style="{StaticResource LauncherDialogTextBoxStyle}"
                     Text="{Binding Dialog.RenameAccountName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="{x:Static res:Strings.Account_UsernameValidation}"
                       Style="{StaticResource DialogValidationTextStyle}"
                       Visibility="{Binding Dialog.IsRenameAccountNameInvalid, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}" />
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Style="{StaticResource DialogFormPanelStyle}"
                    Visibility="{Binding Dialog.IsRenameAccountMessageStep, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}">
            <Grid Width="34"
                  Height="34"
                  HorizontalAlignment="Center">
                <controls:SvgIcon Width="30"
                                  Height="30"
                                  IconKey="{Binding Dialog.RenameAccountIconKey}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center">
                    <controls:SvgIcon.Style>
                        <Style TargetType="{x:Type controls:SvgIcon}">
                            <Setter Property="Foreground" Value="#F4F4F4" />
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Dialog.RenameAccountIconKey}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Dialog.IsRenameAccountResultStep}" Value="True">
                                    <Setter Property="Foreground" Value="#FF8A8A" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Dialog.IsRenameAccountSuccessful}" Value="True">
                                    <Setter Property="Foreground" Value="#7DFFB2" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </controls:SvgIcon.Style>
                </controls:SvgIcon>

                <TextBlock Text="{Binding Dialog.RenameAccountIcon}"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="30"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Setter Property="Foreground" Value="#F4F4F4" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Dialog.RenameAccountIconKey}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
            <TextBlock Text="{Binding Dialog.RenameAccountMessage}"
                       Margin="0,16,0,0"
                       Style="{StaticResource DialogBodyTextStyle}"
                       TextAlignment="Center" />
            <TextBlock Text="{Binding Dialog.RenameAccountErrorCodeMessage}"
                       Margin="0,8,0,0"
                       Foreground="#8FFFFFFF"
                       FontSize="12"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Visibility="{Binding Dialog.HasRenameAccountErrorCode, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}" />
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Style="{StaticResource DialogFooterStyle}">
            <Button Style="{StaticResource LauncherDialogButtonStyle}"
                    Content="{x:Static res:Strings.Cancel_Button}"
                    Command="{Binding RequestCancelRenameAccountDialogCommand}"
                    Visibility="{Binding Dialog.CanShowRenameAccountCancelButton, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}" />
            <Button Style="{StaticResource LauncherPrimaryDialogButtonStyle}"
                    Margin="{StaticResource DialogTrailingButtonMargin}"
                    Content="{x:Static res:Strings.Confirm_Button}"
                    IsEnabled="{Binding Dialog.CanConfirmRenameAccountDialog}"
                    Command="{Binding RequestConfirmRenameAccountDialogCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
