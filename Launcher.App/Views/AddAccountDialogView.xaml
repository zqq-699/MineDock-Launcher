<UserControl x:Class="Launcher.App.Views.AddAccountDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:Launcher.App.Models"
             Focusable="False">
    <Grid Style="{StaticResource DialogContentGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{Binding AddAccountDialogTitle}"
                       Style="{StaticResource DialogTitleTextStyle}" />
            <TextBlock Text="{Binding AddAccountDialogSubtitle}"
                       Style="{StaticResource DialogSubtitleTextStyle}" />
        </StackPanel>

        <ListBox Grid.Row="1"
                 ItemsSource="{Binding AccountTypeOptions}"
                 SelectedItem="{Binding SelectedAccountTypeOption, Mode=TwoWay}"
                 Style="{StaticResource DialogChoiceListStyle}"
                 Visibility="{Binding IsAccountTypeStep, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:AccountTypeOption}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding Icon}"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="22"
                                   Foreground="#F4F4F4"
                                   TextAlignment="Center"
                                   VerticalAlignment="Center" />

                        <StackPanel Grid.Column="1"
                                    Margin="6,0,0,0">
                            <TextBlock Text="{Binding Title}"
                                       Foreground="#F4F4F4"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Description}"
                                       Margin="0,5,0,0"
                                       Foreground="#AFFFFFFF"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="1"
                    Style="{StaticResource DialogFormPanelStyle}"
                    Visibility="{Binding IsOfflineNameStep, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}">
            <TextBlock Text="&#x7528;&#x6237;&#x540D;"
                       Style="{StaticResource DialogFieldLabelTextStyle}" />
            <TextBox Style="{StaticResource LauncherDialogTextBoxStyle}"
                     Text="{Binding NewOfflineAccountName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="&#x7528;&#x6237;&#x540D;&#x4E0D;&#x53EF;&#x4E3A;&#x7A7A;"
                       Style="{StaticResource DialogValidationTextStyle}"
                       Visibility="{Binding IsNewOfflineAccountNameInvalid, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}" />
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Style="{StaticResource DialogFormPanelStyle}"
                    Visibility="{Binding IsMicrosoftStatusStep, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}">
            <TextBlock Text="{Binding MicrosoftLoginIcon}"
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="30"
                       HorizontalAlignment="Center"
                       TextAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#F4F4F4" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMicrosoftLoginResultStep}" Value="True">
                                <Setter Property="Foreground" Value="#FF8A8A" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsMicrosoftLoginSuccessful}" Value="True">
                                <Setter Property="Foreground" Value="#7DFFB2" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <TextBlock Text="{Binding MicrosoftLoginMessage}"
                       Margin="0,16,0,0"
                       Style="{StaticResource DialogBodyTextStyle}"
                       TextAlignment="Center" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Button Style="{StaticResource LauncherDialogButtonStyle}"
                    HorizontalAlignment="Left"
                    Content="&#x4E0A;&#x4E00;&#x6B65;"
                    Click="Back_Click"
                    Visibility="{Binding CanShowAddAccountBackButton, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}" />

            <StackPanel Style="{StaticResource DialogFooterStyle}"
                        IsEnabled="{Binding IsAddAccountFooterEnabled}">
                <Button Style="{StaticResource LauncherDialogButtonStyle}"
                        Content="&#x53D6;&#x6D88;"
                        Click="Cancel_Click"
                        Visibility="{Binding CanShowAddAccountCancelButton, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}" />
                <Button Style="{StaticResource LauncherPrimaryDialogButtonStyle}"
                        Margin="{StaticResource DialogTrailingButtonMargin}"
                        Content="&#x786E;&#x5B9A;"
                        IsEnabled="{Binding CanConfirmAddAccountDialog}"
                        Click="Confirm_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
