<UserControl x:Class="Launcher.App.Views.Settings.ThemeSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:animation="clr-namespace:Launcher.App.Behaviors.Animation"
             xmlns:controls="clr-namespace:Launcher.App.Controls"
             xmlns:res="clr-namespace:Launcher.App.Resources"
             Focusable="False">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BlockHelm_Launcher_x64;component/Views/Settings/SettingsSectionResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Margin="0,0,12,72"
                MaxWidth="{StaticResource DetailPageContentMaxWidth}"
                HorizontalAlignment="Stretch">
        <GroupBox Header="{x:Static res:Strings.Settings_ThemeSection}"
                  Style="{StaticResource LauncherContentSectionStyle}">
            <Border Style="{StaticResource SectionFieldSurfaceStyle}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{x:Static res:Strings.Settings_ThemeFollowSystemLabel}"
                                   Style="{StaticResource SettingsOptionTextStyle}" />
                        <CheckBox Grid.Column="1"
                                  Margin="16,0,0,0"
                                  IsChecked="{Binding FollowSystemTheme, Mode=TwoWay}"
                                  Style="{StaticResource LauncherSwitchToggleButtonStyle}" />
                    </Grid>

                    <Grid Margin="0,18,0,0"
                          animation:AnimatedCollapse.IsExpanded="{Binding IsThemeSelectionVisible}"
                          animation:AnimatedCollapse.Duration="0:0:0.18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="220" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{x:Static res:Strings.Settings_ThemeSelectionLabel}"
                                   Style="{StaticResource SettingsOptionTextStyle}" />

                        <controls:AnimatedComboBox Grid.Column="1"
                                                   ItemsSource="{Binding ThemeOptions}"
                                                   SelectedItem="{Binding SelectedThemeOption, Mode=TwoWay}"
                                                   ItemTemplate="{StaticResource ThemeOptionTemplate}"
                                                   SelectionItemTemplate="{StaticResource ThemeOptionTemplate}"
                                                   Style="{StaticResource LauncherComboBoxStyle}" />
                    </Grid>
                </StackPanel>
            </Border>
        </GroupBox>

        <GroupBox Margin="0,18,0,0"
                  Header="{x:Static res:Strings.Settings_AccentSection}"
                  Style="{StaticResource LauncherContentSectionStyle}">
            <Border Style="{StaticResource SectionFieldSurfaceStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="220" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{x:Static res:Strings.Settings_AccentSelectionLabel}"
                               Style="{StaticResource SettingsOptionTextStyle}" />

                    <controls:AnimatedComboBox Grid.Column="1"
                                               ItemsSource="{Binding AccentColorOptions}"
                                               SelectedItem="{Binding SelectedAccentColorOption, Mode=TwoWay}"
                                               ItemTemplate="{StaticResource AccentColorOptionTemplate}"
                                               SelectionItemTemplate="{StaticResource AccentColorOptionTemplate}"
                                               Style="{StaticResource LauncherComboBoxStyle}" />
                </Grid>
            </Border>
        </GroupBox>

        <GroupBox Margin="0,18,0,0"
                  Header="{x:Static res:Strings.Settings_BackgroundSection}"
                  Style="{StaticResource LauncherContentSectionStyle}">
            <Border Style="{StaticResource SectionFieldSurfaceStyle}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="220" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{x:Static res:Strings.Settings_BackgroundSection}"
                                   Style="{StaticResource SettingsOptionTextStyle}" />
                        <controls:AnimatedComboBox Grid.Column="1"
                                                   ItemsSource="{Binding BackgroundEffectOptions}"
                                                   SelectedItem="{Binding SelectedBackgroundEffectOption, Mode=TwoWay}"
                                                   ItemTemplate="{StaticResource BackgroundEffectOptionTemplate}"
                                                   SelectionItemTemplate="{StaticResource BackgroundEffectOptionTemplate}"
                                                   Style="{StaticResource LauncherComboBoxStyle}" />
                    </Grid>

                    <Grid Margin="0,18,0,0"
                          animation:AnimatedCollapse.IsExpanded="{Binding IsBackgroundImageSelectionVisible}"
                          animation:AnimatedCollapse.Duration="0:0:0.18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{x:Static res:Strings.Settings_BackgroundImageSelectionLabel}"
                                       Style="{StaticResource SettingsOptionTextStyle}" />
                            <TextBlock Margin="0,4,16,0"
                                       Text="{x:Static res:Strings.Settings_BackgroundImageSelectionDescription}"
                                       Style="{StaticResource SettingsDescriptionTextStyle}" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                VerticalAlignment="Center"
                                Content="{x:Static res:Strings.Settings_BackgroundImageOpenFolderButton}"
                                Command="{Binding OpenLauncherBackgroundImageFolderCommand}"
                                Style="{StaticResource LauncherDialogButtonStyle}" />

                        <Button Grid.Column="2"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                Content="{x:Static res:Strings.Settings_BackgroundImageRefreshButton}"
                                Command="{Binding RefreshLauncherBackgroundImageCommand}"
                                Style="{StaticResource LauncherDialogButtonStyle}" />

                        <Button Grid.Column="3"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                Content="{x:Static res:Strings.Settings_BackgroundImageClearButton}"
                                Command="{Binding ClearLauncherBackgroundImagesCommand}"
                                Style="{StaticResource LauncherDangerDialogButtonStyle}" />
                    </Grid>

                    <Grid Margin="0,18,0,0"
                          animation:AnimatedCollapse.IsExpanded="{Binding IsBackgroundImageSelectionVisible}"
                          animation:AnimatedCollapse.Duration="0:0:0.18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{x:Static res:Strings.Settings_BackgroundImageControlBlurLabel}"
                                   Style="{StaticResource SettingsOptionTextStyle}" />
                        <CheckBox Grid.Column="1"
                                  Margin="16,0,0,0"
                                  IsChecked="{Binding EnableImageBackgroundControlBlur, Mode=TwoWay}"
                                  Style="{StaticResource LauncherSwitchToggleButtonStyle}" />
                    </Grid>

                    <Grid Margin="0,18,0,0"
                          animation:AnimatedCollapse.IsExpanded="{Binding IsBackgroundOpacityVisible}"
                          animation:AnimatedCollapse.Duration="0:0:0.18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="162" />
                            <ColumnDefinition Width="46" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{x:Static res:Strings.Settings_BackgroundOpacityLabel}"
                                   Style="{StaticResource SettingsOptionTextStyle}" />

                        <Slider Grid.Column="1"
                                Minimum="0"
                                Maximum="100"
                                TickFrequency="1"
                                SmallChange="1"
                                LargeChange="10"
                                IsSnapToTickEnabled="True"
                                Value="{Binding LauncherBackgroundOpacityPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource LauncherSliderStyle}" />
                        <TextBlock Grid.Column="2"
                                   Margin="12,0,0,0"
                                   Text="{Binding LauncherBackgroundOpacityText}"
                                   Style="{StaticResource ReadOnlyFieldTextStyle}"
                                   VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>
        </GroupBox>
    </StackPanel>
</UserControl>
