<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:behaviors="clr-namespace:Launcher.App.Behaviors"
                    xmlns:settings="clr-namespace:Launcher.App.ViewModels.Settings">
    <Style x:Key="SettingsOptionTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Brush.F2F2F2}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="SettingsFieldLabelStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource LauncherTextSecondaryBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="SettingsDescriptionTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource LauncherTextSecondaryBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <DataTemplate x:Key="JavaSelectionOptionTemplate">
        <TextBlock Text="{Binding Title}"
                   Foreground="{DynamicResource Brush.F4F4F4}"
                   FontSize="13"
                   VerticalAlignment="Center" />
    </DataTemplate>

    <DataTemplate x:Key="DownloadSourceOptionTemplate"
                  DataType="{x:Type settings:SettingsDownloadSourceOption}">
        <TextBlock Text="{Binding Title}"
                   Foreground="{DynamicResource Brush.F4F4F4}"
                   FontSize="13"
                   VerticalAlignment="Center" />
    </DataTemplate>

    <DataTemplate x:Key="ThemeOptionTemplate"
                  DataType="{x:Type settings:SettingsThemeOption}">
        <TextBlock Text="{Binding Title}"
                   Foreground="{DynamicResource Brush.F4F4F4}"
                   FontSize="13"
                   VerticalAlignment="Center" />
    </DataTemplate>

    <DataTemplate x:Key="LanguageOptionTemplate">
        <TextBlock Text="{Binding}"
                   Foreground="{DynamicResource Brush.F4F4F4}"
                   FontSize="13"
                   VerticalAlignment="Center" />
    </DataTemplate>

    <Style x:Key="AccentColorPreviewEllipseStyle" TargetType="Ellipse">
        <Setter Property="Width" Value="10" />
        <Setter Property="Height" Value="10" />
        <Setter Property="Margin" Value="0,0,10,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Fill" Value="{DynamicResource Brush.AccentOption.Blue}" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding Id}" Value="Cyan">
                <Setter Property="Fill" Value="{DynamicResource Brush.AccentOption.Cyan}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Id}" Value="Green">
                <Setter Property="Fill" Value="{DynamicResource Brush.AccentOption.Green}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Id}" Value="Emerald">
                <Setter Property="Fill" Value="{DynamicResource Brush.AccentOption.Emerald}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Id}" Value="Purple">
                <Setter Property="Fill" Value="{DynamicResource Brush.AccentOption.Purple}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Id}" Value="Pink">
                <Setter Property="Fill" Value="{DynamicResource Brush.AccentOption.Pink}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Id}" Value="Orange">
                <Setter Property="Fill" Value="{DynamicResource Brush.AccentOption.Orange}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Id}" Value="Amber">
                <Setter Property="Fill" Value="{DynamicResource Brush.AccentOption.Amber}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <DataTemplate x:Key="AccentColorOptionTemplate"
                  DataType="{x:Type settings:SettingsAccentColorOption}">
        <StackPanel Orientation="Horizontal">
            <Ellipse Style="{StaticResource AccentColorPreviewEllipseStyle}" />
            <TextBlock Text="{Binding Title}"
                       Foreground="{DynamicResource Brush.F4F4F4}"
                       FontSize="13"
                       VerticalAlignment="Center" />
        </StackPanel>
    </DataTemplate>

    <Style x:Key="JavaRuntimeListBoxStyle" TargetType="ListBox">
        <Setter Property="Margin" Value="0,10,0,0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel" />
        <Setter Property="behaviors:SmoothScrollBehavior.IsEnabled" Value="True" />
        <Setter Property="behaviors:SmoothScrollBehavior.AllowContentScroll" Value="True" />
        <Setter Property="behaviors:SmoothScrollBehavior.ScrollAmount" Value="92" />
        <Setter Property="behaviors:SmoothScrollBehavior.WheelAnimationDurationMilliseconds" Value="130" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="JavaRuntimeListBoxItemStyle"
           TargetType="ListBoxItem"
           BasedOn="{StaticResource DialogChoiceItemStyle}">
        <Setter Property="Margin" Value="0,0,0,4" />
        <Setter Property="IsHitTestVisible"
                Value="{Binding DataContext.IsJavaManualSelection, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" />
    </Style>

    <DataTemplate x:Key="JavaRuntimeItemTemplate">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding DisplayName}"
                           Foreground="{DynamicResource Brush.F4F4F4}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding VersionText}"
                           Margin="10,0,0,0"
                           Foreground="{DynamicResource LauncherTextSecondaryBrush}"
                           FontSize="12"
                           VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <TextBlock Text="{Binding Architecture}"
                           Foreground="{DynamicResource Brush.CFFFFFFF}"
                           FontSize="12"
                           VerticalAlignment="Center" />
            </StackPanel>

            <TextBlock Grid.Row="1"
                       Grid.ColumnSpan="2"
                       Margin="0,4,0,0"
                       Text="{Binding ExecutablePath}"
                       Foreground="{DynamicResource Brush.AFFFFFFF}"
                       FontSize="12"
                       TextTrimming="CharacterEllipsis" />
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="InteractiveControlItemTemplate"
                  DataType="{x:Type settings:SettingsInteractiveControlItem}">
        <StackPanel>
            <TextBlock Text="{Binding Title}"
                       Foreground="{DynamicResource Brush.F4F4F4}"
                       FontSize="13"
                       TextTrimming="CharacterEllipsis" />
            <TextBlock Margin="0,3,0,0"
                       Text="{Binding Category}"
                       Foreground="{DynamicResource LauncherTextSecondaryBrush}"
                       FontSize="11"
                       TextTrimming="CharacterEllipsis" />
        </StackPanel>
    </DataTemplate>
</ResourceDictionary>
