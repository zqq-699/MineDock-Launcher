<UserControl x:Class="Launcher.App.Views.Settings.GeneralSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Launcher.App.Controls"
             xmlns:res="clr-namespace:Launcher.App.Resources"
             DataContext="{Binding Parent}"
             Focusable="False">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/MineDock_Launcher_x64;component/Views/Settings/SettingsSectionResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Margin="0,0,12,72"
                MaxWidth="{StaticResource DetailPageContentMaxWidth}"
                HorizontalAlignment="Stretch">
        <GroupBox Header="{x:Static res:Strings.Settings_GeneralFilesAndDirectoriesSection}"
                  Style="{StaticResource LauncherContentSectionStyle}">
            <StackPanel>
                <Border Style="{StaticResource SectionFieldSurfaceStyle}">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,8"
                                   Text="{x:Static res:Strings.Settings_MinecraftDirectoryLabel}"
                                   Style="{StaticResource SettingsFieldLabelStyle}" />
                        <TextBlock Margin="0,0,0,12"
                                   Text="{x:Static res:Strings.Settings_MinecraftDirectoryDescription}"
                                   Style="{StaticResource SettingsDescriptionTextStyle}" />
                        <Border Style="{StaticResource ReadOnlyFieldSurfaceStyle}">
                            <TextBlock Text="{Binding MinecraftDirectory}"
                                       Style="{StaticResource ReadOnlyFieldTextStyle}" />
                        </Border>

                        <WrapPanel Margin="0,16,0,0">
                            <Button Margin="0,0,10,10"
                                    Content="{x:Static res:Strings.Settings_OpenMinecraftDirectoryButton}"
                                    Command="{Binding OpenMinecraftDirectoryCommand}"
                                    Style="{StaticResource LauncherDialogButtonStyle}" />
                            <Button Margin="0,0,10,10"
                                    Content="{x:Static res:Strings.Settings_ChangeMinecraftDirectoryButton}"
                                    Command="{Binding ChangeMinecraftDirectoryCommand}"
                                    Style="{StaticResource LauncherPrimaryDialogButtonStyle}" />
                        </WrapPanel>

                        <TextBlock Margin="0,24,0,8"
                                   Text="{x:Static res:Strings.Settings_LauncherLogDirectoryLabel}"
                                   Style="{StaticResource SettingsFieldLabelStyle}" />
                        <TextBlock Margin="0,0,0,12"
                                   Text="{x:Static res:Strings.Settings_LauncherLogDirectoryDescription}"
                                   Style="{StaticResource SettingsDescriptionTextStyle}" />
                        <Border Style="{StaticResource ReadOnlyFieldSurfaceStyle}">
                            <TextBlock Text="{Binding LauncherLogDirectory}"
                                       Style="{StaticResource ReadOnlyFieldTextStyle}" />
                        </Border>

                        <WrapPanel Margin="0,16,0,0">
                            <Button Margin="0,0,10,10"
                                    Content="{x:Static res:Strings.Settings_OpenLauncherLogDirectoryButton}"
                                    Command="{Binding OpenLauncherLogDirectoryCommand}"
                                    Style="{StaticResource LauncherDialogButtonStyle}" />
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </GroupBox>

        <GroupBox Margin="0,26,0,0"
                  Header="{x:Static res:Strings.Settings_DownloadSection}"
                  Style="{StaticResource LauncherContentSectionStyle}">
            <Border Style="{StaticResource SectionFieldSurfaceStyle}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="220" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{x:Static res:Strings.Settings_DownloadSourceLabel}"
                                   Style="{StaticResource SettingsOptionTextStyle}" />

                        <controls:AnimatedComboBox Grid.Column="1"
                                                   ItemsSource="{Binding DownloadSourceOptions}"
                                                   SelectedItem="{Binding SelectedDownloadSourceOption, Mode=TwoWay}"
                                                   ItemTemplate="{StaticResource DownloadSourceOptionTemplate}"
                                                   SelectionItemTemplate="{StaticResource DownloadSourceOptionTemplate}"
                                                   Style="{StaticResource LauncherComboBoxStyle}" />
                    </Grid>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="220" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{x:Static res:Strings.Settings_DownloadSpeedLimitLabel}"
                                   Style="{StaticResource SettingsOptionTextStyle}" />

                        <Grid Grid.Column="1"
                              Width="220"
                              HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     Margin="0,0,8,0"
                                     Text="{Binding DownloadSpeedLimitMbPerSecondText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource LauncherDialogTextBoxStyle}" />

                            <TextBlock Grid.Column="1"
                                       Text="{x:Static res:Strings.Settings_DownloadSpeedLimitUnit}"
                                       Style="{StaticResource SettingsDescriptionTextStyle}"
                                       Margin="0"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Grid>
                </StackPanel>
            </Border>
        </GroupBox>
    </StackPanel>
</UserControl>
