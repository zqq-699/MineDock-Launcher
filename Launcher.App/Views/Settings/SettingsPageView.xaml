<UserControl x:Class="Launcher.App.Views.Settings.SettingsPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Launcher.App.Controls"
             xmlns:res="clr-namespace:Launcher.App.Resources"
             xmlns:settings="clr-namespace:Launcher.App.ViewModels.Settings"
             xmlns:views="clr-namespace:Launcher.App.Views.Settings"
             x:Name="Root"
             Focusable="False">
    <UserControl.Resources>
        <DataTemplate x:Key="SettingsMenuItemTemplate" DataType="{x:Type settings:SettingsSectionItem}">
            <controls:SecondaryMenuOptionButton Text="{Binding Title}"
                                                IconMode="Svg"
                                                IconKey="{Binding IconKey}"
                                                IsSelected="{Binding IsSelected}"
                                                Command="{Binding DataContext.SelectSectionCommand, RelativeSource={RelativeSource AncestorType={x:Type views:SettingsPageView}}}"
                                                CommandParameter="{Binding}" />
        </DataTemplate>

        <DataTemplate DataType="{x:Type settings:GeneralSettingsViewModel}">
            <views:GeneralSettingsView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type settings:LanguageSettingsViewModel}">
            <views:LanguageSettingsView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type settings:LaunchMemorySettingsViewModel}">
            <views:LaunchMemorySettingsView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type settings:JavaSettingsViewModel}">
            <views:JavaSettingsView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type settings:ThemeSettingsViewModel}">
            <views:ThemeSettingsView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type settings:ListPreviewSettingsViewModel}">
            <views:ListPreviewSettingsView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type settings:InfoSettingsViewModel}">
            <views:InfoSettingsView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type settings:ControlListSettingsViewModel}">
            <views:ControlListSettingsView />
        </DataTemplate>
    </UserControl.Resources>

    <Grid x:Name="PageRoot">
        <controls:SecondaryMenuFrame Title="{x:Static res:Strings.Page_Settings}">
            <controls:SecondaryMenuFrame.MenuContent>
                <ItemsControl ItemsSource="{Binding Sections}"
                              ItemTemplate="{StaticResource SettingsMenuItemTemplate}" />
            </controls:SecondaryMenuFrame.MenuContent>
        </controls:SecondaryMenuFrame>

        <controls:ListPageFrame x:Name="SettingsListFrame"
                                Margin="284,36,24,8"
                                Title="{Binding SectionTitle}"
                                IsSearchVisible="False"
                                IsListVisible="True"
                                IsProgressiveBlurEnabled="{DynamicResource Is.ProgressiveBlur.Enabled}">
            <controls:ListPageFrame.Style>
                <Style TargetType="{x:Type controls:ListPageFrame}">
                    <Setter Property="UseFrameScrollViewer" Value="True" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsListPreviewSection}" Value="True">
                            <Setter Property="UseFrameScrollViewer" Value="False" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </controls:ListPageFrame.Style>
            <controls:ListPageFrame.ListContent>
                <Grid Loaded="SectionContentRoot_OnLoaded"
                      Unloaded="SectionContentRoot_OnUnloaded">
                    <Grid.RenderTransform>
                        <TranslateTransform />
                    </Grid.RenderTransform>

                    <ContentControl HorizontalContentAlignment="Stretch"
                                    VerticalContentAlignment="Stretch"
                                    Content="{Binding CurrentSectionViewModel}" />
                </Grid>
            </controls:ListPageFrame.ListContent>
        </controls:ListPageFrame>
    </Grid>
</UserControl>
