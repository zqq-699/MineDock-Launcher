<UserControl x:Class="Launcher.App.Views.HomePageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Focusable="False">
    <Grid x:Name="PageRoot"
          Margin="0,48,0,0">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="0,-18,0,0">
            <Border Style="{StaticResource HomeAvatarContainerStyle}"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="HomeAvatarScale"
                                    ScaleX="1"
                                    ScaleY="1" />
                </Border.RenderTransform>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Mouse.MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="HomeAvatarScale"
                                                 Storyboard.TargetProperty="ScaleX"
                                                 To="1.125"
                                                 Duration="0:0:0.22">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="HomeAvatarScale"
                                                 Storyboard.TargetProperty="ScaleY"
                                                 To="1.125"
                                                 Duration="0:0:0.22">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="HomeAvatarShadow"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0.66"
                                                 Duration="0:0:0.22">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="HomeAvatarShadowBlur"
                                                 Storyboard.TargetProperty="Radius"
                                                 To="28"
                                                 Duration="0:0:0.22">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="HomeAvatarShadowOffset"
                                                 Storyboard.TargetProperty="Y"
                                                 To="11"
                                                 Duration="0:0:0.22">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="Mouse.MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="HomeAvatarScale"
                                                 Storyboard.TargetProperty="ScaleX"
                                                 To="1"
                                                 Duration="0:0:0.28">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="HomeAvatarScale"
                                                 Storyboard.TargetProperty="ScaleY"
                                                 To="1"
                                                 Duration="0:0:0.28">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="HomeAvatarShadow"
                                                 Storyboard.TargetProperty="Opacity"
                                                 To="0.46"
                                                 Duration="0:0:0.28">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="HomeAvatarShadowBlur"
                                                 Storyboard.TargetProperty="Radius"
                                                 To="20"
                                                 Duration="0:0:0.28">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="HomeAvatarShadowOffset"
                                                 Storyboard.TargetProperty="Y"
                                                 To="8"
                                                 Duration="0:0:0.28">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                <Grid>
                    <Border x:Name="HomeAvatarShadow"
                            Width="64"
                            Height="64"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="#000000"
                            IsHitTestVisible="False"
                            Opacity="0.46">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="HomeAvatarShadowOffset"
                                                Y="8" />
                        </Border.RenderTransform>
                        <Border.Effect>
                            <BlurEffect x:Name="HomeAvatarShadowBlur"
                                        Radius="20" />
                        </Border.Effect>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSelectedAccount}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <TextBlock Text="&#xE77B;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="42"
                               Foreground="#E8FFFFFF"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource HomeDefaultAvatarGlyphStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSelectedAccount}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Image Width="64"
                           Height="64"
                           Source="{Binding HomeAvatarUrl}"
                           Stretch="Fill"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="NearestNeighbor">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSelectedAccount}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                </Grid>
            </Border>

            <TextBlock Text="{Binding HomeAccountDisplayName}"
                       Style="{StaticResource HomeAccountNameTextStyle}" />

            <TextBlock Text="选择或创建账户以进行游戏。">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource HomeAccountHintTextStyle}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasSelectedAccount}" Value="False">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Button Content="启动游戏"
                    Command="{Binding LaunchCommand}"
                    Style="{StaticResource HomeLaunchButtonStyle}" />

            <TextBlock Text="{Binding HomeVersionDisplayName}"
                       Style="{StaticResource HomeVersionNameTextStyle}" />

            <Button Content="更多版本 &gt;"
                    Command="{Binding ChangeHomeVersionCommand}"
                    Style="{StaticResource HomeChangeVersionButtonStyle}" />
        </StackPanel>
    </Grid>
</UserControl>
