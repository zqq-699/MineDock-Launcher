<UserControl x:Class="Launcher.App.Views.GameSettingsPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:Launcher.App.Behaviors"
             xmlns:controls="clr-namespace:Launcher.App.Controls"
             xmlns:views="clr-namespace:Launcher.App.Views"
             xmlns:res="clr-namespace:Launcher.App.Resources"
             x:Name="Root"
             Focusable="False">
    <Grid x:Name="PageRoot">
        <controls:SecondaryMenuFrame Title="{x:Static res:Strings.Nav_GameInstanceList}">
            <controls:SecondaryMenuFrame.MenuContent>
                <ItemsControl ItemsSource="{Binding InstanceCategories}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:SecondaryMenuOptionButton Text="{Binding Title}"
                                                                IconMode="{Binding IconMode}"
                                                                IconKey="{Binding IconKey}"
                                                                Glyph="{Binding Icon}"
                                                                IsSelected="{Binding IsSelected}"
                                                                Command="{Binding DataContext.SelectInstanceCategoryCommand, RelativeSource={RelativeSource AncestorType={x:Type views:GameSettingsPageView}}}"
                                                                CommandParameter="{Binding}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </controls:SecondaryMenuFrame.MenuContent>
        </controls:SecondaryMenuFrame>

        <controls:ListPageFrame Margin="284,36,24,8"
                                Title="{Binding PageTitle}"
                                SearchText="{Binding InstanceSearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                IsSearchVisible="True"
                                IsListVisible="True"
                                UseFrameScrollViewer="False">
            <controls:ListPageFrame.OverlayContent>
                <Grid>
                    <TextBlock Margin="0,122,0,0"
                               Text="{Binding InstanceLoadError}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource PageEmptyStateTextStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Setter Property="Foreground" Value="{StaticResource LauncherDangerBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasInstanceLoadError}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Margin="0,122,0,0"
                               Text="{Binding InstanceEmptyMessage}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource PageEmptyStateTextStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasInstanceEmptyMessage}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </controls:ListPageFrame.OverlayContent>

            <controls:ListPageFrame.ListContent>
                <ListBox ItemsSource="{Binding VisibleInstances}"
                         SelectedItem="{Binding SelectedInstance, Mode=OneWay}"
                         ItemContainerStyle="{StaticResource ListPageVirtualizedListBoxItemStyle}"
                         Style="{StaticResource ListPageVirtualizedListBoxStyle}"
                         behaviors:VirtualizedListItemStateBehavior.IsEnabled="True"
                         behaviors:VirtualizedListItemStateBehavior.EntranceAnimationToken="{Binding ListEntranceAnimationToken}"
                         behaviors:VirtualizedListItemStateBehavior.ContentTopOffset="132"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         VirtualizingPanel.ScrollUnit="Pixel"
                         ScrollViewer.CanContentScroll="True">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel Margin="0,132,0,64"
                                                    VirtualizingPanel.IsVirtualizing="True"
                                                    VirtualizingPanel.VirtualizationMode="Recycling"
                                                    VirtualizingPanel.ScrollUnit="Pixel" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <controls:ListPageItemButton Title="{Binding Name}"
                                                         Subtitle="{Binding Subtitle}"
                                                         TrailingText="{Binding UpdatedDateText}"
                                                         IconSource="{Binding IconSource}"
                                                         IsSelected="{Binding IsSelected}"
                                                         IsFirstVisible="{Binding Tag.IsFirstVisible, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}"
                                                         IsLastVisible="{Binding Tag.IsLastVisible, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}"
                                                         IsPreviousItemHighlighted="{Binding Tag.IsPreviousItemHighlighted, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}"
                                                         ShouldPlayEnterAnimation="{Binding Tag.ShouldPlayEnterAnimation, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}, Mode=TwoWay}"
                                                         EnterAnimationIndex="{Binding Tag.EnterAnimationIndex, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}"
                                                         Command="{Binding DataContext.SelectInstanceCommand, RelativeSource={RelativeSource AncestorType={x:Type views:GameSettingsPageView}}}"
                                                         CommandParameter="{Binding}">
                                <controls:ListPageItemButton.Style>
                                    <Style TargetType="{x:Type controls:ListPageItemButton}">
                                        <Setter Property="Opacity" Value="0" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Tag.ShouldPlayEnterAnimation, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}" Value="True">
                                                <Setter Property="Opacity" Value="1" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Tag.ShouldPlayEnterAnimation, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}" Value="False">
                                                <Setter Property="Opacity" Value="1" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </controls:ListPageItemButton.Style>
                            </controls:ListPageItemButton>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </controls:ListPageFrame.ListContent>
        </controls:ListPageFrame>
    </Grid>
</UserControl>
