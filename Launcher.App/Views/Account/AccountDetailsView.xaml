<UserControl x:Class="Launcher.App.Views.Account.AccountDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:Launcher.App.Behaviors"
             xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
             xmlns:accountModels="clr-namespace:Launcher.Application.Accounts;assembly=Launcher.Application"
             xmlns:models="clr-namespace:Launcher.App.Models"
             xmlns:controls="clr-namespace:Launcher.App.Controls"
             xmlns:accountControls="clr-namespace:Launcher.App.Controls.Account"
             xmlns:res="clr-namespace:Launcher.App.Resources"
             Focusable="False">
    <ScrollViewer x:Name="AccountDetailsScrollViewer"
                  Style="{StaticResource ListPageScrollViewerStyle}"
                  behaviors:VerticalEdgeOpacityMask.IsEnabled="True"
                  behaviors:VerticalEdgeOpacityMask.TopFadeLength="132"
                  behaviors:VerticalEdgeOpacityMask.BottomFadeLength="72"
                  behaviors:VerticalEdgeOpacityMask.MinimumOpacity="0">
        <StackPanel x:Name="DetailsContentRoot"
                    Margin="0,132,12,72"
                    MaxWidth="{StaticResource DetailPageContentMaxWidth}"
                    HorizontalAlignment="Stretch">
            <StackPanel.RenderTransform>
                <TranslateTransform />
            </StackPanel.RenderTransform>
            <Image Width="64"
                   Height="64"
                   HorizontalAlignment="Left"
                   Source="{Binding AccountList.SelectedAccount.AvatarUrl}"
                   Stretch="Fill"
                   SnapsToDevicePixels="True"
                   RenderOptions.BitmapScalingMode="NearestNeighbor" />
            <Grid Margin="0,18,0,0"
                  HorizontalAlignment="Left">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding AccountList.SelectedAccount.DisplayName}"
                           Style="{StaticResource PageTitleTextStyle}"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Margin="10,0,0,0"
                        Style="{StaticResource InlineIconButtonStyle}"
                        Command="{Binding RequestRenameAccountCommand}">
                    <controls:SvgIcon Width="16"
                                      Height="16"
                                      IconKey="general/general_edit"
                                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                </Button>
            </Grid>
            <TextBlock Margin="0,8,0,0"
                       Text="{Binding AccountList.SelectedAccount.IsOffline, Converter={StaticResource AccountKindTextConverter}}"
                       Foreground="#AFFFFFFF"
                       FontSize="13" />

            <StackPanel Margin="0,26,0,0">
                <GroupBox Header="{x:Static res:Strings.Account_UuidHeader}"
                          Style="{StaticResource LauncherContentSectionStyle}">
                    <StackPanel>
                        <Border Style="{StaticResource ReadOnlyFieldSurfaceStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding OfflineUuid.SelectedAccountUuidText}"
                                           Foreground="#CFFFFFFF"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Margin="10,-4,-6,-4"
                                        Style="{StaticResource InlineIconButtonStyle}"
                                        Command="{Binding OfflineUuid.CopySelectedUuidCommand}">
                                    <controls:SvgIcon Width="16"
                                                      Height="16"
                                                      IconKey="general/general_copy"
                                                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                                </Button>
                            </Grid>
                        </Border>

                        <Grid Margin="0,12,0,0"
                              Visibility="{Binding OfflineUuid.HasSelectedOfflineAccount, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{x:Static res:Strings.Account_OfflineUuidModeLabel}"
                                       Foreground="#CFFFFFFF"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                            <controls:AnimatedComboBox Grid.Column="1"
                                                       ItemsSource="{Binding OfflineUuid.OfflineUuidOptions}"
                                                       SelectedItem="{Binding OfflineUuid.SelectedOfflineUuidOption, Mode=TwoWay}"
                                                       Style="{StaticResource LauncherComboBoxStyle}"
                                                       shell:WindowChrome.IsHitTestVisibleInChrome="True">
                                <controls:AnimatedComboBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:OfflineUuidModeOption}">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="#F4F4F4"
                                                   FontSize="13"
                                                   VerticalAlignment="Center" />
                                    </DataTemplate>
                                </controls:AnimatedComboBox.ItemTemplate>
                            </controls:AnimatedComboBox>
                        </Grid>

                        <Grid Margin="0,12,0,0"
                              Visibility="{Binding OfflineUuid.HasManualUuidEditor, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     Height="36"
                                     FontSize="12"
                                     Text="{Binding OfflineUuid.ManualUuidText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource LauncherDialogTextBoxStyle}" />
                            <Button Grid.Column="1"
                                    Margin="10,0,0,0"
                                    Style="{StaticResource LauncherPrimaryDialogButtonStyle}"
                                    Content="{x:Static res:Strings.Apply_Button}"
                                    IsEnabled="{Binding OfflineUuid.CanApplyManualUuid}"
                                    Command="{Binding OfflineUuid.ApplyManualUuidCommand}" />

                            <TextBlock Grid.Row="1"
                                       Grid.ColumnSpan="2"
                                       Margin="2,8,0,0"
                                       Text="{x:Static res:Strings.Account_OfflineUuidInvalid}"
                                       Foreground="#FFFF8A8A"
                                       FontSize="12"
                                       Visibility="{Binding OfflineUuid.IsManualUuidInvalid, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}" />
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <GroupBox Margin="0,22,0,0"
                          Style="{StaticResource LauncherContentSectionStyle}">
                    <GroupBox.Header>
                        <Grid Width="{Binding ActualWidth, ElementName=DetailsContentRoot}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{x:Static res:Strings.Account_SkinHeader}"
                                       Foreground="#A8FFFFFF"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <Button Style="{StaticResource LauncherDialogButtonStyle}"
                                        Content="{x:Static res:Strings.Refresh_Button}"
                                        IsEnabled="{Binding Appearance.CanEditSelectedMicrosoftAccount}"
                                        Command="{Binding Appearance.RefreshSelectedAccountInfoCommand}" />
                                <Button Style="{StaticResource LauncherPrimaryDialogButtonStyle}"
                                        Margin="10,0,0,0"
                                        Content="{x:Static res:Strings.Account_ChangeSkinButton}"
                                        IsEnabled="{Binding Appearance.CanChangeSelectedAccountSkin}"
                                        Command="{Binding Appearance.PickAndChangeSelectedAccountSkinCommand}" />
                            </StackPanel>
                        </Grid>
                    </GroupBox.Header>
                    <Grid>
                        <Grid Width="160"
                              Height="236"
                              HorizontalAlignment="Center">
                            <Grid>
                                <accountControls:SkinPreview3DControl SkinSource="{Binding AccountList.SelectedAccount.SkinSource}"
                                                                      SkinModel="{Binding AccountList.SelectedAccount.SkinModel}"
                                                                      RenderOptions.BitmapScalingMode="NearestNeighbor"
                                                                      Visibility="{Binding Appearance.HasSelectedAccountSkinPreview, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}" />
                                <TextBlock Margin="14"
                                           Text="{x:Static res:Strings.Account_SkinPreviewEmpty}"
                                           Foreground="#8FFFFFFF"
                                           FontSize="12"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding Appearance.CanShowSelectedAccountSkinPreviewEmptyState, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}" />
                            </Grid>
                        </Grid>
                    </Grid>
                </GroupBox>

                <GroupBox Margin="0,22,0,0"
                          Header="{x:Static res:Strings.Account_CapeHeader}"
                          Style="{StaticResource LauncherContentSectionStyle}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <controls:AnimatedComboBox ItemsSource="{Binding Appearance.SelectedAccountCapeOptions}"
                                                       SelectedItem="{Binding Appearance.SelectedAccountCapeOption, Mode=TwoWay}"
                                                       IsEnabled="{Binding Appearance.HasSelectedAccountCapes}"
                                                       Style="{StaticResource LauncherComboBoxStyle}"
                                                       shell:WindowChrome.IsHitTestVisibleInChrome="True">
                                <controls:AnimatedComboBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type accountModels:AccountCapeOption}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="44" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Width="24"
                                                    Height="32"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center"
                                                    Background="#12FFFFFF"
                                                    BorderBrush="#18FFFFFF"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    ClipToBounds="True">
                                                <Grid>
                                                    <Border CornerRadius="3"
                                                            RenderOptions.BitmapScalingMode="NearestNeighbor"
                                                            SnapsToDevicePixels="True">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Setter Property="Background">
                                                                    <Setter.Value>
                                                                        <ImageBrush ImageSource="{Binding ImageUrl}"
                                                                                    Stretch="Fill"
                                                                                    ViewboxUnits="RelativeToBoundingBox"
                                                                                    Viewbox="0,0.03125,0.1875,0.5" />
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsNone}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                    </Border>

                                                    <TextBlock Text="&#xE7B8;"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="10"
                                                               Foreground="#8FFFFFFF"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsNone}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Converter={StaticResource CapeDisplayNameConverter}}"
                                                           Foreground="#F4F4F4"
                                                           FontSize="13" />
                                                <TextBlock Text="{Binding Converter={StaticResource CapeStateTextConverter}}"
                                                           Margin="0,2,0,0"
                                                           Foreground="#8FFFFFFF"
                                                           FontSize="11" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </controls:AnimatedComboBox.ItemTemplate>
                            </controls:AnimatedComboBox>

                            <Button Grid.Column="1"
                                    Margin="10,0,0,0"
                                    Style="{StaticResource LauncherDialogButtonStyle}"
                                    Content="{x:Static res:Strings.Refresh_Button}"
                                    IsEnabled="{Binding Appearance.CanEditSelectedMicrosoftAccount}"
                                    Command="{Binding Appearance.RefreshSelectedAccountProfileCommand}" />
                            <Button Grid.Column="2"
                                    Margin="10,0,0,0"
                                    Style="{StaticResource LauncherPrimaryDialogButtonStyle}"
                                    Content="{x:Static res:Strings.Apply_Button}"
                                    IsEnabled="{Binding Appearance.CanApplySelectedCape}"
                                    Command="{Binding Appearance.ApplySelectedAccountCapeCommand}" />
                        </Grid>

                        <TextBlock Margin="0,14,0,0"
                                   Text="{Binding Appearance.AccountProfileMessage}"
                                   Foreground="#AFFFFFFF"
                                   FontSize="13"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding Appearance.AccountProfileErrorCodeMessage}"
                                   Foreground="#8FFFFFFF"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding Appearance.HasAccountProfileErrorCode, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}" />
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>

