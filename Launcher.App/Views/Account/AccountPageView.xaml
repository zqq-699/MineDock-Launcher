<UserControl x:Class="Launcher.App.Views.Account.AccountPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Launcher.App.Controls"
             xmlns:views="clr-namespace:Launcher.App.Views.Account"
             xmlns:res="clr-namespace:Launcher.App.Resources"
             x:Name="Root"
             Focusable="False">
    <Grid x:Name="PageRoot">
        <controls:SecondaryMenuFrame Title="{x:Static res:Strings.Account_ListTitle}"
                                     controls:SecondaryMenuOptionButton.RefreshRequested="SecondaryMenuOptionButton_OnRefreshRequested">
            <controls:SecondaryMenuFrame.MenuContent>
                <views:AccountMenuView />
            </controls:SecondaryMenuFrame.MenuContent>
        </controls:SecondaryMenuFrame>

        <Grid Margin="284,72,24,24">
            <TextBlock Text="{x:Static res:Strings.Account_EmptySelection}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource PageEmptyStateTextStyle}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding AccountList.SelectedAccount}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <views:AccountDetailsView x:Name="AccountDetailsView">
                <views:AccountDetailsView.Style>
                    <Style TargetType="{x:Type views:AccountDetailsView}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding AccountList.SelectedAccount}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </views:AccountDetailsView.Style>
            </views:AccountDetailsView>
        </Grid>
    </Grid>
</UserControl>

