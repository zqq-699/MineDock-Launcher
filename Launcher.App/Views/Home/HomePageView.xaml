<UserControl x:Class="Launcher.App.Views.Home.HomePageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Launcher.App.Views.Home"
             Focusable="False">
    <Grid x:Name="PageRoot">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="272" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <views:HomeLaunchGameListView Grid.Column="0"
                                      DataContext="{Binding LaunchGames}" />

        <views:HomeLaunchPanelView Grid.Column="1" />
    </Grid>
</UserControl>

