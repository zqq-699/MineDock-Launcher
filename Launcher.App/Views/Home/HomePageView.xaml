<UserControl x:Class="Launcher.App.Views.Home.HomePageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Launcher.App.Views.Home"
             Focusable="False">
    <Grid x:Name="PageRoot">
        <Grid x:Name="HomeLaunchContentHost">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="HomeLaunchContentTranslate" />
            </Grid.RenderTransform>

            <views:HomeLaunchPanelView />
        </Grid>

        <views:HomeLaunchGameListView DataContext="{Binding LaunchGames}"
                                      Panel.ZIndex="4" />
    </Grid>
</UserControl>


