<UserControl x:Class="Launcher.App.Views.GameSettings.GameSettingsDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:Launcher.App.Behaviors"
             xmlns:controls="clr-namespace:Launcher.App.Controls"
             xmlns:res="clr-namespace:Launcher.App.Resources"
             Focusable="False">
    <UserControl.Resources>
        <Style x:Key="SettingsOptionTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.F2F2F2}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <DataTemplate x:Key="InstanceJavaSelectionOptionTemplate">
            <TextBlock Text="{Binding Title}"
                       Foreground="{DynamicResource Brush.F4F4F4}"
                       FontSize="13"
                       VerticalAlignment="Center" />
        </DataTemplate>

        <Style x:Key="InstanceJavaRuntimeListBoxStyle" TargetType="ListBox">
            <Setter Property="Margin" Value="0,10,0,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
            <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel" />
            <Setter Property="behaviors:SmoothScrollBehavior.IsEnabled" Value="True" />
            <Setter Property="behaviors:SmoothScrollBehavior.AllowContentScroll" Value="True" />
            <Setter Property="behaviors:SmoothScrollBehavior.ScrollAmount" Value="92" />
            <Setter Property="behaviors:SmoothScrollBehavior.WheelAnimationDurationMilliseconds" Value="130" />
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InstanceJavaRuntimeListBoxItemStyle"
               TargetType="ListBoxItem"
               BasedOn="{StaticResource DialogChoiceItemStyle}">
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="IsHitTestVisible"
                    Value="{Binding DataContext.CanInteractWithInstanceJavaRuntimeList, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" />
        </Style>

        <DataTemplate x:Key="InstanceJavaRuntimeItemTemplate">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding DisplayName}"
                               Foreground="{DynamicResource Brush.F4F4F4}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding VersionText}"
                               Margin="10,0,0,0"
                               Foreground="{DynamicResource LauncherTextSecondaryBrush}"
                               FontSize="12"
                               VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding Architecture}"
                           Foreground="{DynamicResource Brush.CFFFFFFF}"
                           FontSize="12"
                           VerticalAlignment="Center" />

                <TextBlock Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Margin="0,4,0,0"
                           Text="{Binding ExecutablePath}"
                           Foreground="{DynamicResource Brush.AFFFFFFF}"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </DataTemplate>

    </UserControl.Resources>

    <ScrollViewer x:Name="DetailsScrollViewer"
                  Style="{StaticResource ListPageScrollViewerStyle}">
        <StackPanel x:Name="SectionContentRoot"
                    Margin="0,132,12,72"
                    MaxWidth="{StaticResource DetailPageContentMaxWidth}"
                    HorizontalAlignment="Stretch">
            <StackPanel.RenderTransform>
                <TranslateTransform />
            </StackPanel.RenderTransform>

            <StackPanel Visibility="{Binding IsGeneralSection, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}">
                <Image Width="64"
                       Height="64"
                       HorizontalAlignment="Left"
                       Source="{Binding InstanceIconSource}"
                       Stretch="Fill"
                       SnapsToDevicePixels="True"
                       RenderOptions.BitmapScalingMode="NearestNeighbor" />

                <Grid Margin="0,18,0,0"
                      HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding InstanceName}"
                               VerticalAlignment="Center"
                               Style="{StaticResource PageTitleTextStyle}" />

                    <Button Grid.Column="1"
                            Margin="10,0,0,0"
                            Style="{StaticResource InlineIconButtonStyle}"
                            Command="{Binding RequestEditInstanceCommand}">
                        <controls:SvgIcon Width="16"
                                          Height="16"
                                          IconKey="general/general_edit"
                                          Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                    </Button>
                </Grid>

                <TextBlock Margin="0,8,0,0"
                           Text="{Binding InstanceSubtitle}"
                           Foreground="{DynamicResource Brush.8FFFFFFF}"
                           FontSize="12" />
            </StackPanel>

            <StackPanel Margin="0,26,0,0"
                        Visibility="{Binding IsGeneralSection, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}">
                <GroupBox Header="{x:Static res:Strings.GameSettings_GeneralDescriptionSection}"
                          Style="{StaticResource LauncherContentSectionStyle}">
                    <StackPanel>
                        <TextBox x:Name="DescriptionTextBox"
                                 Loaded="DescriptionTextBox_OnLoaded"
                                 TextChanged="DescriptionTextBox_OnTextChanged"
                                 SizeChanged="DescriptionTextBox_OnSizeChanged"
                                 MinLines="1"
                                 Style="{StaticResource LauncherDialogWrappingTextBoxStyle}"
                                 Text="{Binding DescriptionText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Margin="0,26,0,0"
                          Header="{x:Static res:Strings.GameSettings_GeneralInstanceDirectorySection}"
                          Style="{StaticResource LauncherContentSectionStyle}">
                    <Button HorizontalAlignment="Left"
                            Content="{x:Static res:Strings.GameSettings_GeneralOpenInstanceDirectoryButton}"
                            Command="{Binding OpenInstanceDirectoryCommand}"
                            Style="{StaticResource LauncherPrimaryDialogButtonStyle}" />
                </GroupBox>

                <GroupBox Margin="0,26,0,0"
                          Header="{x:Static res:Strings.GameSettings_GeneralCreatedAtSection}"
                          Style="{StaticResource LauncherContentSectionStyle}">
                    <Border Style="{StaticResource ReadOnlyFieldSurfaceStyle}">
                        <TextBlock Text="{Binding InstanceCreatedAtText}"
                                   Style="{StaticResource ReadOnlyFieldTextStyle}" />
                    </Border>
                </GroupBox>

                <Button Margin="0,26,0,0"
                        HorizontalAlignment="Left"
                        Content="{x:Static res:Strings.GameSettings_DeleteGameButton}"
                        Command="{Binding RequestDeleteInstanceCommand}"
                        Style="{StaticResource LauncherDangerDialogButtonStyle}" />

            </StackPanel>

            <StackPanel Margin="0"
                        Visibility="{Binding IsLaunchSection, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}">
                <controls:LaunchSettingsEditor ShowModeSelector="True"
                                              LaunchSettingsModeOptions="{Binding LaunchSettingsModeOptions}"
                                              SelectedLaunchSettingsModeOption="{Binding SelectedLaunchSettingsModeOption, Mode=TwoWay}"
                                              AreLaunchSettingsOverridesEnabled="{Binding AreLaunchSettingsOverridesEnabled}"
                                              ShowMemorySettings="True"
                                              MemorySettingsModeOptions="{Binding MemoryModeOptions}"
                                              SelectedMemorySettingsModeOption="{Binding SelectedMemoryModeOption, Mode=TwoWay}"
                                              MemoryMb="{Binding MemoryMb, Mode=TwoWay}"
                                              MemoryMinimumMb="{Binding MemorySliderMinimumMb}"
                                              MemoryMaximumMb="{Binding MemorySliderMaximumMb}"
                                              IsMemorySliderEnabled="{Binding IsMemorySliderEnabled}"
                                              IsMemorySliderVisible="{Binding IsMemorySliderVisible}"
                                              IsAutomaticMemorySummaryVisible="{Binding IsAutomaticMemorySummaryVisible}"
                                              AutomaticMemoryText="{Binding AutomaticMemoryText}"
                                              MemoryValueText="{Binding MemoryText}"
                                              SystemMemorySummaryText="{Binding SystemMemorySummaryText}"
                                              CanEditAutoRepairMissingFiles="{Binding CanEditAutoRepairMissingFiles}"
                                              LaunchCheckFilesBeforeLaunchEnabled="{Binding LaunchCheckFilesBeforeLaunchEnabled, Mode=TwoWay}"
                                              LaunchAutoRepairMissingFilesEnabled="{Binding LaunchAutoRepairMissingFilesEnabled, Mode=TwoWay}"
                                              LaunchMinimizeLauncherAfterLaunchEnabled="{Binding LaunchMinimizeLauncherAfterLaunchEnabled, Mode=TwoWay}"
                                              LaunchFullScreenEnabled="{Binding LaunchFullScreenEnabled, Mode=TwoWay}"
                                              LaunchPreLaunchCommand="{Binding LaunchPreLaunchCommand, Mode=TwoWay}"
                                              LaunchWaitForPreLaunchCommand="{Binding LaunchWaitForPreLaunchCommand, Mode=TwoWay}"
                                              LaunchPostExitCommand="{Binding LaunchPostExitCommand, Mode=TwoWay}"
                                              LaunchJvmArguments="{Binding LaunchJvmArguments, Mode=TwoWay}"
                                              LaunchGameArguments="{Binding LaunchGameArguments, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel Margin="0"
                        Visibility="{Binding IsJavaMemorySection, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}">
                <Border Margin="0,0,0,26"
                        Style="{StaticResource SectionFieldSurfaceStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="180" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{x:Static res:Strings.GameSettings_LaunchSettingsModeLabel}"
                                   Style="{StaticResource SettingsOptionTextStyle}" />

                        <controls:AnimatedComboBox Grid.Column="1"
                                                   ItemsSource="{Binding LaunchSettingsModeOptions}"
                                                   SelectedItem="{Binding SelectedInstanceJavaSettingsModeOption, Mode=TwoWay}"
                                                   ItemTemplate="{StaticResource InstanceJavaSelectionOptionTemplate}"
                                                   SelectionItemTemplate="{StaticResource InstanceJavaSelectionOptionTemplate}"
                                                   Style="{StaticResource LauncherComboBoxStyle}" />
                    </Grid>
                </Border>

                <GroupBox Header="{x:Static res:Strings.Settings_JavaSection}"
                          Style="{StaticResource LauncherContentSectionStyle}">
                    <Border Style="{StaticResource SectionFieldSurfaceStyle}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="180" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{x:Static res:Strings.Settings_JavaSelectionLabel}"
                                           Style="{StaticResource SettingsOptionTextStyle}" />

                                <controls:AnimatedComboBox Grid.Column="1"
                                                           ItemsSource="{Binding InstanceJavaSelectionOptions}"
                                                           SelectedItem="{Binding SelectedInstanceJavaSelectionOption, Mode=TwoWay}"
                                                           ItemTemplate="{StaticResource InstanceJavaSelectionOptionTemplate}"
                                                           SelectionItemTemplate="{StaticResource InstanceJavaSelectionOptionTemplate}"
                                                           IsEnabled="{Binding AreInstanceJavaSettingsOverridesEnabled}"
                                                           Style="{StaticResource LauncherComboBoxStyle}" />
                            </Grid>

                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{x:Static res:Strings.Settings_JavaListLabel}"
                                               Style="{StaticResource SettingsOptionTextStyle}" />
                                    <TextBlock Margin="10,0,0,0"
                                               Text="{Binding InstanceJavaRuntimeListMessage}"
                                               Foreground="{DynamicResource LauncherTextSecondaryBrush}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding HasInstanceJavaRuntimeListMessage, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}" />
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Margin="0,0,10,0"
                                        Content="{x:Static res:Strings.Refresh_Button}"
                                        Command="{Binding RefreshInstanceJavaRuntimesCommand}"
                                        Style="{StaticResource LauncherDialogButtonStyle}" />
                                <Button Grid.Column="2"
                                        Content="{x:Static res:Strings.ManualImport_Button}"
                                        Command="{Binding ImportInstanceJavaRuntimeCommand}"
                                        Style="{StaticResource LauncherPrimaryDialogButtonStyle}" />
                            </Grid>

                            <Grid>
                                <ListBox ItemsSource="{Binding InstanceJavaRuntimes}"
                                         SelectedItem="{Binding SelectedInstanceJavaRuntime, Mode=TwoWay}"
                                         ItemTemplate="{StaticResource InstanceJavaRuntimeItemTemplate}"
                                         ItemContainerStyle="{StaticResource InstanceJavaRuntimeListBoxItemStyle}"
                                         Style="{StaticResource InstanceJavaRuntimeListBoxStyle}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </GroupBox>
            </StackPanel>

            <GroupBox Margin="0"
                      Header="{Binding SectionTitle}">
                <GroupBox.Style>
                    <Style TargetType="GroupBox" BasedOn="{StaticResource LauncherContentSectionStyle}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsGeneralSection}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsLaunchSection}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsJavaMemorySection}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </GroupBox.Style>
                <Border Style="{StaticResource SectionFieldSurfaceStyle}">
                    <TextBlock Text="{Binding SectionPlaceholderBody}"
                               Foreground="{DynamicResource Brush.CFFFFFFF}"
                               FontSize="13"
                               TextWrapping="Wrap" />
                </Border>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>

