<UserControl x:Class="Launcher.App.Views.GameSettings.GameSettingsDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Launcher.App.Controls"
             xmlns:res="clr-namespace:Launcher.App.Resources"
             Focusable="False">
    <UserControl.Resources>
        <Style x:Key="GeneralDescriptionTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource LauncherDialogTextBoxStyle}">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="10,0,10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid Margin="{TemplateBinding Padding}">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#667ABEFF" />
                                <Setter TargetName="Root" Property="Background" Value="#2AFFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <ScrollViewer x:Name="DetailsScrollViewer"
                  Style="{StaticResource ListPageScrollViewerStyle}">
        <StackPanel x:Name="SectionContentRoot"
                    Margin="0,132,12,72"
                    MaxWidth="{StaticResource DetailPageContentMaxWidth}"
                    HorizontalAlignment="Stretch">
            <StackPanel.RenderTransform>
                <TranslateTransform />
            </StackPanel.RenderTransform>

            <StackPanel Visibility="{Binding IsGeneralSection, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}">
                <Image Width="64"
                       Height="64"
                       HorizontalAlignment="Left"
                       Source="{Binding InstanceIconSource}"
                       Stretch="Fill"
                       SnapsToDevicePixels="True"
                       RenderOptions.BitmapScalingMode="NearestNeighbor" />

                <Grid Margin="0,18,0,0"
                      HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding InstanceName}"
                               VerticalAlignment="Center"
                               Style="{StaticResource PageTitleTextStyle}" />

                    <Button Grid.Column="1"
                            Margin="10,0,0,0"
                            Style="{StaticResource InlineIconButtonStyle}"
                            Command="{Binding RequestEditInstanceCommand}">
                        <controls:SvgIcon Width="16"
                                          Height="16"
                                          IconKey="general/general_edit"
                                          Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                    </Button>
                </Grid>

                <TextBlock Margin="0,8,0,0"
                           Text="{Binding InstanceSubtitle}"
                           Foreground="#8FFFFFFF"
                           FontSize="12" />
            </StackPanel>

            <StackPanel Margin="0,26,0,0"
                        Visibility="{Binding IsGeneralSection, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}">
                <GroupBox Header="{x:Static res:Strings.GameSettings_GeneralDescriptionSection}"
                          Style="{StaticResource LauncherContentSectionStyle}">
                    <StackPanel>
                        <TextBox x:Name="DescriptionTextBox"
                                 Loaded="DescriptionTextBox_OnLoaded"
                                 TextChanged="DescriptionTextBox_OnTextChanged"
                                 SizeChanged="DescriptionTextBox_OnSizeChanged"
                                 Height="Auto"
                                 MinHeight="40"
                                 MinLines="1"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Disabled"
                                 Style="{StaticResource GeneralDescriptionTextBoxStyle}"
                                 Text="{Binding DescriptionText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Margin="0,26,0,0"
                          Header="{x:Static res:Strings.GameSettings_GeneralInstanceDirectorySection}"
                          Style="{StaticResource LauncherContentSectionStyle}">
                    <Button HorizontalAlignment="Left"
                            Content="{x:Static res:Strings.GameSettings_GeneralOpenInstanceDirectoryButton}"
                            Command="{Binding OpenInstanceDirectoryCommand}"
                            Style="{StaticResource LauncherPrimaryDialogButtonStyle}" />
                </GroupBox>

                <GroupBox Margin="0,26,0,0"
                          Header="{x:Static res:Strings.GameSettings_GeneralCreatedAtSection}"
                          Style="{StaticResource LauncherContentSectionStyle}">
                    <Border Style="{StaticResource SectionFieldSurfaceStyle}">
                        <TextBlock Text="{Binding InstanceCreatedAtText}"
                                   Foreground="#CFFFFFFF"
                                   FontSize="13" />
                    </Border>
                </GroupBox>

            </StackPanel>

            <StackPanel Margin="0"
                        Visibility="{Binding IsLaunchSection, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}">
                <controls:LaunchSettingsEditor ShowModeSelector="True"
                                              LaunchSettingsModeOptions="{Binding LaunchSettingsModeOptions}"
                                              SelectedLaunchSettingsModeOption="{Binding SelectedLaunchSettingsModeOption, Mode=TwoWay}"
                                              AreLaunchSettingsOverridesEnabled="{Binding AreLaunchSettingsOverridesEnabled}"
                                              CanEditAutoRepairMissingFiles="{Binding CanEditAutoRepairMissingFiles}"
                                              LaunchCheckFilesBeforeLaunchEnabled="{Binding LaunchCheckFilesBeforeLaunchEnabled, Mode=TwoWay}"
                                              LaunchAutoRepairMissingFilesEnabled="{Binding LaunchAutoRepairMissingFilesEnabled, Mode=TwoWay}"
                                              LaunchMinimizeLauncherAfterLaunchEnabled="{Binding LaunchMinimizeLauncherAfterLaunchEnabled, Mode=TwoWay}" />
            </StackPanel>

            <GroupBox Margin="0"
                      Header="{Binding SectionTitle}">
                <GroupBox.Style>
                    <Style TargetType="GroupBox" BasedOn="{StaticResource LauncherContentSectionStyle}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsGeneralSection}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsLaunchSection}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </GroupBox.Style>
                <Border Style="{StaticResource SectionFieldSurfaceStyle}">
                    <TextBlock Text="{Binding SectionPlaceholderBody}"
                               Foreground="#CFFFFFFF"
                               FontSize="13"
                               TextWrapping="Wrap" />
                </Border>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
