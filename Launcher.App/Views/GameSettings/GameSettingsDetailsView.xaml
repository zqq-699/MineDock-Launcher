<UserControl x:Class="Launcher.App.Views.GameSettings.GameSettingsDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Launcher.App.Views.GameSettings"
             xmlns:gameSettings="clr-namespace:Launcher.App.ViewModels.GameSettings"
             Focusable="False">
    <UserControl.Resources>
        <DataTemplate DataType="{x:Type gameSettings:InstanceGeneralSettingsViewModel}">
            <views:InstanceGeneralSettingsView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type gameSettings:InstanceLaunchSettingsViewModel}">
            <views:InstanceLaunchSettingsView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type gameSettings:InstanceJavaSettingsViewModel}">
            <views:InstanceJavaSettingsView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type gameSettings:InstanceModManagementSettingsViewModel}">
            <views:InstanceModManagementSettingsView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type gameSettings:InstanceSaveManagementSettingsViewModel}">
            <views:InstanceSaveManagementSettingsView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type gameSettings:InstanceResourcePackManagementSettingsViewModel}">
            <views:InstanceResourcePackManagementSettingsView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type gameSettings:InstanceShaderPackManagementSettingsViewModel}">
            <views:InstanceShaderPackManagementSettingsView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type gameSettings:InstancePlaceholderSettingsViewModel}">
            <views:InstancePlaceholderSettingsView />
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer x:Name="DetailsScrollViewer"
                  Style="{StaticResource ListPageScrollViewerStyle}">
        <StackPanel x:Name="SectionContentRoot"
                    Margin="0,132,12,72"
                    MaxWidth="{StaticResource DetailPageContentMaxWidth}"
                    HorizontalAlignment="Stretch">
            <StackPanel.RenderTransform>
                <TranslateTransform />
            </StackPanel.RenderTransform>

            <ContentControl Content="{Binding CurrentSectionViewModel}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
