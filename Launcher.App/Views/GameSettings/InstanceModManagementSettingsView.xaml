<UserControl x:Class="Launcher.App.Views.GameSettings.InstanceModManagementSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Launcher.App.Controls"
             xmlns:res="clr-namespace:Launcher.App.Resources"
             xmlns:views="clr-namespace:Launcher.App.Views.GameSettings"
             x:Name="Root"
             Focusable="False">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Launcher.App;component/Views/GameSettings/GameSettingsSectionResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="ModListSectionHeaderTextStyle"
                   TargetType="TextBlock"
                   BasedOn="{StaticResource SettingsOptionTextStyle}">
                <Setter Property="Foreground" Value="{DynamicResource Brush.A8FFFFFF}" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="ModListHeaderCompactButtonStyle"
                   TargetType="Button"
                   BasedOn="{StaticResource LauncherDialogButtonStyle}">
                <Setter Property="MinWidth" Value="72" />
                <Setter Property="Height" Value="30" />
                <Setter Property="Padding" Value="14,0" />
                <Setter Property="FontSize" Value="13" />
            </Style>

            <Style x:Key="ModListHeaderCompactDangerButtonStyle"
                   TargetType="Button"
                   BasedOn="{StaticResource LauncherDangerDialogButtonStyle}">
                <Setter Property="MinWidth" Value="72" />
                <Setter Property="Height" Value="30" />
                <Setter Property="Padding" Value="14,0" />
                <Setter Property="FontSize" Value="13" />
            </Style>

            <DataTemplate x:Key="ModListSectionHeaderTemplate">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Margin="0,0,12,0"
                                   Text="{x:Static res:Strings.GameSettings_ModManagementModListSection}"
                                   Style="{StaticResource ModListSectionHeaderTextStyle}"
                                   VerticalAlignment="Center" />

                        <WrapPanel Grid.Column="1"
                                   VerticalAlignment="Center">
                            <WrapPanel Margin="0,0,10,0"
                                       VerticalAlignment="Center">
                                <WrapPanel.Style>
                                    <Style TargetType="WrapPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMultiSelectMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </WrapPanel.Style>

                                <Button Margin="0,0,10,0"
                                        Content="{Binding SelectAllButtonText}"
                                        Command="{Binding SelectAllModsCommand}"
                                        Style="{StaticResource ModListHeaderCompactButtonStyle}" />
                                <Button Margin="0,0,10,0"
                                        Content="{x:Static res:Strings.GameSettings_ModManagementDisableButton}"
                                        Command="{Binding DisableSelectedModsCommand}"
                                        Style="{StaticResource ModListHeaderCompactButtonStyle}" />
                                <Button Margin="0,0,10,0"
                                        Content="{x:Static res:Strings.GameSettings_ModManagementEnableButton}"
                                        Command="{Binding EnableSelectedModsCommand}"
                                        Style="{StaticResource ModListHeaderCompactButtonStyle}" />
                                <Button Content="{x:Static res:Strings.GameSettings_ModManagementDeleteButton}"
                                        Command="{Binding RequestDeleteSelectedModsCommand}"
                                        Style="{StaticResource ModListHeaderCompactDangerButtonStyle}" />
                            </WrapPanel>

                            <Button Command="{Binding ToggleMultiSelectModeCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ModListHeaderCompactButtonStyle}">
                                        <Setter Property="Content" Value="{x:Static res:Strings.GameSettings_ModManagementMultiSelectButton}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMultiSelectMode}" Value="True">
                                                <Setter Property="Content" Value="{x:Static res:Strings.GameSettings_ModManagementCancelMultiSelectButton}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </WrapPanel>
                    </Grid>

                    <TextBox Margin="0,10,0,0"
                             Text="{Binding ModSearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ListPageSearchBoxStyle}" />
                </StackPanel>
            </DataTemplate>

        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <StackPanel>
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CanShowModUnavailableState}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
        <GroupBox Header="{x:Static res:Strings.GameSettings_ModManagementInfoSection}">
            <GroupBox.Style>
                <Style TargetType="GroupBox" BasedOn="{StaticResource LauncherContentSectionStyle}">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CanShowModInfoSection}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </GroupBox.Style>
            <Border Style="{StaticResource SectionFieldSurfaceStyle}">
                <StackPanel>
                    <Border Style="{StaticResource ReadOnlyFieldSurfaceStyle}">
                        <TextBlock Text="{Binding InstalledSummaryText}"
                                   Style="{StaticResource ReadOnlyFieldTextStyle}" />
                    </Border>

                    <TextBlock Margin="0,18,0,10"
                               Text="{x:Static res:Strings.GameSettings_ModManagementActionsLabel}"
                               Style="{StaticResource SettingsOptionTextStyle}" />

                    <WrapPanel>
                        <Button Margin="0,0,10,10"
                                Content="{x:Static res:Strings.GameSettings_ModManagementOpenFolderButton}"
                                Command="{Binding OpenModFolderCommand}"
                                Style="{StaticResource LauncherDialogButtonStyle}" />
                        <Button Margin="0,0,10,10"
                                Content="{x:Static res:Strings.GameSettings_ModManagementLocalImportButton}"
                                Command="{Binding ImportLocalModCommand}"
                                Style="{StaticResource LauncherDialogButtonStyle}" />
                        <Button Margin="0,0,10,10"
                                Content="{x:Static res:Strings.GameSettings_ModManagementOnlineInstallButton}"
                                Command="{Binding InstallOnlineModCommand}"
                                Style="{StaticResource LauncherDialogButtonStyle}" />
                    </WrapPanel>
                </StackPanel>
            </Border>
        </GroupBox>

        <GroupBox x:Name="ModListSection"
                  Margin="0,26,0,0">
            <GroupBox.Style>
                <Style TargetType="GroupBox" BasedOn="{StaticResource LauncherContentSectionStyle}">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CanShowModListSection}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </GroupBox.Style>
            <GroupBox.Header>
                <ContentControl x:Name="OriginalModListHeaderHost"
                                Content="{Binding}"
                                ContentTemplate="{StaticResource ModListSectionHeaderTemplate}" />
            </GroupBox.Header>

            <Grid MinHeight="140">
                <ListBox ItemsSource="{Binding Mods}"
                         SelectedItem="{Binding SelectedMod, Mode=OneWay}"
                         ItemContainerStyle="{StaticResource ListPageVirtualizedListBoxItemStyle}"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         VirtualizingPanel.ScrollUnit="Pixel"
                         ScrollViewer.CanContentScroll="True">
                    <ListBox.Style>
                        <Style TargetType="ListBox" BasedOn="{StaticResource ListPageVirtualizedListBoxStyle}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasMods}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Style>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel VirtualizingPanel.IsVirtualizing="True"
                                                    VirtualizingPanel.VirtualizationMode="Recycling"
                                                    VirtualizingPanel.ScrollUnit="Pixel" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <controls:ListPageItemButton x:Name="ModListItemButton"
                                                         Title="{Binding Title}"
                                                         Subtitle="{Binding Subtitle}"
                                                         TrailingText="{Binding TrailingText}"
                                                         IconSource="{Binding IconSource}"
                                                         IconKey="{Binding IconKey}"
                                                         ItemMargin="0"
                                                         IsSelected="{Binding IsSelected}"
                                                         Command="{Binding DataContext.SelectModCommand, RelativeSource={RelativeSource AncestorType={x:Type views:InstanceModManagementSettingsView}}}"
                                                         CommandParameter="{Binding}">
                                <controls:ListPageItemButton.TrailingContent>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Command="{Binding DataContext.ToggleModEnabledCommand, RelativeSource={RelativeSource AncestorType={x:Type views:InstanceModManagementSettingsView}}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource InlineIconButtonStyle}">
                                                    <Setter Property="ToolTip" Value="{x:Static res:Strings.GameSettings_ModManagementDisableButton}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                            <Setter Property="ToolTip" Value="{x:Static res:Strings.GameSettings_ModManagementEnableButton}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <controls:SvgIcon Width="16"
                                                              Height="16"
                                                              Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}">
                                                <controls:SvgIcon.Style>
                                                    <Style TargetType="{x:Type controls:SvgIcon}">
                                                        <Setter Property="IconKey" Value="account_page/account_page_forbid" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                <Setter Property="IconKey" Value="general/general_passed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </controls:SvgIcon.Style>
                                            </controls:SvgIcon>
                                        </Button>

                                        <Button Margin="4,0,0,0"
                                                Style="{StaticResource InlineIconButtonStyle}"
                                                ToolTip="{x:Static res:Strings.GameSettings_OpenInstanceFolderTooltip}"
                                                Command="{Binding DataContext.OpenModFileLocationCommand, RelativeSource={RelativeSource AncestorType={x:Type views:InstanceModManagementSettingsView}}}"
                                                CommandParameter="{Binding}">
                                            <controls:SvgIcon Width="16"
                                                              Height="16"
                                                              IconKey="general/general_folder"
                                                              Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                                        </Button>

                                        <Button Margin="4,0,0,0"
                                                Style="{StaticResource SecondaryMenuDeleteButtonStyle}"
                                                ToolTip="{x:Static res:Strings.Delete_Button}"
                                                Command="{Binding DataContext.RequestDeleteModCommand, RelativeSource={RelativeSource AncestorType={x:Type views:InstanceModManagementSettingsView}}}"
                                                CommandParameter="{Binding}">
                                            <controls:SvgIcon Width="16"
                                                              Height="16"
                                                              IconKey="general/general_delete"
                                                              Style="{StaticResource DangerActionSvgIconStyle}" />
                                        </Button>
                                    </StackPanel>
                                </controls:ListPageItemButton.TrailingContent>
                            </controls:ListPageItemButton>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                    <Setter TargetName="ModListItemButton" Property="controls:ListPageItemButton.TitleForeground" Value="{DynamicResource Brush.Text.Subtle}" />
                                    <Setter TargetName="ModListItemButton" Property="controls:ListPageItemButton.IconOpacity" Value="0.42" />
                                    <Setter TargetName="ModListItemButton" Property="controls:ListPageItemButton.IconOverlayKey" Value="account_page/account_page_forbid" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Margin="0,42,0,0"
                           Text="{Binding ModEmptyMessage}"
                           Style="{StaticResource PageEmptyStateTextStyle}"
                           Visibility="{Binding CanShowModEmptyState, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}" />
            </Grid>
        </GroupBox>

        <TextBlock Margin="0,72,0,0"
                   Text="{Binding ModEmptyMessage}"
                   Style="{StaticResource PageEmptyStateTextStyle}"
                   Visibility="{Binding CanShowNoModsEmptyState, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}" />
        </StackPanel>

        <Grid Height="{Binding ViewportHeight, RelativeSource={RelativeSource AncestorType={x:Type ScrollViewer}}}"
              Margin="0,-132,0,-72"
              Visibility="{Binding CanShowModUnavailableState, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}">
            <TextBlock Text="{Binding ModUnavailableMessage}"
                       Style="{StaticResource PageEmptyStateTextStyle}" />
        </Grid>
    </Grid>
</UserControl>
