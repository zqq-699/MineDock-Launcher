<UserControl x:Class="Launcher.App.Views.GameSettings.InstanceModManagementSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:Launcher.App.Behaviors"
             xmlns:controls="clr-namespace:Launcher.App.Controls"
             xmlns:gameSettings="clr-namespace:Launcher.App.ViewModels.GameSettings"
             xmlns:res="clr-namespace:Launcher.App.Resources"
             xmlns:views="clr-namespace:Launcher.App.Views.GameSettings"
             x:Name="Root"
             Focusable="False">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Launcher.App;component/Views/GameSettings/GameSettingsSectionResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="ModManagementFilterButtonStyle"
                   TargetType="Button"
                   BasedOn="{StaticResource LauncherDialogButtonStyle}">
                <Setter Property="Margin" Value="0,0,8,6" />
                <Setter Property="MinWidth" Value="74" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource Brush.FFFFFF}" />
                        <Setter Property="Background" Value="{DynamicResource Brush.0891FE}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.0891FE}" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <DataTemplate DataType="{x:Type gameSettings:ModManagementInfoPanelItem}">
                <GroupBox Header="{x:Static res:Strings.GameSettings_ModManagementInfoSection}"
                          Margin="0,0,0,12"
                          Style="{StaticResource LauncherContentSectionStyle}">
                    <Border Style="{StaticResource SectionFieldSurfaceStyle}">
                        <StackPanel>
                            <Border Style="{StaticResource ReadOnlyFieldSurfaceStyle}">
                                <TextBlock Text="{Binding DataContext.InstalledSummaryText, RelativeSource={RelativeSource AncestorType={x:Type views:InstanceModManagementSettingsView}}}"
                                           Style="{StaticResource ReadOnlyFieldTextStyle}" />
                            </Border>

                            <TextBlock Margin="0,12,0,8"
                                       Text="{x:Static res:Strings.GameSettings_ModManagementActionsLabel}"
                                       Style="{StaticResource SettingsOptionTextStyle}" />

                            <WrapPanel>
                                <Button Margin="0,0,8,4"
                                        Content="{x:Static res:Strings.GameSettings_ModManagementOpenFolderButton}"
                                        Command="{Binding DataContext.OpenModFolderCommand, RelativeSource={RelativeSource AncestorType={x:Type views:InstanceModManagementSettingsView}}}"
                                        Style="{StaticResource LauncherDialogButtonStyle}" />
                                <Button Margin="0,0,8,4"
                                        Content="{x:Static res:Strings.GameSettings_ModManagementLocalImportButton}"
                                        Command="{Binding DataContext.ImportLocalModCommand, RelativeSource={RelativeSource AncestorType={x:Type views:InstanceModManagementSettingsView}}}"
                                        Style="{StaticResource LauncherDialogButtonStyle}" />
                                <Button Margin="0,0,8,4"
                                        Content="{x:Static res:Strings.GameSettings_ModManagementOnlineInstallButton}"
                                        Command="{Binding DataContext.InstallOnlineModCommand, RelativeSource={RelativeSource AncestorType={x:Type views:InstanceModManagementSettingsView}}}"
                                        Style="{StaticResource LauncherDialogButtonStyle}" />
                            </WrapPanel>

                            <TextBlock Margin="0,4,0,8"
                                       Text="{x:Static res:Strings.GameSettings_ModManagementFilterLabel}"
                                       Style="{StaticResource SettingsOptionTextStyle}" />

                            <WrapPanel>
                                <Button Content="{x:Static res:Strings.GameSettings_ModManagementFilterAllButton}"
                                        Command="{Binding DataContext.SetModFilterCommand, RelativeSource={RelativeSource AncestorType={x:Type views:InstanceModManagementSettingsView}}}"
                                        CommandParameter="{x:Static gameSettings:ModManagementFilter.All}"
                                        Tag="{Binding DataContext.IsAllModsFilterSelected, RelativeSource={RelativeSource AncestorType={x:Type views:InstanceModManagementSettingsView}}}"
                                        Style="{StaticResource ModManagementFilterButtonStyle}" />
                                <Button Content="{x:Static res:Strings.GameSettings_ModManagementFilterEnabledButton}"
                                        Command="{Binding DataContext.SetModFilterCommand, RelativeSource={RelativeSource AncestorType={x:Type views:InstanceModManagementSettingsView}}}"
                                        CommandParameter="{x:Static gameSettings:ModManagementFilter.Enabled}"
                                        Tag="{Binding DataContext.IsEnabledModsFilterSelected, RelativeSource={RelativeSource AncestorType={x:Type views:InstanceModManagementSettingsView}}}"
                                        Style="{StaticResource ModManagementFilterButtonStyle}" />
                                <Button Content="{x:Static res:Strings.GameSettings_ModManagementFilterDisabledButton}"
                                        Command="{Binding DataContext.SetModFilterCommand, RelativeSource={RelativeSource AncestorType={x:Type views:InstanceModManagementSettingsView}}}"
                                        CommandParameter="{x:Static gameSettings:ModManagementFilter.Disabled}"
                                        Tag="{Binding DataContext.IsDisabledModsFilterSelected, RelativeSource={RelativeSource AncestorType={x:Type views:InstanceModManagementSettingsView}}}"
                                        Style="{StaticResource ModManagementFilterButtonStyle}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </GroupBox>
            </DataTemplate>

            <DataTemplate DataType="{x:Type gameSettings:ModManagementModItemViewModel}">
                <controls:ListPageItemButton x:Name="ModListItemButton"
                                             Title="{Binding Title}"
                                             Subtitle="{Binding Subtitle}"
                                             TrailingText="{Binding TrailingText}"
                                             IconSource="{Binding IconSource}"
                                             IconKey="{Binding IconKey}"
                                             IsSelected="{Binding IsSelected}"
                                             IsFirstVisible="{Binding Tag.IsFirstVisible, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}"
                                             IsLastVisible="{Binding Tag.IsLastVisible, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}"
                                             IsPreviousItemHighlighted="{Binding Tag.IsPreviousItemHighlighted, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}"
                                             ShouldPlayEnterAnimation="{Binding Tag.ShouldPlayEnterAnimation, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}, Mode=TwoWay}"
                                             EnterAnimationIndex="{Binding Tag.EnterAnimationIndex, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}"
                                             Command="{Binding DataContext.SelectModCommand, RelativeSource={RelativeSource AncestorType={x:Type views:InstanceModManagementSettingsView}}}"
                                             CommandParameter="{Binding}"
                                             Style="{StaticResource ListPageItemButtonEntranceStyle}">
                    <controls:ListPageItemButton.TrailingContent>
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding DataContext.ToggleModEnabledCommand, RelativeSource={RelativeSource AncestorType={x:Type views:InstanceModManagementSettingsView}}}"
                                    CommandParameter="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource InlineIconButtonStyle}">
                                        <Setter Property="ToolTip" Value="{x:Static res:Strings.GameSettings_ModManagementDisableButton}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                <Setter Property="ToolTip" Value="{x:Static res:Strings.GameSettings_ModManagementEnableButton}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <controls:SvgIcon Width="16"
                                                  Height="16"
                                                  Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}">
                                    <controls:SvgIcon.Style>
                                        <Style TargetType="{x:Type controls:SvgIcon}">
                                            <Setter Property="IconKey" Value="account_page/account_page_forbid" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                    <Setter Property="IconKey" Value="general/general_passed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </controls:SvgIcon.Style>
                                </controls:SvgIcon>
                            </Button>

                            <Button Margin="4,0,0,0"
                                    Style="{StaticResource InlineIconButtonStyle}"
                                    ToolTip="{x:Static res:Strings.GameSettings_OpenInstanceFolderTooltip}"
                                    Command="{Binding DataContext.OpenModFileLocationCommand, RelativeSource={RelativeSource AncestorType={x:Type views:InstanceModManagementSettingsView}}}"
                                    CommandParameter="{Binding}">
                                <controls:SvgIcon Width="16"
                                                  Height="16"
                                                  IconKey="general/general_folder"
                                                  Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                            </Button>

                            <Button Margin="4,0,0,0"
                                    Style="{StaticResource SecondaryMenuDeleteButtonStyle}"
                                    ToolTip="{x:Static res:Strings.Delete_Button}"
                                    Command="{Binding DataContext.RequestDeleteModCommand, RelativeSource={RelativeSource AncestorType={x:Type views:InstanceModManagementSettingsView}}}"
                                    CommandParameter="{Binding}">
                                <controls:SvgIcon Width="16"
                                                  Height="16"
                                                  IconKey="general/general_delete"
                                                  Style="{StaticResource DangerActionSvgIconStyle}" />
                            </Button>
                        </StackPanel>
                    </controls:ListPageItemButton.TrailingContent>
                </controls:ListPageItemButton>
                <DataTemplate.Triggers>
                    <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                        <Setter TargetName="ModListItemButton" Property="controls:ListPageItemButton.TitleForeground" Value="{DynamicResource Brush.Text.Subtle}" />
                        <Setter TargetName="ModListItemButton" Property="controls:ListPageItemButton.IconOpacity" Value="0.42" />
                        <Setter TargetName="ModListItemButton" Property="controls:ListPageItemButton.IconOverlayKey" Value="account_page/account_page_forbid" />
                    </DataTrigger>
                </DataTemplate.Triggers>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid ClipToBounds="True">
        <ListBox ItemsSource="{Binding VisibleModListItems}"
                 SelectedItem="{Binding SelectedMod, Mode=OneWay}"
                 ItemContainerStyle="{StaticResource ListPageVirtualizedListBoxItemStyle}"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 VirtualizingPanel.ScrollUnit="Pixel"
                 ScrollViewer.CanContentScroll="True"
                 behaviors:VirtualizedListItemStateBehavior.IsEnabled="True"
                 behaviors:VirtualizedListItemStateBehavior.EntranceAnimationToken="{Binding ListEntranceAnimationToken}"
                 behaviors:VirtualizedListItemStateBehavior.ContentTopOffset="132">
            <ListBox.Style>
                <Style TargetType="ListBox" BasedOn="{StaticResource ListPageVirtualizedListBoxStyle}">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CanShowModScrollableContent}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListBox.Style>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel Margin="0,132,12,64"
                                            VirtualizingPanel.IsVirtualizing="True"
                                            VirtualizingPanel.VirtualizationMode="Recycling"
                                            VirtualizingPanel.ScrollUnit="Pixel" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>

        <TextBlock Margin="0,260,12,0"
                   Text="{x:Static res:Strings.GameSettings_ModManagementLoading}"
                   Style="{StaticResource PageEmptyStateTextStyle}"
                   Visibility="{Binding CanShowModLoadingState, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}" />

        <TextBlock Margin="0,260,12,0"
                   Text="{Binding ModEmptyMessage}"
                   Style="{StaticResource PageEmptyStateTextStyle}"
                   Visibility="{Binding CanShowModEmptyState, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}" />

        <TextBlock Margin="0,260,12,0"
                   Text="{Binding ModEmptyMessage}"
                   Style="{StaticResource PageEmptyStateTextStyle}"
                   Visibility="{Binding CanShowNoModsEmptyState, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}" />

        <TextBlock Margin="0,122,12,0"
                   Text="{Binding ModUnavailableMessage}"
                   Style="{StaticResource PageEmptyStateTextStyle}"
                   Visibility="{Binding CanShowModUnavailableState, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}" />
    </Grid>
</UserControl>
