<UserControl x:Class="Launcher.App.Views.GameSettings.InstanceExportSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Launcher.App.Controls"
             xmlns:gameSettings="clr-namespace:Launcher.App.ViewModels.GameSettings"
             xmlns:res="clr-namespace:Launcher.App.Resources"
             Focusable="False">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/BlockHelm_Launcher_x64;component/Views/GameSettings/GameSettingsSectionResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate x:Key="InstanceExportTypeOptionTemplate"
                          DataType="{x:Type gameSettings:InstanceExportTypeOption}">
                <TextBlock Text="{Binding Title}"
                           Foreground="{DynamicResource Brush.F4F4F4}"
                           FontSize="13"
                           VerticalAlignment="Center" />
            </DataTemplate>

        </ResourceDictionary>
    </UserControl.Resources>

    <Grid ClipToBounds="True">
        <ScrollViewer Style="{StaticResource ListPageScrollViewerStyle}">
            <StackPanel Margin="0,132,12,96"
                        MaxWidth="{StaticResource DetailPageContentMaxWidth}"
                        HorizontalAlignment="Stretch">
                <GroupBox Header="{x:Static res:Strings.GameSettings_ExportModpackInfoSection}"
                          Style="{StaticResource LauncherContentSectionStyle}">
                    <Border Style="{StaticResource SectionFieldSurfaceStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" MinWidth="220" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" MinWidth="120" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" MinWidth="120" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Margin="0,0,0,8"
                                           Text="{x:Static res:Strings.GameSettings_ExportModpackNameLabel}"
                                           Style="{StaticResource SettingsOptionTextStyle}" />

                                <TextBox Text="{Binding ExportModpackName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource LauncherDialogTextBoxStyle}" />

                                <TextBlock Margin="0,6,0,0"
                                           Text="{x:Static res:Strings.GameSettings_ExportModpackNameRequired}"
                                           Foreground="{DynamicResource Brush.Text.Danger}"
                                           FontSize="12">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsExportModpackNameEmpty}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Margin="0,0,0,8"
                                           Text="{x:Static res:Strings.GameSettings_ExportAuthorLabel}"
                                           Style="{StaticResource SettingsOptionTextStyle}" />

                                <TextBox Text="{Binding ExportAuthor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource LauncherDialogTextBoxStyle}" />
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Margin="0,0,0,8"
                                           Text="{x:Static res:Strings.GameSettings_ExportVersionLabel}"
                                           Style="{StaticResource SettingsOptionTextStyle}" />

                                <Grid>
                                    <TextBox Text="{Binding ExportVersion, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource LauncherDialogTextBoxStyle}" />

                                    <TextBlock Margin="9,0,0,0"
                                               Text="{x:Static res:Strings.GameSettings_ExportVersionPlaceholder}"
                                               Foreground="{DynamicResource Brush.Text.Disabled}"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ExportVersion}" Value="">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </StackPanel>

                            <TextBlock Grid.Row="1"
                                       Grid.ColumnSpan="5"
                                       Margin="0,8,0,0"
                                       Text="{x:Static res:Strings.GameSettings_ExportAuthorHint}"
                                       Foreground="{DynamicResource Brush.Text.Muted}"
                                       FontSize="12"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </Border>
                </GroupBox>

                <GroupBox Margin="0,26,0,0"
                          Header="{x:Static res:Strings.GameSettings_ExportSettingsSection}"
                          Style="{StaticResource LauncherContentSectionStyle}">
                    <Border Style="{StaticResource SectionFieldSurfaceStyle}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="220" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{x:Static res:Strings.GameSettings_ExportModpackTypeLabel}"
                                           Style="{StaticResource SettingsOptionTextStyle}" />

                                <controls:AnimatedComboBox Grid.Column="1"
                                                           ItemsSource="{Binding ExportTypeOptions}"
                                                           SelectedItem="{Binding SelectedExportTypeOption, Mode=TwoWay}"
                                                           ItemTemplate="{StaticResource InstanceExportTypeOptionTemplate}"
                                                           SelectionItemTemplate="{StaticResource InstanceExportTypeOptionTemplate}"
                                                           Style="{StaticResource LauncherComboBoxStyle}" />
                            </Grid>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{x:Static res:Strings.GameSettings_ExportPackModsLabel}"
                                           Style="{StaticResource SettingsOptionTextStyle}" />

                                <CheckBox Grid.Column="1"
                                          IsChecked="{Binding PackMods, Mode=TwoWay}"
                                          Style="{StaticResource LauncherSwitchToggleButtonStyle}" />
                            </Grid>

                            <Grid Margin="0,16,0,0"
                                  IsEnabled="{Binding CanPackDisabledMods}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{x:Static res:Strings.GameSettings_ExportPackDisabledModsLabel}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource SettingsOptionTextStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CanPackDisabledMods}" Value="False">
                                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Disabled}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <CheckBox Grid.Column="1"
                                          IsChecked="{Binding PackDisabledMods, Mode=TwoWay}"
                                          Style="{StaticResource LauncherSwitchToggleButtonStyle}" />
                            </Grid>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{x:Static res:Strings.GameSettings_ExportPackResourcePacksLabel}"
                                           Style="{StaticResource SettingsOptionTextStyle}" />

                                <CheckBox Grid.Column="1"
                                          IsChecked="{Binding PackResourcePacks, Mode=TwoWay}"
                                          Style="{StaticResource LauncherSwitchToggleButtonStyle}" />
                            </Grid>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{x:Static res:Strings.GameSettings_ExportPackShaderPacksLabel}"
                                           Style="{StaticResource SettingsOptionTextStyle}" />

                                <CheckBox Grid.Column="1"
                                          IsChecked="{Binding PackShaderPacks, Mode=TwoWay}"
                                          Style="{StaticResource LauncherSwitchToggleButtonStyle}" />
                            </Grid>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{x:Static res:Strings.GameSettings_ExportPackSavesLabel}"
                                           Style="{StaticResource SettingsOptionTextStyle}" />

                                <CheckBox Grid.Column="1"
                                          IsChecked="{Binding PackSaves, Mode=TwoWay}"
                                          Style="{StaticResource LauncherSwitchToggleButtonStyle}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
