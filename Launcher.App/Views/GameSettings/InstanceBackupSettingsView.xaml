<UserControl x:Class="Launcher.App.Views.GameSettings.InstanceBackupSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:Launcher.App.Behaviors"
             xmlns:controls="clr-namespace:Launcher.App.Controls"
             xmlns:gameSettings="clr-namespace:Launcher.App.ViewModels.GameSettings"
             xmlns:res="clr-namespace:Launcher.App.Resources"
             xmlns:views="clr-namespace:Launcher.App.Views.GameSettings"
             x:Name="Root"
             Focusable="False">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/MineDock%20Launcher;component/Views/GameSettings/GameSettingsSectionResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type gameSettings:BackupManagementInfoPanelItem}">
                <GroupBox Header="{x:Static res:Strings.GameSettings_BackupInfoSection}"
                          Margin="0,0,0,12"
                          Style="{StaticResource LauncherContentSectionStyle}">
                    <Border Style="{StaticResource SectionFieldSurfaceStyle}">
                        <StackPanel>
                            <Border Style="{StaticResource ReadOnlyFieldSurfaceStyle}">
                                <TextBlock Text="{Binding DataContext.BackupInfoText, RelativeSource={RelativeSource AncestorType={x:Type views:InstanceBackupSettingsView}}}"
                                           Style="{StaticResource ReadOnlyFieldTextStyle}" />
                            </Border>

                            <TextBlock Margin="0,12,0,8"
                                       Text="{x:Static res:Strings.GameSettings_BackupDirectorySection}"
                                       Style="{StaticResource SettingsOptionTextStyle}" />

                            <Border Style="{StaticResource ReadOnlyFieldSurfaceStyle}">
                                <TextBlock Text="{Binding DataContext.BackupDirectoryText, RelativeSource={RelativeSource AncestorType={x:Type views:InstanceBackupSettingsView}}}"
                                           Style="{StaticResource ReadOnlyFieldTextStyle}" />
                            </Border>

                            <TextBlock Margin="0,12,0,8"
                                       Text="{x:Static res:Strings.GameSettings_BackupActionsLabel}"
                                       Style="{StaticResource SettingsOptionTextStyle}" />

                            <WrapPanel>
                                <Button Margin="0,0,8,4"
                                        Content="{x:Static res:Strings.GameSettings_BackupOpenFolderButton}"
                                        Command="{Binding DataContext.OpenBackupFolderCommand, RelativeSource={RelativeSource AncestorType={x:Type views:InstanceBackupSettingsView}}}"
                                        Style="{StaticResource LauncherDialogButtonStyle}" />
                                <Button Margin="0,0,8,4"
                                        Content="{x:Static res:Strings.GameSettings_BackupChangeDirectoryButton}"
                                        Command="{Binding DataContext.ChangeBackupDirectoryCommand, RelativeSource={RelativeSource AncestorType={x:Type views:InstanceBackupSettingsView}}}"
                                        Style="{StaticResource LauncherDialogButtonStyle}" />
                                <Button Margin="0,0,8,4"
                                        Content="{x:Static res:Strings.GameSettings_BackupCreateNowButton}"
                                        Command="{Binding DataContext.CreateBackupNowCommand, RelativeSource={RelativeSource AncestorType={x:Type views:InstanceBackupSettingsView}}}"
                                        Style="{StaticResource LauncherPrimaryDialogButtonStyle}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </GroupBox>
            </DataTemplate>

            <DataTemplate DataType="{x:Type gameSettings:InstanceBackupItemViewModel}">
                <controls:ListPageItemButton Title="{Binding Title}"
                                             Subtitle="{Binding Subtitle}"
                                             TrailingText="{Binding TrailingText}"
                                             IconKey="{Binding IconKey}"
                                             IsSelected="{Binding IsSelected}"
                                             IsFirstVisible="{Binding Tag.IsFirstVisible, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}"
                                             IsLastVisible="{Binding Tag.IsLastVisible, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}"
                                             IsPreviousItemHighlighted="{Binding Tag.IsPreviousItemHighlighted, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}"
                                             ShouldPlayEnterAnimation="{Binding Tag.ShouldPlayEnterAnimation, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}, Mode=TwoWay}"
                                             EnterAnimationIndex="{Binding Tag.EnterAnimationIndex, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}"
                                             Command="{Binding DataContext.SelectBackupCommand, RelativeSource={RelativeSource AncestorType={x:Type views:InstanceBackupSettingsView}}}"
                                             CommandParameter="{Binding}"
                                             Style="{StaticResource ListPageItemButtonEntranceStyle}">
                    <controls:ListPageItemButton.TrailingContent>
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource InlineIconButtonStyle}"
                                    ToolTip="{x:Static res:Strings.GameSettings_BackupRestoreTooltip}"
                                    Command="{Binding DataContext.RequestRestoreBackupCommand, RelativeSource={RelativeSource AncestorType={x:Type views:InstanceBackupSettingsView}}}"
                                    CommandParameter="{Binding}">
                                <controls:SvgIcon Width="16"
                                                  Height="16"
                                                  IconKey="instance_setting_page/recover"
                                                  Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                            </Button>

                            <Button Margin="4,0,0,0"
                                    Style="{StaticResource InlineIconButtonStyle}"
                                    ToolTip="{x:Static res:Strings.GameSettings_BackupOpenLocationTooltip}"
                                    Command="{Binding DataContext.OpenBackupLocationCommand, RelativeSource={RelativeSource AncestorType={x:Type views:InstanceBackupSettingsView}}}"
                                    CommandParameter="{Binding}">
                                <controls:SvgIcon Width="16"
                                                  Height="16"
                                                  IconKey="general/general_folder"
                                                  Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                            </Button>

                            <Button Margin="4,0,0,0"
                                    Style="{StaticResource SecondaryMenuDeleteButtonStyle}"
                                    ToolTip="{x:Static res:Strings.Delete_Button}"
                                    Command="{Binding DataContext.RequestDeleteBackupCommand, RelativeSource={RelativeSource AncestorType={x:Type views:InstanceBackupSettingsView}}}"
                                    CommandParameter="{Binding}">
                                <controls:SvgIcon Width="16"
                                                  Height="16"
                                                  IconKey="general/general_delete"
                                                  Style="{StaticResource DangerActionSvgIconStyle}" />
                            </Button>
                        </StackPanel>
                    </controls:ListPageItemButton.TrailingContent>
                </controls:ListPageItemButton>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid ClipToBounds="True">
        <ListBox ItemsSource="{Binding VisibleBackupListItems}"
                 ItemContainerStyle="{StaticResource ListPageVirtualizedListBoxItemStyle}"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 VirtualizingPanel.ScrollUnit="Pixel"
                 ScrollViewer.CanContentScroll="True"
                 behaviors:VirtualizedListItemStateBehavior.IsEnabled="True"
                 behaviors:VirtualizedListItemStateBehavior.EntranceAnimationToken="{Binding ListEntranceAnimationToken}"
                 behaviors:VirtualizedListItemStateBehavior.ContentTopOffset="132">
            <ListBox.Style>
                <Style TargetType="ListBox" BasedOn="{StaticResource ListPageVirtualizedListBoxStyle}">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CanShowBackupScrollableContent}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListBox.Style>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel Margin="0,132,12,64"
                                            VirtualizingPanel.IsVirtualizing="True"
                                            VirtualizingPanel.VirtualizationMode="Recycling"
                                            VirtualizingPanel.ScrollUnit="Pixel" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>

        <TextBlock Margin="0,260,12,0"
                   Text="{x:Static res:Strings.GameSettings_BackupLoading}"
                   Style="{StaticResource PageEmptyStateTextStyle}"
                   Visibility="{Binding CanShowBackupLoadingState, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}" />

        <TextBlock Margin="0,260,12,0"
                   Text="{Binding BackupEmptyMessage}"
                   Style="{StaticResource PageEmptyStateTextStyle}"
                   Visibility="{Binding CanShowBackupEmptyState, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}" />
    </Grid>
</UserControl>
