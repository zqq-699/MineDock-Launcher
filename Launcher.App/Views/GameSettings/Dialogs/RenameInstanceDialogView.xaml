<UserControl x:Class="Launcher.App.Views.GameSettings.Dialogs.RenameInstanceDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Launcher.App.Controls"
             xmlns:res="clr-namespace:Launcher.App.Resources"
             xmlns:viewModels="clr-namespace:Launcher.App.ViewModels.GameSettings"
             Focusable="False">
    <UserControl.Resources>
        <DataTemplate x:Key="IconOptionTemplate"
                      DataType="{x:Type viewModels:GameSettingsIconOption}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="36" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Image Width="24"
                       Height="24"
                       Source="{Binding IconSource}"
                       Stretch="Fill"
                       SnapsToDevicePixels="True"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center" />

                <TextBlock Grid.Column="1"
                           Margin="10,0,0,0"
                           Text="{Binding Title}"
                           Foreground="{DynamicResource Brush.F4F4F4}"
                           FontSize="13"
                           VerticalAlignment="Center" />
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Style="{StaticResource DialogContentGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{Binding EditInstanceDialogTitle}"
                       Style="{StaticResource DialogTitleTextStyle}" />
            <TextBlock Text="{Binding EditInstanceDialogSubtitle}"
                       Style="{StaticResource DialogSubtitleTextStyle}" />
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Style="{StaticResource DialogFormPanelStyle}"
                    Visibility="{Binding IsEditInstanceInputStep, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}">
            <TextBlock Text="{x:Static res:Strings.GameSettings_InstanceNameLabel}"
                       Style="{StaticResource DialogFieldLabelTextStyle}" />
            <TextBox Style="{StaticResource LauncherDialogTextBoxStyle}"
                     Text="{Binding InstanceName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="{x:Static res:Strings.GameSettings_InstanceNameValidation}"
                       Style="{StaticResource DialogValidationTextStyle}"
                       Visibility="{Binding IsInstanceNameInvalid, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}" />

            <TextBlock Margin="0,20,0,8"
                       Text="{x:Static res:Strings.GameSettings_InstanceIconLabel}"
                       Style="{StaticResource DialogFieldLabelTextStyle}" />

            <controls:AnimatedComboBox ItemsSource="{Binding IconOptions}"
                                       SelectedItem="{Binding SelectedIconOption, Mode=TwoWay}"
                                       SelectionItemTemplate="{StaticResource IconOptionTemplate}"
                                       ItemTemplate="{StaticResource IconOptionTemplate}"
                                       Style="{StaticResource LauncherComboBoxStyle}" />
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Style="{StaticResource DialogFormPanelStyle}"
                    Visibility="{Binding IsEditInstanceMessageStep, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}">
            <Grid Width="34"
                  Height="34"
                  HorizontalAlignment="Center">
                <controls:SvgIcon Width="30"
                                  Height="30"
                                  IconKey="{Binding EditInstanceGlyphIconKey}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center">
                    <controls:SvgIcon.Style>
                        <Style TargetType="{x:Type controls:SvgIcon}">
                            <Setter Property="Foreground" Value="{DynamicResource Brush.F4F4F4}" />
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding EditInstanceGlyphIconKey}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsEditInstanceSuccessful}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource Brush.7DFFB2}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsEditInstanceResultStep}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource Brush.FF8A8A}" />
                                </DataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsEditInstanceResultStep}" Value="True" />
                                        <Condition Binding="{Binding IsEditInstanceSuccessful}" Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Foreground" Value="{DynamicResource Brush.7DFFB2}" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </controls:SvgIcon.Style>
                </controls:SvgIcon>

                <TextBlock Text="{Binding EditInstanceGlyph}"
                           FontFamily="{DynamicResource LauncherIconFontFamily}"
                           FontSize="30"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.F4F4F4}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding EditInstanceGlyphIconKey}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <TextBlock Margin="0,16,0,0"
                       Text="{Binding EditInstanceMessage}"
                       Style="{StaticResource DialogBodyTextStyle}"
                       TextAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Style="{StaticResource DialogFooterStyle}">
            <Button Style="{StaticResource LauncherDialogButtonStyle}"
                    Content="{x:Static res:Strings.Cancel_Button}"
                    Command="{Binding CancelCommand}"
                    Visibility="{Binding CanShowEditInstanceCancelButton, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}" />
            <Button Style="{StaticResource LauncherPrimaryDialogButtonStyle}"
                    Margin="{StaticResource DialogTrailingButtonMargin}"
                    Content="{x:Static res:Strings.Confirm_Button}"
                    IsEnabled="{Binding CanConfirmEditInstanceDialog}"
                    Command="{Binding ConfirmCommand}" />
        </StackPanel>
    </Grid>
</UserControl>

