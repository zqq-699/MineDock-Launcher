<UserControl x:Class="Launcher.App.Views.GameSettings.Dialogs.CreateBackupDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:Launcher.App.Resources"
             Focusable="False">
    <Grid Style="{StaticResource DialogContentGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{x:Static res:Strings.Dialog_CreateBackupTitle}"
                       Style="{StaticResource DialogTitleTextStyle}" />
            <TextBlock Text="{x:Static res:Strings.Dialog_CreateBackupSubtitle}"
                       Style="{StaticResource DialogSubtitleTextStyle}" />
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Style="{StaticResource DialogFormPanelStyle}">
            <TextBlock Text="{x:Static res:Strings.Dialog_CreateBackupNameLabel}"
                       Style="{StaticResource DialogFieldLabelTextStyle}" />
            <TextBox Style="{StaticResource LauncherDialogTextBoxStyle}"
                     Text="{Binding NewBackupName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="{x:Static res:Strings.Dialog_CreateBackupNameValidation}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource DialogValidationTextStyle}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CanConfirmCreateBackupDialog}" Value="False">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Style="{StaticResource DialogFooterStyle}">
            <Button Style="{StaticResource LauncherDialogButtonStyle}"
                    Content="{x:Static res:Strings.Cancel_Button}"
                    Command="{Binding CancelCreateBackupDialogCommand}" />
            <Button Style="{StaticResource LauncherPrimaryDialogButtonStyle}"
                    Margin="{StaticResource DialogTrailingButtonMargin}"
                    Content="{x:Static res:Strings.Confirm_Button}"
                    IsEnabled="{Binding CanConfirmCreateBackupDialog}"
                    Command="{Binding ConfirmCreateBackupDialogCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
