<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
                    xmlns:controls="clr-namespace:Launcher.App.Controls"
                    xmlns:behaviors="clr-namespace:Launcher.App.Behaviors"
                    xmlns:converters="clr-namespace:Launcher.App.Converters"
                    xmlns:res="clr-namespace:Launcher.App.Resources">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/MineDock_Launcher_x64;component/Resources/Themes/Shared.xaml" />
        <ResourceDictionary Source="pack://application:,,,/MineDock_Launcher_x64;component/Styles/ControlStyles.Scroll.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="ListPageHeaderOverlayStyle" TargetType="Border">
        <Setter Property="Height" Value="132" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Panel.ZIndex" Value="2" />
        <Setter Property="IsHitTestVisible" Value="True" />
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style x:Key="DownloadContentHeaderOverlayStyle"
           TargetType="Border"
           BasedOn="{StaticResource ListPageHeaderOverlayStyle}" />

    <Style x:Key="ListPageBottomOverlayStyle" TargetType="Border">
        <Setter Property="Height" Value="72" />
        <Setter Property="Margin" Value="0,0,14,0" />
        <Setter Property="VerticalAlignment" Value="Bottom" />
        <Setter Property="Panel.ZIndex" Value="2" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style x:Key="DownloadContentBottomOverlayStyle"
           TargetType="Border"
           BasedOn="{StaticResource ListPageBottomOverlayStyle}" />

    <Style x:Key="ListPageHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,6,0,0" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.F4FFFFFF}" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="DownloadContentHeaderTextStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource ListPageHeaderTextStyle}" />

    <Style x:Key="ListPageFilterLabelStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource LauncherTextSecondaryBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="ListPageHeaderBackButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.EFFFFFFF}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="ToolTip" Value="{x:Static res:Strings.Back_Tooltip}" />
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid Background="{TemplateBinding Background}">
                        <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualStateGroup.Transitions>
                                        <VisualTransition GeneratedDuration="0:0:0.16" />
                                    </VisualStateGroup.Transitions>
                                    <VisualState x:Name="Normal">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="NormalIcon" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.16" />
                                            <DoubleAnimation Storyboard.TargetName="HoverIcon" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.16" />
                                            <DoubleAnimation Storyboard.TargetName="PressedIcon" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.16" />
                                            <DoubleAnimation Storyboard.TargetName="DisabledIcon" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.16" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="MouseOver">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="NormalIcon" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.16" />
                                            <DoubleAnimation Storyboard.TargetName="HoverIcon" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.16" />
                                            <DoubleAnimation Storyboard.TargetName="PressedIcon" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.16" />
                                            <DoubleAnimation Storyboard.TargetName="DisabledIcon" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.16" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="NormalIcon" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.10" />
                                            <DoubleAnimation Storyboard.TargetName="HoverIcon" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.10" />
                                            <DoubleAnimation Storyboard.TargetName="PressedIcon" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.10" />
                                            <DoubleAnimation Storyboard.TargetName="DisabledIcon" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.10" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="NormalIcon" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.16" />
                                            <DoubleAnimation Storyboard.TargetName="HoverIcon" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.16" />
                                            <DoubleAnimation Storyboard.TargetName="PressedIcon" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.16" />
                                            <DoubleAnimation Storyboard.TargetName="DisabledIcon" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.16" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>

                        <controls:SvgIcon x:Name="NormalIcon"
                                          Width="28"
                                          Height="28"
                                          IconKey="general/general_arrow_left"
                                          Foreground="{TemplateBinding Foreground}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          IsHitTestVisible="False" />
                        <controls:SvgIcon x:Name="HoverIcon"
                                          Width="28"
                                          Height="28"
                                          IconKey="general/general_arrow_left"
                                          Foreground="{DynamicResource Brush.B8FFFFFF}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Opacity="0"
                                          IsHitTestVisible="False" />
                        <controls:SvgIcon x:Name="PressedIcon"
                                          Width="28"
                                          Height="28"
                                          IconKey="general/general_arrow_left"
                                          Foreground="{DynamicResource Brush.90FFFFFF}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Opacity="0"
                                          IsHitTestVisible="False" />
                        <controls:SvgIcon x:Name="DisabledIcon"
                                          Width="28"
                                          Height="28"
                                          IconKey="general/general_arrow_left"
                                          Foreground="{DynamicResource Brush.70FFFFFF}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Opacity="0"
                                          IsHitTestVisible="False" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ListPageHeaderSpacerStyle" TargetType="Border">
        <Setter Property="Height" Value="132" />
        <Setter Property="IsHitTestVisible" Value="False" />
    </Style>

    <Style x:Key="DownloadContentHeaderSpacerStyle"
           TargetType="Border"
           BasedOn="{StaticResource ListPageHeaderSpacerStyle}" />

    <Style x:Key="ListPageSearchBoxStyle" TargetType="TextBox">
        <Setter Property="Height" Value="32" />
        <Setter Property="Margin" Value="0,58,12,0" />
        <Setter Property="Padding" Value="14,0,7,0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.F2FFFFFF}" />
        <Setter Property="CaretBrush" Value="{DynamicResource Brush.F2FFFFFF}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.18FFFFFF}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SelectionBrush" Value="{DynamicResource Brush.660891FE}" />
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Root"
                            Background="Transparent"
                            CornerRadius="10">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12"
                                              Color="{DynamicResource Color.000000}"
                                              Opacity="0.16"
                                              ShadowDepth="0" />
                        </Border.Effect>
                        <Grid>
                            <Border x:Name="SearchBlurSurface"
                                    Background="{DynamicResource Brush.SecondaryMenu.Panel}"
                                    Opacity="1"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10"
                                    ClipToBounds="True"
                                    behaviors:RoundedClip.Radius="10" />
                            <controls:SvgIcon Width="15"
                                              Height="15"
                                              Margin="8,0,0,0"
                                              IconKey="general/general_search"
                                              Foreground="{DynamicResource Brush.70FFFFFF}"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False" />
                            <TextBlock x:Name="SearchPlaceholderText"
                                       Margin="25,0,0,0"
                                           Text="{x:Static res:Strings.Search_Placeholder}"
                                           Foreground="{DynamicResource Brush.70FFFFFF}"
                                           FontSize="13"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Visibility="Collapsed" />
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center">
                                <ScrollViewer.RenderTransform>
                                    <TranslateTransform Y="-1" />
                                </ScrollViewer.RenderTransform>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Text" Value="" />
                                <Condition Property="IsKeyboardFocusWithin" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="SearchPlaceholderText" Property="Visibility" Value="Visible" />
                        </MultiTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="SearchBlurSurface" Property="BorderBrush" Value="{DynamicResource Brush.20FFFFFF}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="SearchBlurSurface" Property="BorderBrush" Value="{DynamicResource Brush.42FFFFFF}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DownloadVersionSearchBoxStyle"
           TargetType="TextBox"
           BasedOn="{StaticResource ListPageSearchBoxStyle}" />

    <Style x:Key="ListPageBottomSpacerStyle" TargetType="Border">
        <Setter Property="Height" Value="64" />
        <Setter Property="IsHitTestVisible" Value="False" />
    </Style>

    <Style x:Key="DownloadContentBottomSpacerStyle"
           TargetType="Border"
           BasedOn="{StaticResource ListPageBottomSpacerStyle}" />

    <Style x:Key="ListPageScrollBarStyle"
           TargetType="ScrollBar"
           BasedOn="{StaticResource MainContentScrollBarStyle}">
        <Setter Property="Margin" Value="0,132,2,72" />
    </Style>

    <Style x:Key="DownloadContentScrollBarStyle"
           TargetType="ScrollBar"
           BasedOn="{StaticResource ListPageScrollBarStyle}" />

    <Style x:Key="ListPageScrollViewerStyle"
           TargetType="ScrollViewer"
           BasedOn="{StaticResource MainContentScrollViewerStyle}">
        <Style.Resources>
            <Style TargetType="ScrollBar" BasedOn="{StaticResource ListPageScrollBarStyle}" />
        </Style.Resources>
    </Style>

    <Style x:Key="DownloadContentScrollViewerStyle"
           TargetType="ScrollViewer"
           BasedOn="{StaticResource ListPageScrollViewerStyle}" />

    <Style x:Key="NativeVirtualizedListPageScrollViewerStyle"
           TargetType="ScrollViewer"
           BasedOn="{StaticResource ListPageScrollViewerStyle}">
        <Setter Property="CanContentScroll" Value="True" />
        <Setter Property="behaviors:SmoothScrollBehavior.IsEnabled" Value="True" />
        <Setter Property="behaviors:SmoothScrollBehavior.AllowContentScroll" Value="True" />
        <Setter Property="behaviors:SmoothScrollBehavior.ScrollAmount" Value="174" />
        <Setter Property="behaviors:SmoothScrollBehavior.WheelAnimationDurationMilliseconds" Value="130" />
    </Style>

    <Style x:Key="DownloadVersionListBoxStyle" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="MaxWidth" Value="{StaticResource DetailPageContentMaxWidth}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel" />
        <Setter Property="VirtualizingPanel.CacheLength" Value="1" />
        <Setter Property="VirtualizingPanel.CacheLengthUnit" Value="Page" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                        <ScrollViewer x:Name="PART_ScrollViewer"
                                      Focusable="False"
                                      Style="{StaticResource NativeVirtualizedListPageScrollViewerStyle}">
                            <ItemsPresenter />
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DownloadVersionListBoxItemStyle" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ListPageVirtualizedListBoxStyle"
           TargetType="ListBox"
           BasedOn="{StaticResource DownloadVersionListBoxStyle}" />

    <Style x:Key="ListPageVirtualizedListBoxItemStyle"
           TargetType="ListBoxItem"
           BasedOn="{StaticResource DownloadVersionListBoxItemStyle}" />

    <Style x:Key="ListPageItemButtonEntranceStyle"
           TargetType="{x:Type controls:ListPageItemButton}">
        <Setter Property="IsEnterAnimationPending" Value="True" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding Tag.IsEntranceAnimationPending, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}" Value="False">
                <Setter Property="IsEnterAnimationPending" Value="False" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag.IsEntranceAnimationPending, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}" Value="True">
                <Setter Property="IsEnterAnimationPending" Value="True" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="DownloadVersionListItemButtonEntranceStyle"
           TargetType="{x:Type controls:ListPageItemButton}"
           BasedOn="{StaticResource ListPageItemButtonEntranceStyle}" />

    <Style x:Key="InstallTaskCardStyle" TargetType="Border">
        <Setter Property="Margin" Value="0,0,12,12" />
        <Setter Property="Height" Value="144" />
        <Setter Property="Padding" Value="18" />
        <Setter Property="Background" Value="{DynamicResource Brush.1CFFFFFF}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.18FFFFFF}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="ClipToBounds" Value="True" />
    </Style>

    <Style x:Key="InstallTaskTitleTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Brush.F4F4F4}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="InstallTaskSubtitleTextStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,5,0,0" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.AFFFFFFF}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="InstallTaskStateTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Brush.DFFFFFFF}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextAlignment" Value="Right" />
        <Setter Property="Height" Value="16" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="InstallTaskSpeedTextStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,5,0,0" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.9FFFFFFF}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextAlignment" Value="Right" />
        <Setter Property="Height" Value="16" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="Visibility" Value="Hidden" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding HasDownloadSpeedText}" Value="True">
                <Setter Property="Visibility" Value="Visible" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="InstallTaskStatusTextStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,4,0,0" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.CFFFFFFF}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="InstallTaskProgressTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Brush.AFFFFFFF}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="SecondaryMenuVirtualizedListBoxStyle" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel" />
        <Setter Property="VirtualizingPanel.CacheLength" Value="1" />
        <Setter Property="VirtualizingPanel.CacheLengthUnit" Value="Page" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel Margin="14,74,14,18"
                                            VirtualizingPanel.IsVirtualizing="True"
                                            VirtualizingPanel.VirtualizationMode="Recycling"
                                            VirtualizingPanel.ScrollUnit="Pixel" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            ClipToBounds="True"
                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                        <ScrollViewer x:Name="PART_ScrollViewer"
                                      Focusable="False"
                                      Style="{StaticResource SecondaryMenuVirtualizedScrollViewerStyle}">
                            <ItemsPresenter />
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HomeLaunchInstanceListBoxStyle"
           TargetType="ListBox"
           BasedOn="{StaticResource SecondaryMenuVirtualizedListBoxStyle}">
        <Setter Property="Margin" Value="0" />
        <Setter Property="Visibility" Value="Visible" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding HasLaunchInstances}" Value="False">
                <Setter Property="Visibility" Value="Collapsed" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SecondaryMenuItemsPanelStyle" TargetType="StackPanel">
        <Setter Property="Margin" Value="14,4,14,0" />
    </Style>

    <Style x:Key="SecondaryMenuBottomSpacerStyle" TargetType="Border">
        <Setter Property="Height" Value="18" />
        <Setter Property="IsHitTestVisible" Value="False" />
    </Style>

</ResourceDictionary>

