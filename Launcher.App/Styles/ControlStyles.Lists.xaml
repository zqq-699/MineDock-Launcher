<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
                    xmlns:controls="clr-namespace:Launcher.App.Controls"
                    xmlns:behaviors="clr-namespace:Launcher.App.Behaviors"
                    xmlns:converters="clr-namespace:Launcher.App.Converters"
                    xmlns:res="clr-namespace:Launcher.App.Resources">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ControlStyles.Scroll.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="ListPageHeaderOverlayStyle" TargetType="Border">
        <Setter Property="Height" Value="132" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Panel.ZIndex" Value="2" />
        <Setter Property="IsHitTestVisible" Value="True" />
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#E0141414" Offset="0" />
                    <GradientStop Color="#D0141414" Offset="0.74" />
                    <GradientStop Color="#00141414" Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DownloadContentHeaderOverlayStyle"
           TargetType="Border"
           BasedOn="{StaticResource ListPageHeaderOverlayStyle}" />

    <Style x:Key="ListPageBottomOverlayStyle" TargetType="Border">
        <Setter Property="Height" Value="72" />
        <Setter Property="Margin" Value="0,0,14,0" />
        <Setter Property="VerticalAlignment" Value="Bottom" />
        <Setter Property="Panel.ZIndex" Value="2" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#00141414" Offset="0" />
                    <GradientStop Color="#B8141414" Offset="0.74" />
                    <GradientStop Color="#E0141414" Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DownloadContentBottomOverlayStyle"
           TargetType="Border"
           BasedOn="{StaticResource ListPageBottomOverlayStyle}" />

    <Style x:Key="ListPageHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,6,0,0" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Foreground" Value="#F4FFFFFF" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="DownloadContentHeaderTextStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource ListPageHeaderTextStyle}" />

    <Style x:Key="ListPageHeaderSpacerStyle" TargetType="Border">
        <Setter Property="Height" Value="132" />
        <Setter Property="IsHitTestVisible" Value="False" />
    </Style>

    <Style x:Key="DownloadContentHeaderSpacerStyle"
           TargetType="Border"
           BasedOn="{StaticResource ListPageHeaderSpacerStyle}" />

    <Style x:Key="ListPageSearchBoxStyle" TargetType="TextBox">
        <Setter Property="Height" Value="32" />
        <Setter Property="Margin" Value="0,58,12,0" />
        <Setter Property="Padding" Value="14,0,7,0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Foreground" Value="#F2FFFFFF" />
        <Setter Property="CaretBrush" Value="#F2FFFFFF" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="#18FFFFFF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SelectionBrush" Value="#660891FE" />
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Root"
                            Background="Transparent"
                            CornerRadius="10">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12"
                                              Color="#000000"
                                              Opacity="0.16"
                                              ShadowDepth="0" />
                        </Border.Effect>
                        <Grid>
                            <controls:BackdropBlurBorder x:Name="SearchBlurSurface"
                                                         SourceElement="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                                         UseSourceElementAsRenderRoot="True"
                                                         Opacity="1"
                                                         BlurRadius="20"
                                                         RenderScale="0.58"
                                                         IsRealtimeRefreshEnabled="True"
                                                         TintColor="#66252525"
                                                         BorderBrush="{TemplateBinding BorderBrush}"
                                                         BorderThickness="{TemplateBinding BorderThickness}"
                                                         CornerRadius="10"
                                                         ClipToBounds="True"
                                                         behaviors:RoundedClip.Radius="10" />
                            <Border x:Name="HoverLayer"
                                    Background="#10FFFFFF"
                                    CornerRadius="10"
                                    Opacity="0" />
                            <controls:SvgIcon Width="15"
                                              Height="15"
                                              Margin="8,0,0,0"
                                              IconKey="general/general_search"
                                              Foreground="#70FFFFFF"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False" />
                            <TextBlock x:Name="SearchPlaceholderText"
                                       Margin="25,0,0,0"
                                           Text="{x:Static res:Strings.Search_Placeholder}"
                                           Foreground="#70FFFFFF"
                                           FontSize="13"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Visibility="Collapsed" />
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center">
                                <ScrollViewer.RenderTransform>
                                    <TranslateTransform Y="-1" />
                                </ScrollViewer.RenderTransform>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Text" Value="" />
                                <Condition Property="IsKeyboardFocusWithin" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="SearchPlaceholderText" Property="Visibility" Value="Visible" />
                        </MultiTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HoverLayer" Property="Opacity" Value="1" />
                            <Setter TargetName="SearchBlurSurface" Property="BorderBrush" Value="#20FFFFFF" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="HoverLayer" Property="Opacity" Value="1" />
                            <Setter TargetName="SearchBlurSurface" Property="BorderBrush" Value="#42FFFFFF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DownloadVersionSearchBoxStyle"
           TargetType="TextBox"
           BasedOn="{StaticResource ListPageSearchBoxStyle}" />

    <Style x:Key="ListPageBottomSpacerStyle" TargetType="Border">
        <Setter Property="Height" Value="64" />
        <Setter Property="IsHitTestVisible" Value="False" />
    </Style>

    <Style x:Key="DownloadContentBottomSpacerStyle"
           TargetType="Border"
           BasedOn="{StaticResource ListPageBottomSpacerStyle}" />

    <Style x:Key="ListPageScrollBarStyle"
           TargetType="ScrollBar"
           BasedOn="{StaticResource MainContentScrollBarStyle}">
        <Setter Property="Margin" Value="0,132,2,72" />
    </Style>

    <Style x:Key="DownloadContentScrollBarStyle"
           TargetType="ScrollBar"
           BasedOn="{StaticResource ListPageScrollBarStyle}" />

    <Style x:Key="ListPageScrollViewerStyle"
           TargetType="ScrollViewer"
           BasedOn="{StaticResource MainContentScrollViewerStyle}">
        <Style.Resources>
            <Style TargetType="ScrollBar" BasedOn="{StaticResource ListPageScrollBarStyle}" />
        </Style.Resources>
    </Style>

    <Style x:Key="DownloadContentScrollViewerStyle"
           TargetType="ScrollViewer"
           BasedOn="{StaticResource ListPageScrollViewerStyle}" />

    <Style x:Key="NativeVirtualizedListPageScrollViewerStyle"
           TargetType="ScrollViewer"
           BasedOn="{StaticResource ListPageScrollViewerStyle}">
        <Setter Property="CanContentScroll" Value="True" />
        <Setter Property="behaviors:SmoothScrollBehavior.IsEnabled" Value="True" />
        <Setter Property="behaviors:SmoothScrollBehavior.AllowContentScroll" Value="True" />
        <Setter Property="behaviors:SmoothScrollBehavior.ScrollAmount" Value="174" />
        <Setter Property="behaviors:SmoothScrollBehavior.WheelAnimationDurationMilliseconds" Value="130" />
    </Style>

    <Style x:Key="DownloadVersionListBoxStyle" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel" />
        <Setter Property="VirtualizingPanel.CacheLength" Value="1" />
        <Setter Property="VirtualizingPanel.CacheLengthUnit" Value="Page" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                        <ScrollViewer x:Name="PART_ScrollViewer"
                                      Focusable="False"
                                      Style="{StaticResource NativeVirtualizedListPageScrollViewerStyle}">
                            <ItemsPresenter />
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DownloadVersionListBoxItemStyle" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryMenuItemsPanelStyle" TargetType="StackPanel">
        <Setter Property="Margin" Value="14,4,14,0" />
    </Style>

    <Style x:Key="SecondaryMenuBottomSpacerStyle" TargetType="Border">
        <Setter Property="Height" Value="18" />
        <Setter Property="IsHitTestVisible" Value="False" />
    </Style>

</ResourceDictionary>
