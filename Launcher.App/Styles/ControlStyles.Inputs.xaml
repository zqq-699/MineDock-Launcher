                            </MultiTrigger.Conditions>
                            <Setter TargetName="SelectionTextBlock" Property="Visibility" Value="Visible" />
                            <Setter TargetName="SelectionContentPresenter" Property="Visibility" Value="Collapsed" />
                        </MultiTrigger>
                        <Trigger Property="SelectionItemTemplate" Value="{x:Null}">
