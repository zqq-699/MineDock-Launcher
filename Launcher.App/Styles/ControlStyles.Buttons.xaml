                                              Opacity="0.28"
                                              ShadowDepth="0" />
                        </Border.Effect>
                        <Grid>
                            <Border x:Name="BaseBackground"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="17" />
                            <Border x:Name="HoverBackground"
                                    Background="{DynamicResource Brush.D04A4A4A}"
                                    CornerRadius="17"
                                    Opacity="0" />
                            <Border x:Name="PressedBackground"
                                    Background="{DynamicResource Brush.E05A5A5A}"
                                    CornerRadius="17"
                                    Opacity="0" />
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="Mouse.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverBackground"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="1"
                                                     Duration="0:0:0.16">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Mouse.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverBackground"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0"
                                                     Duration="0:0:0.22">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="PressedBackground" Property="Opacity" Value="1" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="LauncherProgressBarStyle" TargetType="ProgressBar">
        <Setter Property="Height" Value="5" />
        <Setter Property="Foreground" Value="{DynamicResource LauncherAccentBrush}" />
        <Setter Property="Background" Value="{DynamicResource Brush.24FFFFFF}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="behaviors:ProgressBarAnimation.IsEnabled" Value="True" />
        <Setter Property="behaviors:ProgressBarAnimation.DurationMilliseconds" Value="360" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid x:Name="Root"
                          Height="{TemplateBinding Height}"
                          UseLayoutRounding="True">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3" />
                        <Grid ClipToBounds="True"
                              behaviors:RoundedClip.Radius="3">
                            <Border x:Name="Indicator"
                                    Width="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(behaviors:ProgressBarAnimation.AnimatedWidth)}"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="3">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8"
                                                      Color="{DynamicResource Color.0891FE}"
                                                      Opacity="0.26"
                                                      ShadowDepth="0" />
                                </Border.Effect>
                            </Border>
                        </Grid>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryMenuButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="36" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="12,3" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.F2F2F2}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="behaviors:OptionHoverBehavior.IsEnabled" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            CornerRadius="10">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="10" />
                            <Border x:Name="SelectedBackground"
                                    Background="{DynamicResource Brush.22FFFFFF}"
                                    CornerRadius="10"
                                    Opacity="0" />
                            <Border x:Name="HoverBackground"
                                    Background="{DynamicResource Brush.22FFFFFF}"
                                    CornerRadius="10"
                                    Opacity="0" />
                            <Border x:Name="PressedBackground"
                                    Background="{DynamicResource Brush.34FFFFFF}"
                                    CornerRadius="10"
                                    Opacity="0" />
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="PressedBackground" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="behaviors:OptionHoverBehavior.IsActive" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBackground"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBackground"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.22">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsSelected}" Value="True" />
                                <Condition Binding="{Binding Path=(behaviors:SecondaryMenuButtonBehavior.SuppressSelectedBackground), RelativeSource={RelativeSource TemplatedParent}}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="SelectedBackground" Property="Opacity" Value="1" />
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Tag.IsSelected, RelativeSource={RelativeSource TemplatedParent}}" Value="True" />
                                <Condition Binding="{Binding Path=(behaviors:SecondaryMenuButtonBehavior.SuppressSelectedBackground), RelativeSource={RelativeSource TemplatedParent}}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="SelectedBackground" Property="Opacity" Value="1" />
                        </MultiDataTrigger>
                        <Trigger Property="behaviors:SecondaryMenuButtonBehavior.SuppressSelectedBackground" Value="True">
                            <Setter TargetName="SelectedBackground" Property="Opacity" Value="0" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Disabled}" />
                            <Setter Property="Cursor" Value="Arrow" />
                            <Setter TargetName="HoverBackground" Property="Opacity" Value="0" />
                            <Setter TargetName="PressedBackground" Property="Opacity" Value="0" />
                            <Setter TargetName="Root" Property="Opacity" Value="0.68" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryMenuDeleteButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="30" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Button.DangerIcon.Foreground}" />
