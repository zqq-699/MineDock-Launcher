                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource Brush.F4FFFFFF}" />
                            <Setter TargetName="HoverBackground" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource Brush.E8FFFFFF}" />
                            <Setter TargetName="PressedBackground" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Cursor" Value="Arrow" />
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Icon.Muted}" />
                            <Setter TargetName="HoverBackground" Property="Opacity" Value="0" />
                            <Setter TargetName="PressedBackground" Property="Opacity" Value="0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="controls:SvgIcon">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Icon.Primary}" />
    </Style>

    <Style x:Key="DangerActionSvgIconStyle"
           TargetType="controls:SvgIcon"
           BasedOn="{StaticResource {x:Type controls:SvgIcon}}">
        <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
    </Style>

    <Style x:Key="LauncherSwitchToggleButtonStyle" TargetType="CheckBox">
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="18" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="{DynamicResource Brush.6E6E6E}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid Width="{TemplateBinding Width}"
                          Height="{TemplateBinding Height}"
                          Background="Transparent">
                        <Border x:Name="Track"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5.625" />
                        <Border x:Name="TrackOutline"
                                Background="Transparent"
                                BorderBrush="{DynamicResource Brush.1AFFFFFF}"
                                BorderThickness="1"
                                CornerRadius="5.625" />
                        <Border x:Name="ActiveTrack"
                                Background="{DynamicResource Brush.Accent.Primary}"
                                CornerRadius="5.625"
                                Opacity="0" />
                        <Border x:Name="Thumb"
                                Width="9"
                                Height="11.25"
                                Margin="3.375,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Background="{DynamicResource Brush.FFFFFF}"
                                CornerRadius="3.375">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="ThumbTranslateTransform" X="0" />
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="11.25"
                                                  Color="{DynamicResource Color.20000000}"
                                                  Opacity="0.2"
                                                  ShadowDepth="0" />
                            </Border.Effect>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="ActiveTrack" Property="Opacity" Value="1" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Thumb"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                         To="20.25"
                                                         Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ActiveTrack"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="0:0:0.14">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Thumb"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                         To="0"
                                                         Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ActiveTrack"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Track" Property="Opacity" Value="0.98" />
                            <Setter TargetName="Thumb" Property="Opacity" Value="0.98" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Track" Property="Opacity" Value="0.92" />
                            <Setter TargetName="Thumb" Property="Opacity" Value="0.94" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="1" />
                            <Setter Property="Cursor" Value="Arrow" />
                            <Setter TargetName="Track" Property="Background" Value="{DynamicResource Brush.434343}" />
                            <Setter TargetName="TrackOutline" Property="BorderBrush" Value="{DynamicResource Brush.18FFFFFF}" />
                            <Setter TargetName="ActiveTrack" Property="Background" Value="{DynamicResource Brush.434343}" />
                            <Setter TargetName="ActiveTrack" Property="Opacity" Value="0" />
                            <Setter TargetName="Thumb" Property="Background" Value="{DynamicResource Brush.C8D0D9}" />
                            <Setter TargetName="Thumb" Property="Opacity" Value="0.62" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsEnabled" Value="False" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Track" Property="Background" Value="{DynamicResource Brush.434343}" />
                            <Setter TargetName="TrackOutline" Property="BorderBrush" Value="{DynamicResource Brush.Accent.Border}" />
                            <Setter TargetName="ActiveTrack" Property="Background" Value="{DynamicResource Brush.Accent.Border}" />
                            <Setter TargetName="Thumb" Property="Background" Value="{DynamicResource Brush.FFFFFF}" />
                            <Setter TargetName="Thumb" Property="Opacity" Value="0.82" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="LauncherSwitchToggleButtonDisabledStyle"
           TargetType="CheckBox"
           BasedOn="{StaticResource LauncherSwitchToggleButtonStyle}">
        <Setter Property="IsEnabled" Value="False" />
    </Style>

    <Style x:Key="InstallTaskCancelButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource SecondaryMenuDeleteButtonStyle}">
        <Setter Property="Width" Value="26" />
        <Setter Property="Height" Value="26" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
    </Style>

</ResourceDictionary>

