<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
                    xmlns:controls="clr-namespace:Launcher.App.Controls"
                    xmlns:behaviors="clr-namespace:Launcher.App.Behaviors"
                    xmlns:converters="clr-namespace:Launcher.App.Converters"
                    xmlns:res="clr-namespace:Launcher.App.Resources">
    <Style x:Key="LauncherContentSectionStyle" TargetType="GroupBox">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.A8FFFFFF}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <StackPanel>
                        <ContentPresenter ContentSource="Header"
                                          RecognizesAccessKey="True"
                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                          TextElement.FontSize="16"
                                          TextElement.FontWeight="{TemplateBinding FontWeight}" />
                        <ContentPresenter Margin="0,12,0,0"
                                          ContentSource="Content" />
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ListPageItemButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="52" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.F2F2F2}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="behaviors:OptionHoverBehavior.IsEnabled" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            CornerRadius="10">
                        <Grid>
                            <Border x:Name="SelectedBackground"
                                    Background="{DynamicResource Brush.List.Item.Selected}"
                                    CornerRadius="10"
                                    Opacity="0" />
                            <Border x:Name="HoverBackground"
                                    Background="{DynamicResource Brush.List.Item.Hover}"
                                    CornerRadius="10"
                                    Opacity="0" />
                            <Border x:Name="PressedBackground"
                                    Background="{DynamicResource Brush.2EFFFFFF}"
                                    CornerRadius="10"
                                    Opacity="0" />
                            <Border x:Name="TopSeparator"
                                    Height="1"
                                    Margin="44,0,30,0"
                                    VerticalAlignment="Top"
                                    Background="{DynamicResource Brush.14FFFFFF}" />
                            <Border x:Name="BottomSeparator"
                                    Height="1"
                                    Margin="44,0,30,0"
                                    VerticalAlignment="Bottom"
                                    Background="{DynamicResource Brush.14FFFFFF}"
                                    Opacity="0" />
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="PressedBackground" Property="Opacity" Value="1" />
                            <Setter TargetName="TopSeparator" Property="Opacity" Value="0" />
                        </Trigger>
                        <Trigger Property="behaviors:OptionHoverBehavior.IsActive" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBackground"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBackground"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.22">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                            <Setter TargetName="TopSeparator" Property="Opacity" Value="0" />
                        </Trigger>
                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type controls:ListPageItemButton}}}" Value="True">
                            <Setter TargetName="SelectedBackground" Property="Opacity" Value="1" />
                            <Setter TargetName="TopSeparator" Property="Opacity" Value="0" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsFirstVisible, RelativeSource={RelativeSource AncestorType={x:Type controls:ListPageItemButton}}}" Value="True">
                            <Setter TargetName="TopSeparator" Property="Opacity" Value="0" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsLastVisible, RelativeSource={RelativeSource AncestorType={x:Type controls:ListPageItemButton}}}" Value="True">
                            <Setter TargetName="BottomSeparator" Property="Opacity" Value="0" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsPreviousItemHighlighted, RelativeSource={RelativeSource AncestorType={x:Type controls:ListPageItemButton}}}" Value="True">
                            <Setter TargetName="TopSeparator" Property="Opacity" Value="0" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DownloadVersionListButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource ListPageItemButtonStyle}" />

    <Style x:Key="ListPagePrimaryFloatingButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="116" />
        <Setter Property="Height" Value="42" />
        <Setter Property="Margin" Value="0,0,30,28" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Bottom" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.FFFFFF}" />
        <Setter Property="Background" Value="{DynamicResource Brush.0891FE}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Panel.ZIndex" Value="4" />
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            CornerRadius="9">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18"
                                              Color="{DynamicResource Color.0891FE}"
                                              Opacity="0.32"
                                              ShadowDepth="0" />
                        </Border.Effect>
                        <Grid>
                            <Border x:Name="BaseBackground"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="9" />
                            <Border x:Name="HoverBackground"
                                    Background="{DynamicResource Brush.047EDC}"
                                    CornerRadius="9"
                                    Opacity="0" />
                            <Border x:Name="PressedBackground"
                                    Background="{DynamicResource Brush.036FC2}"
                                    CornerRadius="9"
                                    Opacity="0" />
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="Mouse.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverBackground"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="1"
                                                     Duration="0:0:0.16">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Mouse.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverBackground"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0"
                                                     Duration="0:0:0.22">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="PressedBackground" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource Brush.BFFFFFFF}" />
                            <Setter Property="Cursor" Value="Arrow" />
                            <Setter TargetName="Root" Property="Effect" Value="{x:Null}" />
                            <Setter TargetName="BaseBackground" Property="Background" Value="{DynamicResource Brush.5A5A5A}" />
                            <Setter TargetName="HoverBackground" Property="Opacity" Value="0" />
                            <Setter TargetName="PressedBackground" Property="Opacity" Value="0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DownloadNextStepButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource ListPagePrimaryFloatingButtonStyle}">
        <Setter Property="Width" Value="100" />
        <Setter Property="Height" Value="36" />
        <Setter Property="FontSize" Value="14" />
    </Style>

