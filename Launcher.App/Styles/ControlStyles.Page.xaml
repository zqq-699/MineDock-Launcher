<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
                    xmlns:controls="clr-namespace:Launcher.App.Controls"
                    xmlns:behaviors="clr-namespace:Launcher.App.Behaviors"
                    xmlns:converters="clr-namespace:Launcher.App.Converters"
                    xmlns:res="clr-namespace:Launcher.App.Resources">
    <sys:Double x:Key="DetailPageContentMaxWidth">520</sys:Double>

    <Style x:Key="PageTitleTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Brush.F4F4F4}" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="PageStatusTextStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,12,0,0" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.B8FFFFFF}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="PageEmptyStateTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Brush.B8FFFFFF}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
    </Style>

    <Style x:Key="DownloadOverlayEmptyStateTextStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource PageEmptyStateTextStyle}">
        <Setter Property="Margin" Value="0,122,0,0" />
        <Setter Property="Visibility" Value="Collapsed" />
    </Style>

    <Style x:Key="DownloadOverlayErrorTextStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource DownloadOverlayEmptyStateTextStyle}">
        <Setter Property="Foreground" Value="{DynamicResource Brush.FFFF8D8D}" />
    </Style>

    <Style x:Key="DownloadInstanceOptionLabelTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Brush.AFFFFFFF}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="DownloadInstanceOptionWarningTextStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,8,0,0" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.FFFFC56D}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Visibility" Value="Collapsed" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding HasInstanceNameDuplicateMessage}" Value="True">
                <Setter Property="Visibility" Value="Visible" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="DownloadLoaderOptionTitleTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Brush.F4F4F4}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="DownloadLoaderOptionSubtitleTextStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,5,0,0" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.AFFFFFFF}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="HomeAvatarContainerStyle" TargetType="Border">
        <Setter Property="Width" Value="86" />
        <Setter Property="Height" Value="86" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="ClipToBounds" Value="False" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding HasSelectedAccount}" Value="True">
                <Setter Property="IsHitTestVisible" Value="True" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="HomeDefaultAvatarGlyphStyle" TargetType="TextBlock">
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="20"
                                  Color="{DynamicResource Color.000000}"
                                  Direction="270"
                                  Opacity="0.62"
                                  ShadowDepth="8" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HomeAccountHintTextStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,4,0,0" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.A8FFFFFF}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextAlignment" Value="Center" />
    </Style>

    <Style x:Key="HomeAccountNameTextStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,14,0,0" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.F4FFFFFF}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="MaxWidth" Value="260" />
    </Style>

    <Style x:Key="HomeVersionNameTextStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,12,0,0" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.F4FFFFFF}" />
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextAlignment" Value="Center" />
    </Style>

    <Style x:Key="HomeLaunchInstanceNameTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Brush.F4FFFFFF}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="18" />
    </Style>

    <Style x:Key="HomeLaunchInstanceSubtitleTextStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,2,0,0" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.9FFFFFFF}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="LineHeight" Value="14" />
    </Style>

    <Style x:Key="HomeLaunchInstanceEmptyTextStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="24,0,24,0" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.A8FFFFFF}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TranslateTransform Y="-18" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HomeChangeVersionButtonStyle" TargetType="Button">
        <Setter Property="Margin" Value="0,2,0,0" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.9FFFFFFF}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="Transparent">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource Brush.F0FFFFFF}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource Brush.FFFFFF}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HomeLaunchButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="190" />
        <Setter Property="Height" Value="50" />
        <Setter Property="Margin" Value="0,22,0,0" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.FFFFFF}" />
        <Setter Property="Background" Value="{DynamicResource Brush.0891FE}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            CornerRadius="9">
                        <Border.Effect>
                            <DropShadowEffect x:Name="RootGlow"
                                              BlurRadius="18"
                                              Color="{DynamicResource Color.0891FE}"
                                              Opacity="0.28"
                                              ShadowDepth="0" />
                        </Border.Effect>
                        <Grid>
                            <Grid RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <ScaleTransform x:Name="BackgroundScale"
                                                    ScaleX="1"
                                                    ScaleY="1" />
                                </Grid.RenderTransform>
                                <Border x:Name="BaseBackground"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="9" />
                                <Border x:Name="HoverBackground"
                                        Background="{DynamicResource Brush.047EDC}"
                                        CornerRadius="9"
                                        Opacity="0" />
                                <Border x:Name="PressedBackground"
                                        Background="{DynamicResource Brush.036FC2}"
                                        CornerRadius="9"
                                        Opacity="0" />
                            </Grid>
                            <ContentPresenter x:Name="ButtonContentPresenter"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              SnapsToDevicePixels="True"
                                              TextOptions.TextFormattingMode="Display"
                                              TextOptions.TextRenderingMode="Auto">
                                <ContentPresenter.LayoutTransform>
                                    <ScaleTransform x:Name="ContentScale"
                                                    ScaleX="1"
                                                    ScaleY="1" />
                                </ContentPresenter.LayoutTransform>
                            </ContentPresenter>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="Mouse.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverBackground"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="1"
                                                     Duration="0:0:0.16">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="RootGlow"
                                                     Storyboard.TargetProperty="BlurRadius"
                                                     To="38"
                                                     Duration="0:0:0.18">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="RootGlow"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.62"
                                                     Duration="0:0:0.18">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="BackgroundScale"
                                                     Storyboard.TargetProperty="ScaleX"
                                                     To="1.03"
                                                     Duration="0:0:0.18">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="BackgroundScale"
                                                     Storyboard.TargetProperty="ScaleY"
                                                     To="1.03"
                                                     Duration="0:0:0.18">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="ContentScale"
                                                     Storyboard.TargetProperty="ScaleX"
                                                     To="1.03"
                                                     Duration="0:0:0.18">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="ContentScale"
                                                     Storyboard.TargetProperty="ScaleY"
                                                     To="1.03"
                                                     Duration="0:0:0.18">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Mouse.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverBackground"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0"
                                                     Duration="0:0:0.22">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="RootGlow"
                                                     Storyboard.TargetProperty="BlurRadius"
                                                     To="18"
                                                     Duration="0:0:0.24">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="RootGlow"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.28"
                                                     Duration="0:0:0.24">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="BackgroundScale"
                                                     Storyboard.TargetProperty="ScaleX"
                                                     To="1"
                                                     Duration="0:0:0.24">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="BackgroundScale"
                                                     Storyboard.TargetProperty="ScaleY"
                                                     To="1"
                                                     Duration="0:0:0.24">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="ContentScale"
                                                     Storyboard.TargetProperty="ScaleX"
                                                     To="1"
                                                     Duration="0:0:0.24">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="ContentScale"
                                                     Storyboard.TargetProperty="ScaleY"
                                                     To="1"
                                                     Duration="0:0:0.24">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="PressedBackground" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource Brush.BFFFFFFF}" />
                            <Setter Property="Cursor" Value="Arrow" />
                            <Setter TargetName="Root" Property="Effect" Value="{x:Null}" />
                            <Setter TargetName="BaseBackground" Property="Background" Value="{DynamicResource Brush.5A5A5A}" />
                            <Setter TargetName="HoverBackground" Property="Opacity" Value="0" />
                            <Setter TargetName="PressedBackground" Property="Opacity" Value="0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SectionFieldSurfaceStyle" TargetType="Border">
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="Background" Value="{DynamicResource Brush.Card.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Card.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style x:Key="ReadOnlyFieldSurfaceStyle"
           TargetType="Border"
           BasedOn="{StaticResource SectionFieldSurfaceStyle}">
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="14,7" />
        <Setter Property="Background" Value="{DynamicResource Brush.Field.ReadOnly.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Field.ReadOnly.Border}" />
    </Style>

    <Style x:Key="ReadOnlyFieldTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Brush.CFFFFFFF}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

</ResourceDictionary>

