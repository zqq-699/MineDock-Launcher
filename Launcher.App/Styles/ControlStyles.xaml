<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
                    xmlns:controls="clr-namespace:Launcher.App.Controls">
    <SolidColorBrush x:Key="MenuButtonSelectedBackgroundBrush" Color="#30808080" />
    <SolidColorBrush x:Key="MenuButtonHoverBackgroundBrush" Color="#30606060" />

    <Style x:Key="SecondaryMenuPanelStyle" TargetType="Border">
        <Setter Property="Width" Value="224" />
        <Setter Property="Margin" Value="24,88,0,24" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Background" Value="#5A4A4A4A" />
        <Setter Property="BorderBrush" Value="#24FFFFFF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="controls:RoundedClip.Radius" Value="14" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="18"
                                  Color="#000000"
                                  Opacity="0.26"
                                  ShadowDepth="0" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryMenuHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="34,46,0,0" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Foreground" Value="#E8FFFFFF" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="SlimScrollRepeatButtonStyle" TargetType="RepeatButton">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SlimScrollThumbStyle" TargetType="Thumb">
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Background" Value="#5CFFFFFF" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="Root"
                            Width="5"
                            Margin="1,2"
                            HorizontalAlignment="Center"
                            Background="{TemplateBinding Background}"
                            CornerRadius="3" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#84FFFFFF" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#A8FFFFFF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SlimVerticalScrollBarStyle" TargetType="ScrollBar">
        <Setter Property="Width" Value="8" />
        <Setter Property="MinWidth" Value="8" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track"
                               IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                              Style="{StaticResource SlimScrollRepeatButtonStyle}" />
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource SlimScrollThumbStyle}" />
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                              Style="{StaticResource SlimScrollRepeatButtonStyle}" />
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryMenuScrollBarStyle"
           TargetType="ScrollBar"
           BasedOn="{StaticResource SlimVerticalScrollBarStyle}">
        <Setter Property="Margin" Value="0,10,5,14" />
        <Setter Property="Opacity" Value="0" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ScrollViewer}}" Value="True">
                <Setter Property="Opacity" Value="1" />
                <Setter Property="IsHitTestVisible" Value="True" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SecondaryMenuScrollViewerStyle" TargetType="ScrollViewer">
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ClipToBounds" Value="True" />
        <Style.Resources>
            <Style TargetType="ScrollBar" BasedOn="{StaticResource SecondaryMenuScrollBarStyle}" />
        </Style.Resources>
    </Style>

    <Style x:Key="MainContentScrollBarStyle"
           TargetType="ScrollBar"
           BasedOn="{StaticResource SlimVerticalScrollBarStyle}">
        <Setter Property="Margin" Value="0,8,2,8" />
        <Setter Property="Opacity" Value="0" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ScrollViewer}}" Value="True">
                <Setter Property="Opacity" Value="1" />
                <Setter Property="IsHitTestVisible" Value="True" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="MainContentScrollViewerStyle" TargetType="ScrollViewer">
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Style.Resources>
            <Style TargetType="ScrollBar" BasedOn="{StaticResource MainContentScrollBarStyle}" />
        </Style.Resources>
    </Style>

    <Style x:Key="SecondaryMenuItemsPanelStyle" TargetType="StackPanel">
        <Setter Property="Margin" Value="14,18,14,0" />
    </Style>

    <Style x:Key="SecondaryMenuBottomSpacerStyle" TargetType="Border">
        <Setter Property="Height" Value="18" />
        <Setter Property="IsHitTestVisible" Value="False" />
    </Style>

    <Style x:Key="SecondaryMenuButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="40" />
        <Setter Property="Margin" Value="0,0,0,6" />
        <Setter Property="Padding" Value="12,4" />
        <Setter Property="Foreground" Value="#F2F2F2" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            CornerRadius="10">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="10" />
                            <Border x:Name="SelectedBackground"
                                    Background="#3D3D3D"
                                    CornerRadius="10"
                                    Opacity="0" />
                            <Border x:Name="HoverBackground"
                                    Background="#22FFFFFF"
                                    CornerRadius="10"
                                    Opacity="0" />
                            <Border x:Name="PressedBackground"
                                    Background="#34FFFFFF"
                                    CornerRadius="10"
                                    Opacity="0" />
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="Mouse.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverBackground"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="1"
                                                     Duration="0:0:0.16">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Mouse.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverBackground"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0"
                                                     Duration="0:0:0.22">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="PressedBackground" Property="Opacity" Value="1" />
                        </Trigger>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter TargetName="SelectedBackground" Property="Opacity" Value="1" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryMenuDeleteButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="30" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Foreground" Value="#FF2F2F" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            CornerRadius="7">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="7" />
                            <Border x:Name="HoverBackground"
                                    Background="#18FF4A4A"
                                    CornerRadius="7"
                                    Opacity="0" />
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="Mouse.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverBackground"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="1"
                                                     Duration="0:0:0.16">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Mouse.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverBackground"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0"
                                                     Duration="0:0:0.22">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="#FF4A4A" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Foreground" Value="#E00000" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="InlineIconButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Foreground" Value="#DFFFFFFF" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            CornerRadius="8">
                        <Grid>
                            <Border x:Name="HoverBackground"
                                    Background="#22FFFFFF"
                                    CornerRadius="8"
                                    Opacity="0" />
                            <Border x:Name="PressedBackground"
                                    Background="#34FFFFFF"
                                    CornerRadius="8"
                                    Opacity="0" />
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="Mouse.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverBackground"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="1"
                                                     Duration="0:0:0.16">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Mouse.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverBackground"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0"
                                                     Duration="0:0:0.22">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="PressedBackground" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Cursor" Value="Arrow" />
                            <Setter Property="Foreground" Value="#7DFFB2" />
                            <Setter TargetName="HoverBackground" Property="Opacity" Value="0" />
                            <Setter TargetName="PressedBackground" Property="Opacity" Value="0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DialogOverlayStyle" TargetType="Grid">
        <Setter Property="Grid.ColumnSpan" Value="2" />
        <Setter Property="Grid.RowSpan" Value="2" />
        <Setter Property="Background" Value="#99000000" />
        <Setter Property="Opacity" Value="0" />
        <Setter Property="Visibility" Value="Collapsed" />
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
    </Style>

    <Style x:Key="DialogShadowStyle" TargetType="Border">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Background" Value="#01000000" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="28"
                                  Color="#000000"
                                  Opacity="0.34"
                                  ShadowDepth="0" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DialogSurfaceStyle" TargetType="Border">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="#24FFFFFF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="controls:RoundedClip.Radius" Value="16" />
    </Style>

    <Style x:Key="DialogBlurLayerStyle" TargetType="Border">
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Background">
            <Setter.Value>
                <ImageBrush Stretch="Fill" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DialogContentGridStyle" TargetType="Grid">
        <Setter Property="Margin" Value="24" />
    </Style>

    <Style x:Key="DialogTitleTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#F4F4F4" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="DialogSubtitleTextStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,8,0,0" />
        <Setter Property="Foreground" Value="#AFFFFFFF" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="DialogBodyTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#CFFFFFFF" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="DialogFieldLabelTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#F4F4F4" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="DialogValidationTextStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="2,8,0,0" />
        <Setter Property="Foreground" Value="#FFFF8A8A" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="DialogChoiceItemStyle" TargetType="ListBoxItem">
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Foreground" Value="#F4F4F4" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Root"
                            CornerRadius="10">
                        <Grid>
                            <Border Background="#12FFFFFF"
                                    CornerRadius="10" />
                            <Border x:Name="SelectedBackground"
                                    Background="#3D3D3D"
                                    CornerRadius="10"
                                    Opacity="0" />
                            <Border x:Name="HoverBackground"
                                    Background="#20FFFFFF"
                                    CornerRadius="10"
                                    Opacity="0" />
                            <ContentPresenter Margin="14"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="Mouse.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverBackground"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="1"
                                                     Duration="0:0:0.16">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Mouse.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverBackground"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0"
                                                     Duration="0:0:0.22">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="SelectedBackground" Property="Opacity" Value="1" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DialogChoiceListStyle" TargetType="ListBox">
        <Setter Property="ItemContainerStyle" Value="{StaticResource DialogChoiceItemStyle}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Margin" Value="0,22,0,18" />
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
    </Style>

    <Style x:Key="DialogFormPanelStyle" TargetType="StackPanel">
        <Setter Property="Margin" Value="0,24,0,26" />
    </Style>

    <Style x:Key="DialogFooterStyle" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal" />
        <Setter Property="HorizontalAlignment" Value="Right" />
    </Style>

    <Thickness x:Key="DialogTrailingButtonMargin">10,0,0,0</Thickness>

    <Style x:Key="DialogTrailingButtonStyle" TargetType="Button">
        <Setter Property="Margin" Value="10,0,0,0" />
    </Style>

    <Style x:Key="DialogButtonStyle" TargetType="Button">
        <Setter Property="MinWidth" Value="86" />
        <Setter Property="Height" Value="34" />
        <Setter Property="Padding" Value="18,0" />
        <Setter Property="Foreground" Value="#F4F4F4" />
        <Setter Property="Background" Value="#20FFFFFF" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            CornerRadius="8">
                        <Grid>
                            <Border x:Name="BaseBackground"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8" />
                            <Border x:Name="HoverBackground"
                                    Background="#32FFFFFF"
                                    CornerRadius="8"
                                    Opacity="0" />
                            <Border x:Name="PressedBackground"
                                    Background="#50808080"
                                    CornerRadius="8"
                                    Opacity="0" />
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="Mouse.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverBackground"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="1"
                                                     Duration="0:0:0.16">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Mouse.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverBackground"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0"
                                                     Duration="0:0:0.22">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="PressedBackground" Property="Opacity" Value="1" />
