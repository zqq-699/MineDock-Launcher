    </Style>

    <Style x:Key="HomeChangeVersionButtonStyle" TargetType="Button">
        <Setter Property="Margin" Value="0,2,0,0" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="Foreground" Value="#9FFFFFFF" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="Transparent">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="#F0FFFFFF" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Foreground" Value="#FFFFFF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HomeLaunchButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="190" />
        <Setter Property="Height" Value="50" />
        <Setter Property="Margin" Value="0,22,0,0" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="Background" Value="#0891FE" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            CornerRadius="9">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18"
                                              Color="#0891FE"
                                              Opacity="0.28"
                                              ShadowDepth="0" />
                        </Border.Effect>
                        <Grid>
                            <Border x:Name="BaseBackground"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="9" />
                            <Border x:Name="HoverBackground"
                                    Background="#047EDC"
                                    CornerRadius="9"
                                    Opacity="0" />
                            <Border x:Name="PressedBackground"
                                    Background="#036FC2"
                                    CornerRadius="9"
                                    Opacity="0" />
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="Mouse.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverBackground"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="1"
                                                     Duration="0:0:0.16">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Mouse.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverBackground"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0"
                                                     Duration="0:0:0.22">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="PressedBackground" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#BFFFFFFF" />
                            <Setter Property="Cursor" Value="Arrow" />
                            <Setter TargetName="Root" Property="Effect" Value="{x:Null}" />
                            <Setter TargetName="BaseBackground" Property="Background" Value="#5A5A5A" />
                            <Setter TargetName="HoverBackground" Property="Opacity" Value="0" />
                            <Setter TargetName="PressedBackground" Property="Opacity" Value="0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SectionFieldSurfaceStyle" TargetType="Border">
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="Background" Value="#18FFFFFF" />
        <Setter Property="BorderBrush" Value="#16FFFFFF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style x:Key="SecondaryMenuPanelStyle" TargetType="Border">
        <Setter Property="Width" Value="224" />
        <Setter Property="Margin" Value="24,24,0,24" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Background" Value="#5A4A4A4A" />
        <Setter Property="BorderBrush" Value="#24FFFFFF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="controls:RoundedClip.Radius" Value="14" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="18"
                                  Color="#000000"
                                  Opacity="0.26"
                                  ShadowDepth="0" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryMenuHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="22,18,22,8" />
        <Setter Property="Foreground" Value="#E8FFFFFF" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="SecondaryMenuHeaderOverlayStyle" TargetType="Border">
        <Setter Property="Height" Value="74" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Panel.ZIndex" Value="2" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="CornerRadius" Value="14,14,0,0" />
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#D8282828" Offset="0" />
                    <GradientStop Color="#C2282828" Offset="0.72" />
                    <GradientStop Color="#00282828" Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryMenuHeaderSpacerStyle" TargetType="Border">
        <Setter Property="Height" Value="70" />
        <Setter Property="IsHitTestVisible" Value="False" />
    </Style>

    <Style x:Key="SlimScrollRepeatButtonStyle" TargetType="RepeatButton">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SlimScrollThumbStyle" TargetType="Thumb">
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Background" Value="#5CFFFFFF" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="Root"
                            Width="5"
                            Margin="1,2"
                            HorizontalAlignment="Center"
                            Background="{TemplateBinding Background}"
                            CornerRadius="2.5" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#84FFFFFF" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#A8FFFFFF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SlimVerticalScrollBarStyle" TargetType="ScrollBar">
        <Setter Property="Width" Value="8" />
        <Setter Property="MinWidth" Value="8" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track"
                               IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                              Style="{StaticResource SlimScrollRepeatButtonStyle}" />
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource SlimScrollThumbStyle}" />
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                              Style="{StaticResource SlimScrollRepeatButtonStyle}" />
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="OverlayScrollViewerStyle" TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="CanContentScroll" Value="False" />
        <Setter Property="PanningMode" Value="VerticalOnly" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid Background="{TemplateBinding Background}"
                          ClipToBounds="{TemplateBinding ClipToBounds}"
                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                        <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                Margin="{TemplateBinding Padding}"
                                                CanContentScroll="{TemplateBinding CanContentScroll}" />

                        <ScrollBar x:Name="PART_VerticalScrollBar"
                                   Panel.ZIndex="1"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Stretch"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   Value="{Binding VerticalOffset, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}">
                            <ScrollBar.ViewportSize>
                                <MultiBinding Converter="{StaticResource MinimumScrollThumbViewportConverter}"
                                              ConverterParameter="58">
                                    <Binding Path="ViewportHeight" RelativeSource="{RelativeSource TemplatedParent}" />
                                    <Binding Path="ScrollableHeight" RelativeSource="{RelativeSource TemplatedParent}" />
                                    <Binding Path="ActualHeight" RelativeSource="{RelativeSource Self}" />
                                </MultiBinding>
                            </ScrollBar.ViewportSize>
                        </ScrollBar>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryMenuScrollBarStyle"
           TargetType="ScrollBar"
           BasedOn="{StaticResource SlimVerticalScrollBarStyle}">
        <Setter Property="Margin" Value="0,74,5,14" />
        <Setter Property="Opacity" Value="0" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ScrollViewer}}" Value="True">
                <Setter Property="Opacity" Value="1" />
                <Setter Property="IsHitTestVisible" Value="True" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SecondaryMenuScrollViewerStyle"
           TargetType="ScrollViewer"
           BasedOn="{StaticResource OverlayScrollViewerStyle}">
        <Setter Property="controls:SmoothScrollBehavior.IsEnabled" Value="True" />
        <Setter Property="controls:SmoothScrollBehavior.ScrollAmount" Value="72" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ClipToBounds" Value="True" />
        <Style.Resources>
            <Style TargetType="ScrollBar" BasedOn="{StaticResource SecondaryMenuScrollBarStyle}" />
        </Style.Resources>
    </Style>

    <Style x:Key="MainContentScrollBarStyle"
           TargetType="ScrollBar"
           BasedOn="{StaticResource SlimVerticalScrollBarStyle}">
        <Setter Property="Margin" Value="0,8,2,8" />
        <Setter Property="Opacity" Value="0" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ScrollViewer}}" Value="True">
                <Setter Property="Opacity" Value="1" />
                <Setter Property="IsHitTestVisible" Value="True" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="MainContentScrollViewerStyle"
           TargetType="ScrollViewer"
           BasedOn="{StaticResource OverlayScrollViewerStyle}">
        <Setter Property="controls:SmoothScrollBehavior.IsEnabled" Value="True" />
        <Setter Property="controls:SmoothScrollBehavior.ScrollAmount" Value="92" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ClipToBounds" Value="True" />
        <Style.Resources>
            <Style TargetType="ScrollBar" BasedOn="{StaticResource MainContentScrollBarStyle}" />
        </Style.Resources>
    </Style>

    <Style x:Key="ListPageHeaderOverlayStyle" TargetType="Border">
        <Setter Property="Height" Value="132" />
        <Setter Property="VerticalAlignment" Value="Top" />
