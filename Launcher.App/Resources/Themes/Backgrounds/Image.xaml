<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <!--
      Independent style layer for image background mode. It inherits every shared font,
      dimension, and control style. Future image-mode overrides belong in this dictionary
      under the same resource keys so that other background modes remain unchanged.
    -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/BlockHelm_Launcher_x64;component/Resources/Themes/Shared.xaml" />
        <ResourceDictionary Source="pack://application:,,,/BlockHelm_Launcher_x64;component/Styles/ControlStyles.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <SolidColorBrush x:Key="Brush.LauncherBackground.Image.DimOverlay" Color="#FF000000" />
    <sys:Double x:Key="Opacity.LauncherBackground.Image.NonHomeDim">0.35</sys:Double>
    <sys:Boolean x:Key="Is.SecondaryMenu.BackdropBlur.Enabled">True</sys:Boolean>
</ResourceDictionary>
