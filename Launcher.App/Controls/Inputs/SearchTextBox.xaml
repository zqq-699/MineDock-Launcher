<UserControl x:Class="Launcher.App.Controls.SearchTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Launcher.App.Controls"
             xmlns:res="clr-namespace:Launcher.App.Resources"
             x:Name="Root"
             Height="{StaticResource LauncherCompactControlHeight}"
             Focusable="False">
    <Grid>
        <TextBox x:Name="PART_TextBox"
                 Padding="32,0,7,0"
                 Tag="{Binding Tag, ElementName=Root}"
                 Text="{Binding Text, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource LauncherDialogTextBoxStyle}" />

        <controls:SvgIcon Width="15"
                          Height="15"
                          Margin="10,0,0,0"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center"
                          Foreground="{DynamicResource Brush.70FFFFFF}"
                          IconKey="general/general_search"
                          IsHitTestVisible="False" />

        <TextBlock Margin="32,0,0,0"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   FontSize="13"
                   Foreground="{DynamicResource Brush.70FFFFFF}"
                   IsHitTestVisible="False"
                   Text="{x:Static res:Strings.Search_Placeholder}">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding Text, ElementName=PART_TextBox}" Value="" />
                                <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=PART_TextBox}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </Grid>
</UserControl>
