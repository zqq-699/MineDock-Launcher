<UserControl x:Class="Launcher.App.Controls.ListPageItemButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:Launcher.App.Behaviors"
             xmlns:controls="clr-namespace:Launcher.App.Controls"
             x:Name="Root"
             MouseEnter="Root_MouseEnter"
             MouseLeave="Root_MouseLeave"
             Focusable="False">
    <UserControl.Style>
        <Style TargetType="{x:Type controls:ListPageItemButton}">
            <Setter Property="TitleForeground" Value="{DynamicResource Brush.F2F2F2}" />
            <Setter Property="SubtitleForeground" Value="{DynamicResource Brush.Text.Muted}" />
            <Setter Property="TrailingForeground" Value="{DynamicResource Brush.Text.Subtle}" />
            <Setter Property="IconOverlayForeground" Value="{DynamicResource Brush.Text.Danger}" />
        </Style>
    </UserControl.Style>

    <Grid x:Name="AnimatedRoot">
        <Button x:Name="PART_Button"
                Margin="{Binding ItemMargin, ElementName=Root}"
                Tag="{Binding ElementName=Root}"
                RenderTransformOrigin="0.5,0.5"
                Style="{StaticResource ListPageItemButtonStyle}"
                Command="{Binding Command, ElementName=Root}"
                CommandParameter="{Binding CommandParameter, ElementName=Root}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{Binding IconColumnWidth, ElementName=Root}" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Width="{Binding IconWidth, ElementName=Root}"
                      Height="{Binding IconHeight, ElementName=Root}"
                      Margin="{Binding IconMargin, ElementName=Root}"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Center"
                      IsHitTestVisible="False">
                    <Border Background="Transparent"
                            CornerRadius="{StaticResource LauncherCornerRadiusSmall}"
                            ClipToBounds="True"
                            Opacity="{Binding IconOpacity, ElementName=Root}"
                            behaviors:RoundedClip.Radius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ResolvedIconSource, ElementName=Root}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <Image HorizontalAlignment="Stretch"
                               VerticalAlignment="Stretch"
                               Stretch="UniformToFill"
                               RenderOptions.BitmapScalingMode="{Binding IconScalingMode, ElementName=Root}"
                               SnapsToDevicePixels="True"
                               Source="{Binding ResolvedIconSource, ElementName=Root}" />
                    </Border>

                    <controls:SvgIcon Width="{Binding IconWidth, ElementName=Root}"
                                      Height="{Binding IconHeight, ElementName=Root}"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Center"
                                      IconKey="{Binding IconKey, ElementName=Root}"
                                      Foreground="{DynamicResource Brush.DFFFFFFF}"
                                      Opacity="{Binding IconOpacity, ElementName=Root}">
                        <controls:SvgIcon.Style>
                            <Style TargetType="{x:Type controls:SvgIcon}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IconKey, ElementName=Root}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IconKey, ElementName=Root}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </controls:SvgIcon.Style>
                    </controls:SvgIcon>

                    <controls:SvgIcon Width="16"
                                      Height="16"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      IconKey="{Binding IconOverlayKey, ElementName=Root}"
                                      Foreground="{Binding IconOverlayForeground, ElementName=Root}">
                        <controls:SvgIcon.Style>
                            <Style TargetType="{x:Type controls:SvgIcon}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IconOverlayKey, ElementName=Root}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IconOverlayKey, ElementName=Root}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </controls:SvgIcon.Style>
                    </controls:SvgIcon>
                </Grid>

                <Grid Grid.Column="1"
                      Margin="{Binding TextMargin, ElementName=Root}"
                      VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="{Binding Title, ElementName=Root}"
                               Foreground="{Binding TitleForeground, ElementName=Root}"
                               FontSize="{Binding TitleFontSize, ElementName=Root}"
                               FontWeight="{Binding TitleFontWeight, ElementName=Root}"
                               TextTrimming="CharacterEllipsis" />

                    <TextBlock Grid.Row="1"
                               Margin="0,2,0,0"
                               Text="{Binding Subtitle, ElementName=Root}"
                               Foreground="{Binding SubtitleForeground, ElementName=Root}"
                               FontSize="{Binding SubtitleFontSize, ElementName=Root}"
                               FontWeight="Normal"
                               TextTrimming="CharacterEllipsis">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Subtitle, ElementName=Root}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Subtitle, ElementName=Root}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <TextBlock x:Name="TrailingTextBlock"
                           Grid.Column="2"
                           Margin="{Binding TrailingMargin, ElementName=Root}"
                           Text="{Binding TrailingText, ElementName=Root}"
                           Foreground="{Binding TrailingForeground, ElementName=Root}"
                           FontSize="{Binding TrailingFontSize, ElementName=Root}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right" />
            </Grid>
        </Button>

        <ContentPresenter x:Name="TrailingContentPresenter"
                          Margin="{Binding TrailingMargin, ElementName=Root}"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          Content="{Binding TrailingContent, ElementName=Root}"
                          RenderTransformOrigin="0.5,0.5"
                          Opacity="0">
            <ContentPresenter.Style>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Visibility" Value="Visible" />
                    <Setter Property="IsHitTestVisible" Value="False" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding TrailingContent, ElementName=Root}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=Root}" Value="True">
                            <Setter Property="IsHitTestVisible" Value="True" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ContentPresenter.Style>
        </ContentPresenter>
    </Grid>

</UserControl>

