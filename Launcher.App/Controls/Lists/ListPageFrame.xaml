<UserControl x:Class="Launcher.App.Controls.ListPageFrame"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:Launcher.App.Behaviors"
             x:Name="Root"
             Focusable="False">
    <Grid>
        <ContentPresenter Content="{Binding OverlayContent, ElementName=Root}" />

        <Grid x:Name="PART_ListLayer"
              behaviors:VerticalEdgeOpacityMask.IsEnabled="{Binding IsListVisible, ElementName=Root}">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="behaviors:VerticalEdgeOpacityMask.TopFadeLength" Value="140" />
                    <Setter Property="behaviors:VerticalEdgeOpacityMask.TopIntermediateLength" Value="100" />
                    <Setter Property="behaviors:VerticalEdgeOpacityMask.TopIntermediateOpacity" Value="0.1" />
                    <Setter Property="behaviors:VerticalEdgeOpacityMask.BottomFadeLength" Value="72" />
                    <Setter Property="behaviors:VerticalEdgeOpacityMask.MinimumOpacity" Value="0" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSearchFilterVisible, ElementName=Root}" Value="True">
                            <Setter Property="behaviors:VerticalEdgeOpacityMask.TopFadeLength" Value="172" />
                            <Setter Property="behaviors:VerticalEdgeOpacityMask.TopIntermediateLength" Value="132" />
                        </DataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsSearchToolbarVisible, ElementName=Root}" Value="True" />
                                <Condition Binding="{Binding IsSearchFilterVisible, ElementName=Root}" Value="True" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="behaviors:VerticalEdgeOpacityMask.TopFadeLength" Value="196" />
                            <Setter Property="behaviors:VerticalEdgeOpacityMask.TopIntermediateLength" Value="156" />
                        </MultiDataTrigger>
                        <DataTrigger Binding="{Binding IsSearchVisible, ElementName=Root}" Value="False">
                            <Setter Property="behaviors:VerticalEdgeOpacityMask.TopFadeLength" Value="70" />
                            <Setter Property="behaviors:VerticalEdgeOpacityMask.TopIntermediateLength" Value="30" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid x:Name="PART_DirectListHost"
                  SnapsToDevicePixels="True">
                <Grid x:Name="PART_ListVisualSource"
                      Background="Transparent">
                    <ScrollViewer x:Name="PART_ScrollViewer">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer" BasedOn="{StaticResource ListPageScrollViewerStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsListVisible, ElementName=Root}" Value="True" />
                                            <Condition Binding="{Binding UseFrameScrollViewer, ElementName=Root}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>

                        <StackPanel>
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource ListPageHeaderSpacerStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSearchFilterVisible, ElementName=Root}" Value="True">
                                                <Setter Property="Height" Value="148" />
                                            </DataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsSearchToolbarVisible, ElementName=Root}" Value="True" />
                                                    <Condition Binding="{Binding IsSearchFilterVisible, ElementName=Root}" Value="True" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Height" Value="172" />
                                            </MultiDataTrigger>
                                            <DataTrigger Binding="{Binding IsSearchVisible, ElementName=Root}" Value="False">
                                                <Setter Property="Height" Value="70" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <ContentPresenter>
                                <ContentPresenter.Style>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Content" Value="{Binding ListContent, ElementName=Root}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UseFrameScrollViewer, ElementName=Root}" Value="False">
                                                <Setter Property="Content" Value="{x:Null}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ContentPresenter.Style>
                            </ContentPresenter>
                            <Border Style="{StaticResource ListPageBottomSpacerStyle}" />
                        </StackPanel>
                    </ScrollViewer>

                    <ContentPresenter>
                        <ContentPresenter.Style>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Content" Value="{x:Null}" />
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsListVisible, ElementName=Root}" Value="True" />
                                            <Condition Binding="{Binding UseFrameScrollViewer, ElementName=Root}" Value="False" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Content" Value="{Binding ListContent, ElementName=Root}" />
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentPresenter.Style>
                    </ContentPresenter>
                </Grid>
            </Grid>

            <Grid x:Name="PART_BlurBandViewport"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Top"
                  ClipToBounds="True"
                  IsHitTestVisible="False"
                  SnapsToDevicePixels="True"
                  Visibility="Collapsed">
                <Grid x:Name="PART_BlurBandUpscaleHost"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top"
                      RenderOptions.BitmapScalingMode="Linear">
                    <Grid.RenderTransform>
                        <ScaleTransform x:Name="PART_BlurBandUpscaleTransform"
                                        ScaleX="1"
                                        ScaleY="1" />
                    </Grid.RenderTransform>

                    <Grid x:Name="PART_BlurBandVerticalHost"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top">
                        <Border x:Name="PART_BlurBandHorizontalHost"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top">
                            <Border.Background>
                                <VisualBrush x:Name="PART_BlurBandBrush"
                                             Viewbox="0,0,1,1"
                                             ViewboxUnits="Absolute"
                                             Viewport="0,0,1,1"
                                             ViewportUnits="RelativeToBoundingBox"
                                             Stretch="Fill"
                                             TileMode="None" />
                            </Border.Background>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <Border x:Name="PART_HeaderOverlay">
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource ListPageHeaderOverlayStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSearchFilterVisible, ElementName=Root}" Value="True">
                            <Setter Property="Height" Value="148" />
                        </DataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsSearchToolbarVisible, ElementName=Root}" Value="True" />
                                <Condition Binding="{Binding IsSearchFilterVisible, ElementName=Root}" Value="True" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Height" Value="172" />
                        </MultiDataTrigger>
                        <DataTrigger Binding="{Binding IsSearchVisible, ElementName=Root}" Value="False">
                            <Setter Property="Height" Value="70" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsListVisible, ElementName=Root}" Value="False">
                            <Setter Property="Background" Value="Transparent" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid x:Name="PART_HeaderTitleRow"
                      Margin="0,6,12,0"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Command="{Binding HeaderBackCommand, ElementName=Root}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ListPageHeaderBackButtonStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHeaderBackButtonVisible, ElementName=Root}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Image Grid.Column="1"
                           Width="28"
                           Height="28"
                           Margin="0,0,10,0"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                           SnapsToDevicePixels="True"
                           Source="{Binding TitleIconSource, ElementName=Root}">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TitleIconSource, ElementName=Root}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>

                    <TextBlock Grid.Column="2"
                               Text="{Binding Title, ElementName=Root}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource ListPageHeaderTextStyle}">
                                <Setter Property="Margin" Value="0" />
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                <ContentPresenter Content="{Binding DataContext, ElementName=Root}"
                                  ContentTemplate="{Binding SearchToolbarContentTemplate, ElementName=Root}"
                                  Height="30"
                                  Margin="0,46,12,0"
                                  VerticalAlignment="Top">
                    <ContentPresenter.Style>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSearchToolbarVisible, ElementName=Root}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentPresenter.Style>
                </ContentPresenter>

                <Grid Height="32"
                      VerticalAlignment="Top">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible" />
                            <Setter Property="Margin" Value="0,58,12,0" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSearchVisible, ElementName=Root}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsSearchToolbarVisible, ElementName=Root}" Value="True">
                                    <Setter Property="Margin" Value="0,82,12,0" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox Tag="{Binding ElementName=PART_ListLayer}"
                             Text="{Binding SearchText, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource ListPageSearchBoxStyle}">
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="VerticalAlignment" Value="Stretch" />
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <ContentPresenter Grid.Column="1"
                                      Content="{Binding SearchTrailingContent, ElementName=Root}"
                                      DataContext="{Binding DataContext, ElementName=Root}"
                                      VerticalAlignment="Center">
                        <ContentPresenter.Style>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Margin" Value="10,0,0,0" />
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchTrailingContent, ElementName=Root}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SearchTrailingContent.Visibility, ElementName=Root}" Value="Collapsed">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentPresenter.Style>
                    </ContentPresenter>
                </Grid>

                <ContentPresenter Content="{Binding SearchFilterContent, ElementName=Root}"
                                  ContentTemplate="{Binding SearchFilterContentTemplate, ElementName=Root}"
                                  Height="32"
                                  VerticalAlignment="Top">
                    <ContentPresenter.Style>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Margin" Value="0,100,12,0" />
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSearchFilterVisible, ElementName=Root}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsSearchToolbarVisible, ElementName=Root}" Value="True">
                                    <Setter Property="Margin" Value="0,124,12,0" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentPresenter.Style>
                </ContentPresenter>
            </Grid>
        </Border>

        <Border>
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource ListPageBottomOverlayStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsListVisible, ElementName=Root}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>

        <ContentPresenter Panel.ZIndex="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Content="{Binding FloatingContent, ElementName=Root}" />
    </Grid>
</UserControl>

