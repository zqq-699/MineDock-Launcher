<UserControl x:Class="Launcher.App.Controls.ListPageFrame"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:Launcher.App.Behaviors"
             xmlns:controls="clr-namespace:Launcher.App.Controls"
             xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
             x:Name="Root"
             Focusable="False">
    <Grid>
        <ContentPresenter Content="{Binding OverlayContent, ElementName=Root}" />

        <Grid x:Name="PART_ListLayer"
              behaviors:VerticalEdgeOpacityMask.IsEnabled="{Binding IsListVisible, ElementName=Root}"
              behaviors:VerticalEdgeOpacityMask.TopFadeLength="132"
              behaviors:VerticalEdgeOpacityMask.BottomFadeLength="72"
              behaviors:VerticalEdgeOpacityMask.MinimumOpacity="0">
            <ScrollViewer x:Name="PART_ScrollViewer">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer" BasedOn="{StaticResource ListPageScrollViewerStyle}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsListVisible, ElementName=Root}" Value="True" />
                                    <Condition Binding="{Binding UseFrameScrollViewer, ElementName=Root}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>

                <StackPanel>
                    <Border Style="{StaticResource ListPageHeaderSpacerStyle}" />
                    <ContentPresenter>
                        <ContentPresenter.Style>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Content" Value="{Binding ListContent, ElementName=Root}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UseFrameScrollViewer, ElementName=Root}" Value="False">
                                        <Setter Property="Content" Value="{x:Null}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentPresenter.Style>
                    </ContentPresenter>
                    <Border Style="{StaticResource ListPageBottomSpacerStyle}" />
                </StackPanel>
            </ScrollViewer>

            <ContentPresenter>
                <ContentPresenter.Style>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Content" Value="{x:Null}" />
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsListVisible, ElementName=Root}" Value="True" />
                                    <Condition Binding="{Binding UseFrameScrollViewer, ElementName=Root}" Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Content" Value="{Binding ListContent, ElementName=Root}" />
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentPresenter.Style>
            </ContentPresenter>
        </Grid>

        <Border>
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource ListPageHeaderOverlayStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsListVisible, ElementName=Root}" Value="False">
                            <Setter Property="Background" Value="Transparent" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid Margin="0,6,12,0"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Command="{Binding HeaderBackCommand, ElementName=Root}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ListPageHeaderBackButtonStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHeaderBackButtonVisible, ElementName=Root}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Image Grid.Column="1"
                           Width="28"
                           Height="28"
                           Margin="0,0,10,0"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                           SnapsToDevicePixels="True"
                           Source="{Binding TitleIconSource, ElementName=Root}">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TitleIconSource, ElementName=Root}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>

                    <TextBlock Grid.Column="2"
                               Text="{Binding Title, ElementName=Root}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource ListPageHeaderTextStyle}">
                                <Setter Property="Margin" Value="0" />
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                <TextBox Tag="{Binding ElementName=PART_ListLayer}"
                         Text="{Binding SearchText, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource ListPageSearchBoxStyle}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSearchVisible, ElementName=Root}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </Grid>
        </Border>

        <Border>
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource ListPageBottomOverlayStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsListVisible, ElementName=Root}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>

        <ContentPresenter Panel.ZIndex="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Content="{Binding FloatingContent, ElementName=Root}" />
    </Grid>
</UserControl>
