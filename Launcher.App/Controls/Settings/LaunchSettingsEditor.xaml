<UserControl x:Class="Launcher.App.Controls.LaunchSettingsEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:animation="clr-namespace:Launcher.App.Behaviors.Animation"
             xmlns:controls="clr-namespace:Launcher.App.Controls"
             xmlns:res="clr-namespace:Launcher.App.Resources"
             x:Name="Root"
             Focusable="False">
    <UserControl.Resources>
        <Style x:Key="SettingsOptionRowStyle" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style x:Key="SettingsOptionTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="AdvancedLaunchTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource LauncherDialogWrappingTextBoxStyle}">
            <EventSetter Event="Loaded" Handler="AdvancedLaunchTextBox_OnLoaded" />
            <EventSetter Event="TextChanged" Handler="AdvancedLaunchTextBox_OnTextChanged" />
            <EventSetter Event="SizeChanged" Handler="AdvancedLaunchTextBox_OnSizeChanged" />
        </Style>

        <Style x:Key="AdvancedLaunchEditableTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource AdvancedLaunchTextBoxStyle}">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding ShowModeSelector, ElementName=Root}" Value="True" />
                        <Condition Binding="{Binding AreLaunchSettingsOverridesEnabled, ElementName=Root}" Value="False" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Visibility" Value="Collapsed" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AdvancedLaunchGlobalTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource AdvancedLaunchTextBoxStyle}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="IsEnabled" Value="False" />
            <Setter Property="Text" Value="{x:Static res:Strings.GameSettings_LaunchSettingsModeUseGlobal}" />
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding ShowModeSelector, ElementName=Root}" Value="True" />
                        <Condition Binding="{Binding AreLaunchSettingsOverridesEnabled, ElementName=Root}" Value="False" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Visibility" Value="Visible" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="LaunchSettingsModeOptionTemplate">
            <TextBlock Text="{Binding Title}"
                       Foreground="#F4F4F4"
                       FontSize="13"
                       FontWeight="Normal"
                       VerticalAlignment="Center" />
        </DataTemplate>

        <DataTemplate x:Key="MemorySettingsModeOptionTemplate">
            <TextBlock Text="{Binding Title}"
                       Foreground="#F4F4F4"
                       FontSize="13"
                       FontWeight="Normal"
                       VerticalAlignment="Center" />
        </DataTemplate>
    </UserControl.Resources>

    <StackPanel>
        <Border Margin="0,0,0,26">
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource SectionFieldSurfaceStyle}">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowModeSelector, ElementName=Root}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="180" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{x:Static res:Strings.GameSettings_LaunchSettingsModeLabel}"
                           Style="{StaticResource SettingsOptionTextStyle}" />

                <controls:AnimatedComboBox Grid.Column="1"
                                           ItemsSource="{Binding LaunchSettingsModeOptions, ElementName=Root}"
                                           SelectedItem="{Binding SelectedLaunchSettingsModeOption, ElementName=Root, Mode=TwoWay}"
                                           ItemTemplate="{StaticResource LaunchSettingsModeOptionTemplate}"
                                           Style="{StaticResource LauncherComboBoxStyle}" />
            </Grid>
        </Border>

        <GroupBox Header="{x:Static res:Strings.GameSettings_LaunchSettingsSection}"
                  Style="{StaticResource LauncherContentSectionStyle}">
            <Border Style="{StaticResource SectionFieldSurfaceStyle}">
                <StackPanel>
                    <Grid Style="{StaticResource SettingsOptionRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{x:Static res:Strings.GameSettings_LaunchCheckFilesOption}"
                                   Style="{StaticResource SettingsOptionTextStyle}" />

                        <CheckBox Grid.Column="1"
                                  IsChecked="{Binding LaunchCheckFilesBeforeLaunchEnabled, ElementName=Root, Mode=TwoWay}"
                                  IsEnabled="{Binding AreLaunchSettingsOverridesEnabled, ElementName=Root}"
                                  Style="{StaticResource LauncherSwitchToggleButtonStyle}" />
                    </Grid>

                    <Grid Style="{StaticResource SettingsOptionRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{x:Static res:Strings.GameSettings_LaunchAutoRepairOption}"
                                   Style="{StaticResource SettingsOptionTextStyle}" />

                        <CheckBox Grid.Column="1"
                                  IsChecked="{Binding LaunchAutoRepairMissingFilesEnabled, ElementName=Root, Mode=TwoWay}"
                                  IsEnabled="{Binding CanEditAutoRepairMissingFiles, ElementName=Root}"
                                  Style="{StaticResource LauncherSwitchToggleButtonStyle}" />
                    </Grid>

                    <Grid Style="{StaticResource SettingsOptionRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{x:Static res:Strings.GameSettings_LaunchMinimizeLauncherOption}"
                                   Style="{StaticResource SettingsOptionTextStyle}" />

                        <CheckBox Grid.Column="1"
                                  IsChecked="{Binding LaunchMinimizeLauncherAfterLaunchEnabled, ElementName=Root, Mode=TwoWay}"
                                  IsEnabled="{Binding AreLaunchSettingsOverridesEnabled, ElementName=Root}"
                                  Style="{StaticResource LauncherSwitchToggleButtonStyle}" />
                    </Grid>

                    <Grid Margin="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{x:Static res:Strings.GameSettings_LaunchFullScreenOption}"
                                   Style="{StaticResource SettingsOptionTextStyle}" />

                        <CheckBox Grid.Column="1"
                                  IsChecked="{Binding LaunchFullScreenEnabled, ElementName=Root, Mode=TwoWay}"
                                  IsEnabled="{Binding AreLaunchSettingsOverridesEnabled, ElementName=Root}"
                                  Style="{StaticResource LauncherSwitchToggleButtonStyle}" />
                    </Grid>
                </StackPanel>
            </Border>
        </GroupBox>

        <GroupBox Margin="0,26,0,0"
                  Header="{x:Static res:Strings.Settings_MemorySection}"
                  Style="{StaticResource LauncherContentSectionStyle}">
            <GroupBox.Visibility>
                <Binding ElementName="Root"
                         Path="ShowMemorySettings"
                         Converter="{StaticResource BooleanToMenuTextVisibilityConverter}" />
            </GroupBox.Visibility>
            <Border Style="{StaticResource SectionFieldSurfaceStyle}">
                <StackPanel>
                    <Grid Style="{StaticResource SettingsOptionRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="180" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{x:Static res:Strings.Settings_MemoryModeLabel}"
                                   Style="{StaticResource SettingsOptionTextStyle}" />

                        <controls:AnimatedComboBox Grid.Column="1"
                                                   ItemsSource="{Binding MemorySettingsModeOptions, ElementName=Root}"
                                                   SelectedItem="{Binding SelectedMemorySettingsModeOption, ElementName=Root, Mode=TwoWay}"
                                                   ItemTemplate="{StaticResource MemorySettingsModeOptionTemplate}"
                                                   SelectionItemTemplate="{StaticResource MemorySettingsModeOptionTemplate}"
                                                   IsEnabled="{Binding AreLaunchSettingsOverridesEnabled, ElementName=Root}"
                                                   Style="{StaticResource LauncherComboBoxStyle}" />
                    </Grid>

                    <StackPanel Margin="0,0,0,14"
                                animation:AnimatedCollapse.IsExpanded="{Binding IsMemorySliderVisible, ElementName=Root}">
                        <TextBlock Text="{x:Static res:Strings.Settings_MaxMemoryLabel}"
                                   Style="{StaticResource SettingsOptionTextStyle}"
                                   Margin="0,0,0,10" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="72" />
                            </Grid.ColumnDefinitions>

                            <Slider Minimum="{Binding MemoryMinimumMb, ElementName=Root}"
                                    Maximum="{Binding MemoryMaximumMb, ElementName=Root}"
                                    Value="{Binding MemoryMb, ElementName=Root, Mode=TwoWay}"
                                    IsEnabled="{Binding IsMemorySliderEnabled, ElementName=Root}"
                                    Style="{StaticResource LauncherSliderStyle}" />

                            <TextBlock Grid.Column="1"
                                       Margin="12,0,0,0"
                                       Text="{Binding MemoryValueText, ElementName=Root}"
                                       Foreground="#CFFFFFFF"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       TextAlignment="Right" />
                        </Grid>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{x:Static res:Strings.Settings_SystemMemorySummaryLabel}"
                                       Foreground="{StaticResource LauncherTextSecondaryBrush}"
                                       FontSize="12" />
                            <TextBlock Margin="0,5,0,0"
                                       Text="{Binding SystemMemorySummaryText, ElementName=Root}"
                                       Foreground="#F2F2F2"
                                       FontSize="13" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Margin="18,0,0,0"
                                    HorizontalAlignment="Right"
                                    Visibility="{Binding IsAutomaticMemorySummaryVisible, ElementName=Root, Converter={StaticResource BooleanToMenuTextVisibilityConverter}}">
                            <TextBlock Text="{x:Static res:Strings.Settings_AutomaticMemoryAllocationLabel}"
                                       Foreground="{StaticResource LauncherTextSecondaryBrush}"
                                       FontSize="12"
                                       TextAlignment="Right" />
                            <TextBlock Margin="0,5,0,0"
                                       Text="{Binding AutomaticMemoryText, ElementName=Root}"
                                       Foreground="#F2F2F2"
                                       FontSize="13"
                                       TextAlignment="Right" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </GroupBox>

        <GroupBox Margin="0,26,0,0"
                  Header="{x:Static res:Strings.GameSettings_AdvancedLaunchSettingsSection}"
                  Style="{StaticResource LauncherContentSectionStyle}">
            <Border Style="{StaticResource SectionFieldSurfaceStyle}">
                <StackPanel>
                    <TextBlock Text="{x:Static res:Strings.GameSettings_PreLaunchCommandOption}"
                               Style="{StaticResource SettingsOptionTextStyle}"
                               Margin="0,0,0,8" />
                    <Grid>
                        <TextBox Text="{Binding LaunchPreLaunchCommand, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding AreLaunchSettingsOverridesEnabled, ElementName=Root}"
                                 Style="{StaticResource AdvancedLaunchEditableTextBoxStyle}" />
                        <TextBox Style="{StaticResource AdvancedLaunchGlobalTextBoxStyle}" />
                    </Grid>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{x:Static res:Strings.GameSettings_WaitForPreLaunchCommandOption}"
                                   Style="{StaticResource SettingsOptionTextStyle}" />

                        <CheckBox Grid.Column="1"
                                  IsChecked="{Binding LaunchWaitForPreLaunchCommand, ElementName=Root, Mode=TwoWay}"
                                  IsEnabled="{Binding AreLaunchSettingsOverridesEnabled, ElementName=Root}"
                                  Style="{StaticResource LauncherSwitchToggleButtonStyle}" />
                    </Grid>

                    <TextBlock Text="{x:Static res:Strings.GameSettings_PostExitCommandOption}"
                               Style="{StaticResource SettingsOptionTextStyle}"
                               Margin="0,16,0,8" />
                    <Grid>
                        <TextBox Text="{Binding LaunchPostExitCommand, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding AreLaunchSettingsOverridesEnabled, ElementName=Root}"
                                 Style="{StaticResource AdvancedLaunchEditableTextBoxStyle}" />
                        <TextBox Style="{StaticResource AdvancedLaunchGlobalTextBoxStyle}" />
                    </Grid>

                    <TextBlock Text="{x:Static res:Strings.GameSettings_CustomJvmArgumentsOption}"
                               Style="{StaticResource SettingsOptionTextStyle}"
                               Margin="0,16,0,8" />
                    <Grid>
                        <TextBox Text="{Binding LaunchJvmArguments, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding AreLaunchSettingsOverridesEnabled, ElementName=Root}"
                                 Style="{StaticResource AdvancedLaunchEditableTextBoxStyle}" />
                        <TextBox Style="{StaticResource AdvancedLaunchGlobalTextBoxStyle}" />
                    </Grid>

                    <TextBlock Text="{x:Static res:Strings.GameSettings_CustomGameArgumentsOption}"
                               Style="{StaticResource SettingsOptionTextStyle}"
                               Margin="0,16,0,8" />
                    <Grid>
                        <TextBox Text="{Binding LaunchGameArguments, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding AreLaunchSettingsOverridesEnabled, ElementName=Root}"
                                 Style="{StaticResource AdvancedLaunchEditableTextBoxStyle}" />
                        <TextBox Style="{StaticResource AdvancedLaunchGlobalTextBoxStyle}" />
                    </Grid>
                </StackPanel>
            </Border>
        </GroupBox>
    </StackPanel>
</UserControl>
