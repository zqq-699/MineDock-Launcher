<UserControl x:Class="Launcher.App.Controls.SecondaryMenuOptionButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:Launcher.App.Behaviors"
             xmlns:controls="clr-namespace:Launcher.App.Controls"
             x:Name="Root"
             Margin="0,0,0,3"
             Focusable="False">
    <Button x:Name="PART_Button"
            Margin="0"
            Tag="{Binding ElementName=Root}"
            behaviors:SecondaryMenuButtonBehavior.IsSelected="{Binding IsSelected, ElementName=Root}"
            Style="{StaticResource SecondaryMenuButtonStyle}"
            Command="{Binding Command, ElementName=Root}"
            CommandParameter="{Binding CommandParameter, ElementName=Root}"
            Click="Button_OnClick">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{StaticResource SecondaryMenuIconColumnWidth}" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
            </Grid.ColumnDefinitions>

            <Grid Width="24"
                  Height="24"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
                <Border>
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource SecondaryMenuAvatarContainerStyle}">
                            <Setter Property="Visibility" Value="{Binding AvatarIconVisibility, ElementName=Root}" />
                        </Style>
                    </Border.Style>
                    <Image Source="{Binding AvatarSource, ElementName=Root}"
                           Stretch="Fill"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="NearestNeighbor" />
                </Border>

                <controls:SvgIcon Width="{Binding IconWidth, ElementName=Root}"
                                  Height="{Binding IconHeight, ElementName=Root}"
                                  IconKey="{Binding IconKey, ElementName=Root}"
                                  Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}">
                    <controls:SvgIcon.Style>
                        <Style TargetType="{x:Type controls:SvgIcon}">
                            <Setter Property="Visibility" Value="{Binding SvgIconVisibility, ElementName=Root}" />
                        </Style>
                    </controls:SvgIcon.Style>
                </controls:SvgIcon>

                <TextBlock Text="{Binding Glyph, ElementName=Root}"
                           FontFamily="{Binding GlyphFontFamily, ElementName=Root}"
                           FontSize="{Binding GlyphFontSize, ElementName=Root}"
                           FontWeight="{Binding GlyphFontWeight, ElementName=Root}"
                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                           TextAlignment="Center"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="{Binding GlyphIconVisibility, ElementName=Root}" />
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <TextBlock Grid.Column="1"
                       Text="{Binding Text, ElementName=Root}"
                       Margin="{Binding TextMargin, ElementName=Root}"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="NoWrap"
                       Style="{StaticResource SecondaryMenuItemTextStyle}" />
        </Grid>
    </Button>
</UserControl>

