<UserControl x:Class="Launcher.App.Controls.FloatingMessage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Host"
             Focusable="False"
             IsHitTestVisible="False"
             Opacity="0"
             Visibility="Collapsed">
    <UserControl.RenderTransform>
        <TranslateTransform x:Name="MessageOffset"
                            Y="-10" />
    </UserControl.RenderTransform>

    <Border Style="{StaticResource FloatingMessageSurfaceStyle}">
        <TextBlock Text="{Binding Message, ElementName=Host}"
                   Style="{StaticResource FloatingMessageTextStyle}" />
    </Border>
</UserControl>

