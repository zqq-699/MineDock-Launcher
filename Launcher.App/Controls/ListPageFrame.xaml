<UserControl x:Class="Launcher.App.Controls.ListPageFrame"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Launcher.App.Controls"
             xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
             x:Name="Root"
             Focusable="False">
    <Grid shell:WindowChrome.IsHitTestVisibleInChrome="True">
        <ContentPresenter Content="{Binding OverlayContent, ElementName=Root}" />

        <ScrollViewer x:Name="PART_ScrollViewer">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer" BasedOn="{StaticResource ListPageScrollViewerStyle}">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsListVisible, ElementName=Root}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>

            <StackPanel>
                <Border Style="{StaticResource ListPageHeaderSpacerStyle}" />
                <ContentPresenter Content="{Binding ListContent, ElementName=Root}" />
                <Border Style="{StaticResource ListPageBottomSpacerStyle}" />
            </StackPanel>
        </ScrollViewer>

        <Border Style="{StaticResource ListPageHeaderOverlayStyle}">
            <Grid>
                <TextBlock Text="{Binding Title, ElementName=Root}"
                           Style="{StaticResource ListPageHeaderTextStyle}" />
                <TextBox Tag="{Binding ElementName=PART_ScrollViewer}"
                         Text="{Binding SearchText, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource ListPageSearchBoxStyle}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSearchVisible, ElementName=Root}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </Grid>
        </Border>

        <Border Style="{StaticResource ListPageBottomOverlayStyle}" />

        <ContentPresenter Panel.ZIndex="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Content="{Binding FloatingContent, ElementName=Root}" />
    </Grid>
</UserControl>
