<UserControl x:Class="Launcher.App.Controls.DialogHost"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Launcher.App.Controls"
             x:Name="Host"
             Focusable="False">
    <Grid x:Name="RootOverlay"
          Style="{StaticResource DialogOverlayStyle}">
        <Border Width="{Binding DialogWidth, ElementName=Host}"
                Style="{StaticResource DialogShadowStyle}" />
        <Border x:Name="Surface"
                Width="{Binding DialogWidth, ElementName=Host}"
                Style="{StaticResource DialogSurfaceStyle}">
            <Grid ClipToBounds="True">
                <Border Background="{DynamicResource Brush.FF252525}" />
                <controls:BackdropBlurBorder x:Name="BlurLayer"
                                             BlurRadius="42"
                                             TintBrush="{DynamicResource Brush.00252525}"
                                             Style="{StaticResource DialogBlurLayerStyle}" />
                <Border Background="{DynamicResource Brush.8A252525}" />
                <ContentPresenter Content="{Binding DialogContent, ElementName=Host}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>

